    line-height: 1.5;\n  }\n\n  /* =========================\n     DESKTOP ARROWS\n  ========================= */\n\n  .sorelya-pain-slider__arrow {\n    position: absolute;\n    top: 49%;\n    z-index: 5;\n    display: none;\n    align-items: center;\n    justify-content: center;\n    width: 58px;\n    height: 58px;\n    padding: 0;\n    border: 0;\n    border-radius: 50%;\n    background: #fff;\n    color: #111;\n    box-shadow: 0 3px 12px rgba(0, 0, 0, 0.12);\n    cursor: pointer;\n    transform: translateY(-50%);\n  }\n\n  .sorelya-pain-slider__arrow--prev {\n    left: 18px;\n  }\n\n  .sorelya-pain-slider__arrow--next {\n    right: 18px;\n  }\n\n  .sorelya-pain-slider__arrow svg {\n    width: 25px;\n    height: 25px;\n    fill: none;\n    stroke: currentColor;\n    stroke-width: 2;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n\n  /* =========================\n     DOTS\n  ========================= */\n\n  .sorelya-pain-slider__dots {\n    display: none;\n    align-items: center;\n    justify-content: center;\n    gap: 9px;\n    margin-top: 22px;\n  }\n\n  .sorelya-pain-slider__dot {\n    width: 8px;\n    height: 8px;\n    padding: 0;\n    border: 0;\n    border-radius: 50%;\n    background: rgba(255, 255, 255, 0.45);\n    cursor: pointer;\n    transition:\n      width 0.2s ease,\n      background-color 0.2s ease;\n  }\n\n  .sorelya-pain-slider__dot.active {\n    width: 24px;\n    border-radius: 999px;\n    background: #fff;\n  }\n\n  /* =========================\n     MOBILE\n  ========================= */\n\n  @media (max-width: 749px) {\n    .sorelya-pain-slider {\n      padding: 32px 0 26px;\n    }\n\n    .sorelya-pain-slider__heading {\n      margin-bottom: 24px;\n      padding: 0 20px;\n      font-size: 31px;\n    }\n\n    .sorelya-pain-slider__track {\n      display: flex;\n      gap: 14px;\n      width: 100%;\n      padding: 0 18px;\n      overflow-x: auto;\n      overscroll-behavior-x: contain;\n      scroll-behavior: smooth;\n      scroll-snap-type: x mandatory;\n      scrollbar-width: none;\n      -webkit-overflow-scrolling: touch;\n      touch-action: pan-x;\n    }\n\n    .sorelya-pain-slider__track::-webkit-scrollbar {\n      display: none;\n    }\n\n    .sorelya-pain-card {\n      flex: 0 0 100%;\n      width: 100%;\n    }\n\n    .sorelya-pain-card__image-wrap {\n      border-radius: 9px;\n    }\n\n    .sorelya-pain-card__content {\n      padding: 18px 8px 0;\n    }\n\n    .sorelya-pain-card__title {\n      margin-bottom: 9px;\n      font-size: 22px;\n      line-height: 1.15;\n    }\n\n    .sorelya-pain-card__text {\n      max-width: 340px;\n      font-size: 15px;\n      line-height: 1.48;\n    }\n\n    .sorelya-pain-slider__dots {\n      display: flex;\n    }\n  }\n</style>\n\n<section\n  class=\"sorelya-pain-slider\"\n  data-sorelya-pain-slider\n>\n  <div class=\"sorelya-pain-slider__inner\">\n\n    <h2 class=\"sorelya-pain-slider__heading\">\n      Does This Sound Familiar?\n    </h2>\n\n    <div\n      class=\"sorelya-pain-slider__track\"\n      data-sorelya-pain-track\n    >\n\n      <!-- SLIDE 1 -->\n      <article\n        class=\"sorelya-pain-card\"\n        data-sorelya-pain-card\n      >\n        <div class=\"sorelya-pain-card__image-wrap\">\n          <img\n            class=\"sorelya-pain-card__image\"\n            src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/ChatGPT_Image_21_juil._2026_03_42_34_430x.png?v=1784601775\"\n            alt=\"A drawer filled with unused lipsticks\"\n            loading=\"lazy\"\n          >\n        </div>\n\n        <div class=\"sorelya-pain-card__content\">\n          <h3 class=\"sorelya-pain-card__title\">\n            The Drawer Full of Regrets\n          </h3>\n\n          <p class=\"sorelya-pain-card__text\">\n            Beautiful in the store. Orange, harsh or completely wrong\n            once you put it on.\n          </p>\n        </div>\n      </article>\n\n      <!-- SLIDE 2 -->\n      <article\n        class=\"sorelya-pain-card\"\n        data-sorelya-pain-card\n      >\n        <div class=\"sorelya-pain-card__image-wrap\">\n          <img\n            class=\"sorelya-pain-card__image\"\n            src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/ChatGPT_Image_21_juil._2026_03_42_36_430x.png?v=1784601776\"\n            alt=\"A mature woman reapplying lipstick in a parked car\"\n            loading=\"lazy\"\n          >\n        </div>\n\n        <div class=\"sorelya-pain-card__content\">\n          <h3 class=\"sorelya-pain-card__title\">\n            Touch-Ups Every Two Hours\n          </h3>\n\n          <p class=\"sorelya-pain-card__text\">\n            After every coffee, every meal and every meeting—back to\n            the mirror.\n          </p>\n        </div>\n      </article>\n\n      <!-- SLIDE 3 -->\n      <article\n        class=\"sorelya-pain-card\"\n        data-sorelya-pain-card\n      >\n        <div class=\"sorelya-pain-card__image-wrap\">\n          <img\n            class=\"sorelya-pain-card__image\"\n            src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/ChatGPT_Image_21_juil._2026_03_42_38_430x.png?v=1784601775\"\n            alt=\"A mature woman noticing dry uncomfortable lips\"\n            loading=\"lazy\"\n          >\n        </div>\n\n        <div class=\"sorelya-pain-card__content\">\n          <h3 class=\"sorelya-pain-card__title\">\n            Dry, Tight Lips by Noon\n          </h3>\n\n          <p class=\"sorelya-pain-card__text\">\n            That papery feeling that only gets worse as the hours\n            pass.\n          </p>\n        </div>\n      </article>\n\n    </div>\n\n    <button\n      class=\"sorelya-pain-slider__arrow sorelya-pain-slider__arrow--prev\"\n      type=\"button\"\n      aria-label=\"Previous slide\"\n      data-sorelya-pain-prev\n    >\n      <svg viewBox=\"0 0 24 24\">\n        <polyline points=\"15 18 9 12 15 6\"></polyline>\n      </svg>\n    </button>\n\n    <button\n      class=\"sorelya-pain-slider__arrow sorelya-pain-slider__arrow--next\"\n      type=\"button\"\n      aria-label=\"Next slide\"\n      data-sorelya-pain-next\n    >\n      <svg viewBox=\"0 0 24 24\">\n        <polyline points=\"9 18 15 12 9 6\"></polyline>\n      </svg>\n    </button>\n\n    <div class=\"sorelya-pain-slider__dots\">\n      <button\n        class=\"sorelya-pain-slider__dot active\"\n        type=\"button\"\n        aria-label=\"Show problem 1\"\n        data-sorelya-pain-dot=\"0\"\n      ></button>\n\n      <button\n        class=\"sorelya-pain-slider__dot\"\n        type=\"button\"\n        aria-label=\"Show problem 2\"\n        data-sorelya-pain-dot=\"1\"\n      ></button>\n\n      <button\n        class=\"sorelya-pain-slider__dot\"\n        type=\"button\"\n        aria-label=\"Show problem 3\"\n        data-sorelya-pain-dot=\"2\"\n      ></button>\n    </div>\n\n  </div>\n</section>\n\n<script>\n  (function () {\n    document\n      .querySelectorAll('[data-sorelya-pain-slider]')\n      .forEach(function (slider) {\n        var track = slider.querySelector(\n          '[data-sorelya-pain-track]'\n        );\n\n        var cards = Array.from(\n          slider.querySelectorAll(\n            '[data-sorelya-pain-card]'\n          )\n        );\n\n        var dots = Array.from(\n          slider.querySelectorAll(\n            '[data-sorelya-pain-dot]'\n          )\n        );\n\n        if (!track || !cards.length) return;\n\n        function setActiveDot(index) {\n          dots.forEach(function (dot, dotIndex) {\n            dot.classList.toggle(\n              'active',\n              dotIndex === index\n            );\n          });\n        }\n\n        function scrollToCard(index) {\n          if (!cards[index]) return;\n\n          track.scrollTo({\n            left: cards[index].offsetLeft - track.offsetLeft,\n            behavior: 'smooth'\n          });\n\n          setActiveDot(index);\n        }\n\n        /* Always begin on first slide */\n        requestAnimationFrame(function () {\n          track.scrollLeft = 0;\n          setActiveDot(0);\n        });\n\n        if ('IntersectionObserver' in window) {\n          var observer = new IntersectionObserver(\n            function (entries) {\n              entries.forEach(function (entry) {\n                if (\n                  entry.isIntersecting &&\n                  entry.intersectionRatio >= 0.65\n                ) {\n                  var index = cards.indexOf(entry.target);\n\n                  if (index >= 0) {\n                    setActiveDot(index);\n                  }\n                }\n              });\n            },\n            {\n              root: track,\n              threshold: [0.4, 0.65, 0.9]\n            }\n          );\n\n          cards.forEach(function (card) {\n            observer.observe(card);\n          });\n        }\n\n        dots.forEach(function (dot, index) {\n          dot.addEventListener('click', function () {\n            scrollToCard(index);\n          });\n        });\n      });\n  })();\n</script>",
