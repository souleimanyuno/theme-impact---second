    "custom_liquid_Pktczq": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": true,
        "liquid": "<style>\n  .sorelya-experts,\n  .sorelya-experts * {\n    box-sizing: border-box;\n  }\n\n  .sorelya-experts {\n    width: 100%;\n    padding: 42px 18px 42px;\n    background: #b88c66;\n    color: #fff;\n    font-family: Arial, Helvetica, sans-serif;\n  }\n\n  .sorelya-experts__inner {\n    width: 100%;\n    max-width: 1100px;\n    margin: 0 auto;\n  }\n\n  /* =========================\n     HEADER\n  ========================= */\n\n  .sorelya-experts__heading {\n    margin: 0 0 12px;\n    color: #fff;\n    font-size: clamp(31px, 4.5vw, 62px);\n    font-weight: 900;\n    line-height: 1.03;\n    text-align: center;\n    letter-spacing: -0.045em;\n    text-transform: uppercase;\n  }\n\n  .sorelya-experts__subheading {\n    max-width: 760px;\n    margin: 0 auto 28px;\n    color: rgba(255, 255, 255, 0.88);\n    font-size: 16px;\n    font-weight: 500;\n    line-height: 1.55;\n    text-align: center;\n  }\n\n  /* =========================\n     LIST\n  ========================= */\n\n  .sorelya-experts__list {\n    display: flex;\n    flex-direction: column;\n    gap: 14px;\n  }\n\n  .sorelya-expert {\n    display: flex;\n    align-items: flex-start;\n    gap: 18px;\n    padding: 18px;\n    border: 1px solid rgba(255, 255, 255, 0.18);\n    border-radius: 18px;\n    background: rgba(255, 255, 255, 0.08);\n    backdrop-filter: blur(2px);\n  }\n\n  /* =========================\n     AVATAR\n  ========================= */\n\n  .sorelya-expert__avatar-wrap {\n    flex: 0 0 auto;\n  }\n\n  .sorelya-expert__avatar {\n    display: block;\n    width: 76px;\n    height: 76px;\n    border-radius: 999px;\n    object-fit: cover;\n    border: 2px solid rgba(255, 255, 255, 0.28);\n  }\n\n  /* =========================\n     CONTENT\n  ========================= */\n\n  .sorelya-expert__content {\n    min-width: 0;\n    flex: 1 1 auto;\n  }\n\n  .sorelya-expert__name {\n    margin: 0 0 4px;\n    color: #fff;\n    font-size: 22px;\n    font-weight: 900;\n    line-height: 1.1;\n    letter-spacing: -0.025em;\n    text-transform: uppercase;\n  }\n\n  .sorelya-expert__role {\n    margin: 0 0 10px;\n    color: rgba(255, 255, 255, 0.78);\n    font-size: 12px;\n    font-weight: 800;\n    line-height: 1.2;\n    letter-spacing: 0.08em;\n    text-transform: uppercase;\n  }\n\n  .sorelya-expert__quote {\n    margin: 0;\n    color: rgba(255, 255, 255, 0.96);\n    font-size: 16px;\n    font-weight: 500;\n    line-height: 1.6;\n  }\n\n  .sorelya-expert__quote::before {\n    content: \"“\";\n  }\n\n  .sorelya-expert__quote::after {\n    content: \"”\";\n  }\n\n  /* =========================\n     MOBILE\n  ========================= */\n\n  @media (max-width: 749px) {\n    .sorelya-experts {\n      padding: 34px 14px 34px;\n    }\n\n    .sorelya-experts__heading {\n      font-size: 29px;\n      line-height: 1.06;\n    }\n\n    .sorelya-experts__subheading {\n      margin-bottom: 22px;\n      font-size: 14px;\n      line-height: 1.5;\n    }\n\n    .sorelya-experts__list {\n      gap: 12px;\n    }\n\n    .sorelya-expert {\n      gap: 13px;\n      padding: 15px 14px;\n      border-radius: 16px;\n    }\n\n    .sorelya-expert__avatar {\n      width: 58px;\n      height: 58px;\n    }\n\n    .sorelya-expert__name {\n      font-size: 17px;\n    }\n\n    .sorelya-expert__role {\n      margin-bottom: 8px;\n      font-size: 10.5px;\n      letter-spacing: 0.07em;\n    }\n\n    .sorelya-expert__quote {\n      font-size: 14px;\n      line-height: 1.52;\n    }\n  }\n</style>\n\n<section class=\"sorelya-experts\">\n  <div class=\"sorelya-experts__inner\">\n\n    <h2 class=\"sorelya-experts__heading\">\n      Trusted by Skin Professionals\n    </h2>\n\n    <p class=\"sorelya-experts__subheading\">\n      Why mature-lip comfort, soft color and a more flattering finish matter.\n    </p>\n\n    <div class=\"sorelya-experts__list\">\n\n      <!-- EXPERT 1 -->\n      <article class=\"sorelya-expert\">\n        <div class=\"sorelya-expert__avatar-wrap\">\n          <img\n            class=\"sorelya-expert__avatar\"\n            src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/med1_430x.avif?v=1784602883\"\n            alt=\"Dr. Marco Rinaldi\"\n            loading=\"lazy\"\n          >\n        </div>\n\n        <div class=\"sorelya-expert__content\">\n          <h3 class=\"sorelya-expert__name\">Dr. Marco Rinaldi</h3>\n          <p class=\"sorelya-expert__role\">Dermatologist</p>\n          <p class=\"sorelya-expert__quote\">\n            Mature lips often need comfort just as much as color. What I like about this type of formula is that it gives a softer-looking tint without the heavy, dry finish many traditional lipsticks can leave behind.\n          </p>\n        </div>\n      </article>\n\n      <!-- EXPERT 2 -->\n      <article class=\"sorelya-expert\">\n        <div class=\"sorelya-expert__avatar-wrap\">\n          <img\n            class=\"sorelya-expert__avatar\"\n            src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/med2_430x.webp?v=1784602882\"\n            alt=\"Dr. Elena Ferraro\"\n            loading=\"lazy\"\n          >\n        </div>\n\n        <div class=\"sorelya-expert__content\">\n          <h3 class=\"sorelya-expert__name\">Dr. Elena Ferraro</h3>\n          <p class=\"sorelya-expert__role\">Dermatologist</p>\n          <p class=\"sorelya-expert__quote\">\n            Many women stop wearing lipstick because it starts to feel drying or settles into the fine lines around the mouth. A more comfortable, balm-like texture can make color feel wearable again.\n          </p>\n        </div>\n      </article>\n\n      <!-- EXPERT 3 -->\n      <article class=\"sorelya-expert\">\n        <div class=\"sorelya-expert__avatar-wrap\">\n          <img\n            class=\"sorelya-expert__avatar\"\n            src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/med3_430x.webp?v=1784602881\"\n            alt=\"Dr. Giulia Marchetti\"\n            loading=\"lazy\"\n          >\n        </div>\n\n        <div class=\"sorelya-expert__content\">\n          <h3 class=\"sorelya-expert__name\">Dr. Giulia Marchetti</h3>\n          <p class=\"sorelya-expert__role\">Dermatologist</p>\n          <p class=\"sorelya-expert__quote\">\n            The most flattering lip products are usually the ones that work with the lips rather than covering them. A lightweight tint with a natural-looking finish tends to be more forgiving and easier to wear throughout the day.\n          </p>\n        </div>\n      </article>\n\n    </div>\n\n  </div>\n</section>",
        "background": "",
        "background_gradient": "",
        "text_color": ""
      }
    },
    "custom_liquid_WgJTim": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
