        "liquid": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');\n\n  .sorelya-comparison {\n    width: 100%;\n    max-width: 960px;\n    margin: 0 auto;\n    padding: 34px 12px;\n    font-family: 'Inter', sans-serif;\n  }\n\n  .sorelya-comparison__card {\n    background: #ffffff;\n    border: 1.5px solid #e3e8df;\n    border-radius: 18px;\n    overflow: hidden;\n    box-shadow: 0 8px 26px rgba(25, 45, 20, 0.07);\n  }\n\n  .sorelya-comparison__content {\n    padding: 26px 20px 20px;\n    text-align: left;\n  }\n\n  .sorelya-comparison__eyebrow {\n    display: inline-flex;\n    align-items: center;\n    gap: 7px;\n    background: #eef5e9;\n    color: #5f873f;\n    border-radius: 999px;\n    padding: 6px 11px;\n    margin-bottom: 13px;\n    font-size: 11px;\n    font-weight: 800;\n    line-height: 1;\n    letter-spacing: 0.06em;\n    text-transform: uppercase;\n  }\n\n  .sorelya-comparison__eyebrow svg {\n    width: 14px;\n    height: 14px;\n    stroke: #78a953;\n    fill: none;\n    stroke-width: 2.2;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n\n  .sorelya-comparison__title {\n    margin: 0 0 11px;\n    color: #111111;\n    font-size: 28px;\n    font-weight: 900;\n    line-height: 1.12;\n    letter-spacing: -0.035em;\n  }\n\n  .sorelya-comparison__title span {\n    color: #78a953;\n  }\n\n  .sorelya-comparison__description {\n    margin: 0;\n    max-width: 720px;\n    color: #4b4b4b;\n    font-size: 15px;\n    font-weight: 400;\n    line-height: 1.55;\n  }\n\n  .sorelya-comparison__description strong {\n    color: #111111;\n    font-weight: 800;\n  }\n\n  .sorelya-comparison__image-wrap {\n    width: 100%;\n    padding: 0 10px 12px;\n    background: #ffffff;\n  }\n\n  .sorelya-comparison__image {\n    display: block;\n    width: 100%;\n    height: auto;\n    border-radius: 12px;\n  }\n\n  @media (min-width: 769px) {\n    .sorelya-comparison {\n      padding: 48px 20px;\n    }\n\