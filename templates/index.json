    "custom_liquid_q4d3Ea": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": true,
        "liquid": "<div class=\"sv-compare-section\">\n  <h2 class=\"sv-compare-title\">Why SkinVeil™ beats everything else.</h2>\n\n  <div class=\"sv-compare-table\">\n\n    <!-- HEADER -->\n    <div class=\"sv-compare-header\">\n      <div class=\"sv-col-feature\"></div>\n      <div class=\"sv-col-us\">\n        <div class=\"sv-us-badge\">\n          <span class=\"sv-us-logo\">SORELYA</span>\n          <span class=\"sv-us-sub\">SkinVeil™</span>\n        </div>\n      </div>\n      <div class=\"sv-col-other\">Regular Foundation</div>\n      <div class=\"sv-col-other\">Self-Tanner</div>\n    </div>\n\n    <!-- ROWS -->\n    <div class=\"sv-compare-row\">\n      <div class=\"sv-col-feature\">Covers thread veins, stretch marks & scars</div>\n      <div class=\"sv-col-us\"><span class=\"sv-check\">✓</span></div>\n      <div class=\"sv-col-other\"><span class=\"sv-partial\">~</span></div>\n      <div class=\"sv-col-other\"><span class=\"sv-cross\">✕</span></div>\n    </div>\n\n    <div class=\"sv-compare-row\">\n      <div class=\"sv-col-feature\">No transfer on clothes, sheets or towels</div>\n      <div class=\"sv-col-us\"><span class=\"sv-check\">✓</span></div>\n      <div class=\"sv-col-other\"><span class=\"sv-cross\">✕</span></div>\n      <div class=\"sv-col-other\"><span class=\"sv-cross\">✕</span></div>\n    </div>\n\n    <div class=\"sv-compare-row\">\n      <div class=\"sv-col-feature\">Waterproof, sweat-resistant & sun-safe</div>\n      <div class=\"sv-col-us\"><span class=\"sv-check\">✓</span></div>\n      <div class=\"sv-col-other\"><span class=\"sv-cross\">✕</span></div>\n      <div class=\"sv-col-other\"><span class=\"sv-partial\">~</span></div>\n    </div>\n\n    <div class=\"sv-compare-row\">\n      <div class=\"sv-col-feature\">Dries in 10 minutes</div>\n      <div class=\"sv-col-us\"><span class=\"sv-check\">✓</span></div>\n      <div class=\"sv-col-other\"><span class=\"sv-partial\">~</span></div>\n      <div class=\"sv-col-other\"><span class=\"sv-cross\">✕</span></div>\n    </div>\n\n    <div class=\"sv-compare-row\">\n      <div class=\"sv-col-feature\">Remove whenever you want, in the shower</div>\n      <div class=\"sv-col-us\"><span class=\"sv-check\">✓</span></div>\n      <div class=\"sv-col-other\"><span class=\"sv-check sv-check-dark\">✓</span></div>\n      <div class=\"sv-col-other\"><span class=\"sv-cross\">✕</span></div>\n    </div>\n\n    <div class=\"sv-compare-row\">\n      <div class=\"sv-col-feature\">Precise shade match, zero orange cast</div>\n      <div class=\"sv-col-us\"><span class=\"sv-check\">✓</span></div>\n      <div class=\"sv-col-other\"><span class=\"sv-partial\">~</span></div>\n      <div class=\"sv-col-other\"><span class=\"sv-cross\">✕</span></div>\n    </div>\n\n    <div class=\"sv-compare-row sv-last-row\">\n      <div class=\"sv-col-feature\">Zero DHA, zero chemical bronzing agents</div>\n      <div class=\"sv-col-us\"><span class=\"sv-check\">✓</span></div>\n      <div class=\"sv-col-other\"><span class=\"sv-check sv-check-dark\">✓</span></div>\n      <div class=\"sv-col-other\"><span class=\"sv-cross\">✕</span></div>\n    </div>\n\n  </div>\n</div>\n\n<style>\n.sv-compare-section {\n  padding: 36px 16px 28px;\n  background: #ffffff;\n  font-family: -apple-system, 'Helvetica Neue', Arial, sans-serif;\n}\n\n.sv-compare-title {\n  font-family: Georgia, serif;\n  font-size: 24px;\n  font-style: italic;\n  color: #1a1a2e;\n  margin: 0 0 24px;\n  line-height: 1.3;\n  text-align: left;\n}\n\n.sv-compare-table {\n  width: 100%;\n  border-radius: 16px;\n  overflow: hidden;\n}\n\n.sv-compare-header,\n.sv-compare-row {\n  display: grid;\n  grid-template-columns: 1fr 56px 56px 56px;\n  align-items: center;\n  gap: 0;\n}\n\n.sv-compare-header {\n  margin-bottom: 4px;\n}\n\n.sv-compare-header .sv-col-feature {\n  background: transparent;\n}\n\n/* US COLUMN HEADER */\n.sv-col-us {\n  background: linear-gradient(180deg, #2a2040 0%, #8b7355 100%);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  padding: 16px 8px;\n  border-radius: 14px 14px 0 0;\n}\n\n.sv-us-badge {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 2px;\n}\n\n.sv-us-logo {\n  font-size: 10px;\n  font-weight: 800;\n  color: #fff;\n  letter-spacing: 1px;\n  text-transform: uppercase;\n}\n\n.sv-us-sub {\n  font-family: Georgia, serif;\n  font-size: 11px;\n  font-style: italic;\n  color: #c9a84c;\n}\n\n/* OTHER COLUMNS HEADER */\n.sv-col-other {\n  font-size: 11px;\n  font-weight: 600;\n  color: #999;\n  text-align: center;\n  padding: 12px 4px;\n  line-height: 1.3;\n  background: #efefef;\n  border-radius: 14px 14px 0 0;\n  margin: 0 2px;\n}\n\n/* ROWS */\n.sv-compare-row {\n  border-bottom: 1px solid #ece8e4;\n}\n\n.sv-compare-row:last-child {\n  border-bottom: none;\n}\n\n/* FEATURE COLUMN */\n.sv-col-feature {\n  font-size: 13px;\n  font-weight: 600;\n  color: #1a1a2e;\n  line-height: 1.4;\n  background: #f5f5f5;\n  padding: 14px 10px;\n  border-bottom: 1px solid #ece8e4;\n}\n\n/* US COLUMN ROWS */\n.sv-compare-row .sv-col-us {\n  background: linear-gradient(180deg, #2a2040 0%, #8b7355 100%);\n  border-radius: 0;\n  padding: 14px 8px;\n}\n\n.sv-last-row .sv-col-us {\n  border-radius: 0 0 14px 14px;\n}\n\n/* OTHER COLUMN ROWS */\n.sv-compare-row .sv-col-other {\n  background: #efefef;\n  border-radius: 0;\n  padding: 14px 8px;\n  border-bottom: 1px solid #e5e5e5;\n  font-size: 13px;\n  font-weight: 400;\n  margin: 0 2px;\n}\n\n.sv-last-row .sv-col-other {\n  border-radius: 0 0 14px 14px;\n  border-bottom: none;\n}\n\n/* ICONS */\n.sv-check {\n  width: 28px;\n  height: 28px;\n  border-radius: 50%;\n  border: 2px solid rgba(255,255,255,0.6);\n  color: #fff;\n  font-size: 14px;\n  font-weight: 700;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  margin: 0 auto;\n}\n\n.sv-check-dark {\n  border-color: rgba(0,0,0,0.2);\n  color: #555;\n  background: rgba(0,0,0,0.06);\n}\n\n.sv-cross {\n  width: 28px;\n  height: 28px;\n  border-radius: 50%;\n  background: #1a1a2e;\n  color: #fff;\n  font-size: 13px;\n  font-weight: 700;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  margin: 0 auto;\n}\n\n.sv-partial {\n  width: 28px;\n  height: 28px;\n  border-radius: 50%;\n  background: #b8a080;\n  color: #fff;\n  font-size: 16px;\n  font-weight: 700;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  margin: 0 auto;\n  line-height: 1;\n}\n</style>",
