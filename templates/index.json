   Helps stay out of fine lip lines\n          </div>\n\n          <div class=\"sorelya-compare__cell sorelya-compare__cell--sorelya\" role=\"cell\">\n            <span class=\"sorelya-compare__icon sorelya-compare__icon--check\">\n              <svg viewBox=\"0 0 24 24\">\n                <polyline points=\"20 6 9 17 4 12\"></polyline>\n              </svg>\n            </span>\n          </div>\n\n          <div class=\"sorelya-compare__cell\" role=\"cell\">\n            <span class=\"sorelya-compare__icon sorelya-compare__icon--cross\">\n              <svg viewBox=\"0 0 24 24\">\n                <line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"></line>\n                <line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"></line>\n              </svg>\n            </span>\n          </div>\n        </div>\n\n        <!-- ROW 3 -->\n        <div class=\"sorelya-compare__row\" role=\"row\">\n          <div class=\"sorelya-compare__cell sorelya-compare__cell--feature\" role=\"cell\">\n            Balm-like comfort\n          </div>\n\n          <div class=\"sorelya-compare__cell sorelya-compare__cell--sorelya\" role=\"cell\">\n            <span class=\"sorelya-compare__icon sorelya-compare__icon--check\">\n              <svg viewBox=\"0 0 24 24\">\n                <polyline points=\"20 6 9 17 4 12\"></polyline>\n              </svg>\n            </span>\n          </div>\n\n          <div class=\"sorelya-compare__cell\" role=\"cell\">\n            <span class=\"sorelya-compare__icon sorelya-compare__icon--cross\">\n              <svg viewBox=\"0 0 24 24\">\n                <line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"></line>\n                <line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"></line>\n              </svg>\n            </span>\n          </div>\n        </div>\n\n        <!-- ROW 4 -->\n        <div class=\"sorelya-compare__row\" role=\"row\">\n          <div class=\"sorelya-compare__cell sorelya-compare__cell--feature\" role=\"cell\">\n            Made with mature lips in mind\n          </div>\n\n          <div class=\"sorelya-compare__cell sorelya-compare__cell--sorelya\" role=\"cell\">\n            <span class=\"sorelya-compare__icon sorelya-compare__icon--check\">\n              <svg viewBox=\"0 0 24 24\">\n                <polyline points=\"20 6 9 17 4 12\"></polyline>\n              </svg>\n            </span>\n          </div>\n\n          <div class=\"sorelya-compare__cell\" role=\"cell\">\n            <span class=\"sorelya-compare__icon sorelya-compare__icon--cross\">\n              <svg viewBox=\"0 0 24 24\">\n                <line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"></line>\n                <line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"></line>\n              </svg>\n            </span>\n          </div>\n        </div>\n\n        <!-- ROW 5 -->\n        <div class=\"sorelya-compare__row\" role=\"row\">\n          <div class=\"sorelya-compare__cell sorelya-compare__cell--feature\" role=\"cell\">\n            No shade chart or guessing\n          </div>\n\n          <div class=\"sorelya-compare__cell sorelya-compare__cell--sorelya\" role=\"cell\">\n            <span class=\"sorelya-compare__icon sorelya-compare__icon--check\">\n              <svg viewBox=\"0 0 24 24\">\n                <polyline points=\"20 6 9 17 4 12\"></polyline>\n              </svg>\n            </span>\n          </div>\n\n          <div class=\"sorelya-compare__cell\" role=\"cell\">\n            <span class=\"sorelya-compare__icon sorelya-compare__icon--cross\">\n              <svg viewBox=\"0 0 24 24\">\n                <line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"></line>\n                <line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"></line>\n              </svg>\n            </span>\n          </div>\n        </div>\n\n        <!-- ROW 6 -->\n        <div class=\"sorelya-compare__row\" role=\"row\">\n          <div class=\"sorelya-compare__cell sorelya-compare__cell--feature\" role=\"cell\">\n            Soft, natural-looking finish\n          </div>\n\n          <div class=\"sorelya-compare__cell sorelya-compare__cell--sorelya\" role=\"cell\">\n            <span class=\"sorelya-compare__icon sorelya-compare__icon--check\">\n              <svg viewBox=\"0 0 24 24\">\n                <polyline points=\"20 6 9 17 4 12\"></polyline>\n              </svg>\n            </span>\n          </div>\n\n          <div class=\"sorelya-compare__cell\" role=\"cell\">\n            <span class=\"sorelya-compare__icon sorelya-compare__icon--cross\">\n              <svg viewBox=\"0 0 24 24\">\n                <line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"></line>\n                <line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"></line>\n              </svg>\n            </span>\n          </div>\n        </div>\n\n        <!-- ROW 7 -->\n        <div class=\"sorelya-compare__row\" role=\"row\">\n          <div class=\"sorelya-compare__cell sorelya-compare__cell--feature\" role=\"cell\">\n            Designed for fewer touch-ups\n          </div>\n\n          <div class=\"sorelya-compare__cell sorelya-compare__cell--sorelya\" role=\"cell\">\n            <span class=\"sorelya-compare__icon sorelya-compare__icon--check\">\n              <svg viewBox=\"0 0 24 24\">\n                <polyline points=\"20 6 9 17 4 12\"></polyline>\n              </svg>\n            </span>\n          </div>\n\n          <div class=\"sorelya-compare__cell\" role=\"cell\">\n            <span class=\"sorelya-compare__icon sorelya-compare__icon--cross\">\n              <svg viewBox=\"0 0 24 24\">\n                <line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"></line>\n                <line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"></line>\n              </svg>\n            </span>\n          </div>\n        </div>\n\n      </div>\n\n      <p class=\"sorelya-compare__note\">\n        Comparison reflects typical conventional lipstick formats.\n        Individual formulas may vary.\n      </p>\n\n    </div>\n  </div>\n</section>",
