        "collapsible_text_yQXtGn": {
          "type": "collapsible_text",
          "settings": {
            "icon": "none",
            "icon_width": 20,
            "title": "Performance-Tested Winter Protection",
            "content": "<p>Discover <strong>ELORYA winter boots :</strong> your all-day <strong>solution for cold, cramped feet and slippery conditions</strong>, without the bulk or discomfort of traditional winter boots.</p><p>Thanks to advanced insulation, a wide anatomical toe box, and aggressive non-slip treads, <strong>ELORYA targets the root causes of winter foot pain</strong> — keeping you warm, stable, and comfortable from the first step.</p><p>Tested in real winters and backed by thousands of satisfied customers, <strong>ELORYA delivers immediate comfort, superior traction, and long-lasting durability</strong> that outlasts cheaper alternatives.</p>",
            "page": ""
          }
        },
