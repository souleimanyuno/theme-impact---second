            "liquid": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');\n\n  /* ── GUARANTEE BAR ── */\n  .cnacc-trust {\n    font-family: 'poppins bold', sans-serif;\n    text-align: center;\n    padding: 16px 0 10px;\n  }\n\n  .cnacc-trust__text {\n    font-size: 11px;\n    font-weight: 700;\n    color: #111;\n    margin-bottom: 12px;\n    letter-spacing: -0.01em;\n  }\n\n  .cnacc-trust__text span {\n    display: inline-block;\n    margin: 0 6px;\n    color: #bbb;\n    font-weight: 400;\n  }\n\n  .cnacc-trust__payments img {\n    width: 100%;\n    max-width: 420px;\n    height: auto;\n    display: block;\n    margin: 0 auto;\n  }\n\n  /* ── ACCORDION ── */\n  .cnacc {\n    font-family: 'Inter', sans-serif;\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n    padding: 16px 0;\n    width: 100%;\n  }\n\n  .cnacc__item {\n    border: 1.5px solid #e2e2e2;\n    border-radius: 16px;\n    background: #fff;\n    overflow: hidden;\n    transition: border-color 0.25s;\n  }\n  .cnacc__item.open {\n    border-color: #1a5cff;\n  }\n\n  .cnacc__trigger {\n    width: 100%;\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    padding: 14px 16px;\n    background: none;\n    border: none;\n    cursor: pointer;\n    text-align: left;\n  }\n\n  .cnacc__badge {\n    width: 40px;\n    height: 40px;\n    border-radius: 10px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    flex-shrink: 0;\n  }\n  .cnacc__badge svg { width: 20px; height: 20px; }\n  .cnacc__badge--blue   { background: #eef1ff; }\n  .cnacc__badge--blue   svg { stroke: #1a5cff; fill: none; }\n  .cnacc__badge--green  { background: #eaf6f0; }\n  .cnacc__badge--green  svg { stroke: #1a7a3f; fill: none; }\n  .cnacc__badge--purple { background: #f0eaff; }\n  .cnacc__badge--purple svg { stroke: #6b3fcb; fill: none; }\n  .cnacc__badge--orange { background: #fff2ea; }\n  .cnacc__badge--orange svg { stroke: #d95f1a; fill: none; }\n\n  .cnacc__label {\n    flex: 1;\n    font-size: 15px;\n    font-weight: 700;\n    color: #111;\n    letter-spacing: -0.01em;\n  }\n\n  .cnacc__chev {\n    width: 18px;\n    height: 18px;\n    flex-shrink: 0;\n    stroke: #aaa;\n    fill: none;\n    transition: transform 0.3s, stroke 0.2s;\n  }\n  .cnacc__item.open .cnacc__chev {\n    transform: rotate(180deg);\n    stroke: #1a5cff;\n  }\n\n  .cnacc__body {\n    display: none;\n    padding: 2px 16px 18px 16px;\n  }\n  .cnacc__item.open .cnacc__body { display: block; }\n\n  /* DETAILS */\n  .cnacc__desc {\n    font-size: 13.5px;\n    color: #444;\n    line-height: 1.65;\n    margin-bottom: 18px;\n  }\n\n  .cnacc__feat-grid {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    text-align: center;\n    gap: 4px;\n  }\n  .cnacc__feat-cell {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 5px;\n  }\n  .cnacc__feat-cell svg {\n    width: 24px;\n    height: 24px;\n    stroke: #1a5cff;\n    fill: none;\n    stroke-width: 1.8;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n  .cnacc__feat-cell span {\n    font-size: 11.5px;\n    font-weight: 700;\n    color: #111;\n  }\n\n  /* MATERIALS */\n  .cnacc__layers {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 8px;\n    margin-bottom: 14px;\n  }\n  .cnacc__layer {\n    border: 1.5px solid #e2e2e2;\n    border-radius: 12px;\n    padding: 12px 8px 10px;\n    text-align: center;\n  }\n  .cnacc__layer-num {\n    width: 26px;\n    height: 26px;\n    background: #111;\n    color: #fff;\n    border-radius: 50%;\n    font-size: 12px;\n    font-weight: 800;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    margin: 0 auto 8px;\n  }\n  .cnacc__layer-name {\n    font-size: 12px;\n    font-weight: 700;\n    color: #111;\n    margin-bottom: 3px;\n  }\n  .cnacc__layer-sub {\n    font-size: 11.5px;\n    color: #666;\n    line-height: 1.4;\n  }\n\n  .cnacc__pills {\n    display: flex;\n    gap: 7px;\n    flex-wrap: wrap;\n    margin-bottom: 12px;\n  }\n  .cnacc__pill {\n    display: inline-flex;\n    align-items: center;\n    gap: 5px;\n    background: #eaf6f0;\n    color: #1a7a3f;\n    font-size: 11px;\n    font-weight: 700;\n    padding: 5px 11px;\n    border-radius: 999px;\n  }\n  .cnacc__pill svg {\n    width: 13px;\n    height: 13px;\n    stroke: #1a7a3f;\n    fill: none;\n    stroke-width: 2.2;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n\n  .cnacc__care {\n    font-size: 13px;\n    color: #555;\n    line-height: 1.5;\n  }\n\n  /* SIZING */\n  .cnacc__size-section + .cnacc__size-section { margin-top: 20px; }\n  .cnacc__size-heading {\n    font-size: 11.5px;\n    font-weight: 900;\n    color: #111;\n    text-transform: uppercase;\n    letter-spacing: 0.07em;\n    margin-bottom: 12px;\n  }\n\n  .cnacc__size-grid-4 {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 7px;\n    margin-bottom: 6px;\n  }\n  .cnacc__size-grid-3 {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 7px;\n    margin-bottom: 6px;\n  }\n\n  .cnacc__size-card {\n    border: 1.5px solid #e2e2e2;\n    border-radius: 12px;\n    padding: 11px 6px;\n    text-align: center;\n    position: relative;\n  }\n  .cnacc__size-card.pop {\n    border-color: #1a5cff;\n    background: #f0f4ff;\n  }\n  .cnacc__size-card .pop-tag {\n    position: absolute;\n    top: -9px;\n    left: 50%;\n    transform: translateX(-50%);\n    background: #1a5cff;\n    color: #fff;\n    font-size: 8.5px;\n    font-weight: 800;\n    letter-spacing: 0.07em;\n    text-transform: uppercase;\n    padding: 2px 7px;\n    border-radius: 999px;\n    white-space: nowrap;\n  }\n  .cnacc__size-letter {\n    font-size: 20px;\n    font-weight: 900;\n    color: #111;\n    line-height: 1;\n    margin-bottom: 3px;\n  }\n  .cnacc__size-dims {\n    font-size: 10.5px;\n    color: #777;\n    margin-bottom: 2px;\n  }\n  .cnacc__size-weight {\n    font-size: 10.5px;\n    font-weight: 700;\n    color: #111;\n  }\n\n  .cnacc__size-note {\n    font-size: 12px;\n    color: #666;\n    font-style: italic;\n    margin: 10px 0 8px;\n  }\n  .cnacc__size-tip {\n    background: #f3f5fb;\n    border-radius: 10px;\n    padding: 9px 12px;\n    font-size: 12.5px;\n    color: #444;\n    display: flex;\n    align-items: center;\n    gap: 7px;\n  }\n  .cnacc__size-tip svg {\n    width: 15px;\n    height: 15px;\n    stroke: #1a5cff;\n    fill: none;\n    flex-shrink: 0;\n    stroke-width: 2;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n  .cnacc__size-tip strong { font-weight: 800; color: #111; }\n\n  /* SHIPPING */\n  .cnacc__ship-grid {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 8px;\n  }\n  .cnacc__ship-card {\n    background: #f7f8fa;\n    border-radius: 12px;\n    padding: 12px 10px;\n    display: flex;\n    align-items: flex-start;\n    gap: 9px;\n  }\n  .cnacc__ship-card svg {\n    width: 18px;\n    height: 18px;\n    stroke: #d95f1a;\n    fill: none;\n    stroke-width: 1.8;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n    flex-shrink: 0;\n    margin-top: 1px;\n  }\n  .cnacc__ship-title {\n    font-size: 13px;\n    font-weight: 700;\n    color: #111;\n    margin-bottom: 2px;\n    line-height: 1.3;\n  }\n  .cnacc__ship-sub {\n    font-size: 11.5px;\n    color: #777;\n    line-height: 1.4;\n  }\n</style>\n\n<!-- GUARANTEE + PAYMENTS BAR -->\n<div class=\"cnacc-trust\">\n  <p class=\"cnacc-trust__text\">\n    30-Day Money Back Guarantee • Free Shipping on All Orders\n  </p>\n  <div class=\"cnacc-trust__payments\">\n    <img\n      src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/Capture_d_ecran_le_2026-06-26_a_14.45.12_430x.png?v=1782481530\"\n      alt=\"Secure payment methods\"\n      loading=\"lazy\"\n    >\n  </div>\n</div>\n\n<!-- ACCORDION -->\n<div class=\"cnacc\">\n\n  <!-- ① DETAILS -->\n  <div class=\"cnacc__item\" data-cnacc>\n    <button class=\"cnacc__trigger\" type=\"button\">\n      <div class=\"cnacc__badge cnacc__badge--blue\">\n        <svg stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\" viewBox=\"0 0 24 24\">\n          <circle cx=\"12\" cy=\"12\" r=\"10\"/>\n          <line x1=\"12\" y1=\"8\" x2=\"12\" y2=\"8.5\" stroke-width=\"2.5\"/>\n          <line x1=\"12\" y1=\"11\" x2=\"12\" y2=\"16\"/>\n        </svg>\n      </div>\n      <span class=\"cnacc__label\">Details</span>\n      <svg class=\"cnacc__chev\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" viewBox=\"0 0 24 24\">\n        <polyline points=\"6 9 12 15 18 9\"/>\n      </svg>\n    </button>\n    <div class=\"cnacc__body\">\n      <p class=\"cnacc__desc\">The ChillNest uses advanced self-cooling fiber technology to pull heat away from your dog's body the second he lays down — no water, no electricity, no freezing required. The pressure-activated surface responds instantly to body contact, keeping him comfortable all day long.</p>\n      <div class=\"cnacc__feat-grid\">\n        <div class=\"cnacc__feat-cell\">\n          <svg viewBox=\"0 0 24 24\"><path d=\"M12 2 L12 22 M4.93 4.93 L19.07 19.07 M2 12 L22 12 M4.93 19.07 L19.07 4.93\"/></svg>\n          <span>Instant Cool</span>\n        </div>\n        <div class=\"cnacc__feat-cell\">\n          <svg viewBox=\"0 0 24 24\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/></svg>\n          <span>Pet-Safe</span>\n        </div>\n        <div class=\"cnacc__feat-cell\">\n          <svg viewBox=\"0 0 24 24\">\n            <polyline points=\"17 1 21 5 17 9\"/>\n            <path d=\"M3 11V9a4 4 0 0 1 4-4h14\"/>\n            <polyline points=\"7 23 3 19 7 15\"/>\n            <path d=\"M21 13v2a4 4 0 0 1-4 4H3\"/>\n          </svg>\n          <span>Reversible</span>\n        </div>\n        <div class=\"cnacc__feat-cell\">\n          <svg viewBox=\"0 0 24 24\">\n            <path d=\"M12 2a5 5 0 0 1 5 5c0 5-5 13-5 13S7 12 7 7a5 5 0 0 1 5-5z\"/>\n            <circle cx=\"12\" cy=\"7\" r=\"2\"/>\n          </svg>\n          <span>Washable</span>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <!-- ② MATERIALS & CARE -->\n  <div class=\"cnacc__item\" data-cnacc>\n    <button class=\"cnacc__trigger\" type=\"button\">\n      <div class=\"cnacc__badge cnacc__badge--green\">\n        <svg stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\" viewBox=\"0 0 24 24\">\n          <path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/>\n          <polyline points=\"9 12 11 14 15 10\"/>\n        </svg>\n      </div>\n      <span class=\"cnacc__label\">Materials & Care</span>\n      <svg class=\"cnacc__chev\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" viewBox=\"0 0 24 24\">\n        <polyline points=\"6 9 12 15 18 9\"/>\n      </svg>\n    </button>\n    <div class=\"cnacc__body\">\n      <div class=\"cnacc__layers\">\n        <div class=\"cnacc__layer\">\n          <div class=\"cnacc__layer-num\">1</div>\n          <div class=\"cnacc__layer-name\">Top</div>\n          <div class=\"cnacc__layer-sub\">Self-cooling fiber fabric</div>\n        </div>\n        <div class=\"cnacc__layer\">\n          <div class=\"cnacc__layer-num\">2</div>\n          <div class=\"cnacc__layer-name\">Mid</div>\n          <div class=\"cnacc__layer-sub\">Ice silk cooling fiber</div>\n        </div>\n        <div class=\"cnacc__layer\">\n          <div class=\"cnacc__layer-num\">3</div>\n          <div class=\"cnacc__layer-name\">Base</div>\n          <div class=\"cnacc__layer-sub\">Non-slip waterproof</div>\n        </div>\n      </div>\n      <div class=\"cnacc__pills\">\n        <span class=\"cnacc__pill\">\n          <svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n          No Gel Inside\n        </span>\n        <span class=\"cnacc__pill\">\n          <svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n          Non-Toxic\n        </span>\n        <span class=\"cnacc__pill\">\n          <svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n          Pet-Safe\n        </span>\n      </div>\n      <p class=\"cnacc__care\">Machine washable · Cold water gentle cycle · Air dry recommended</p>\n    </div>\n  </div>\n\n  <!-- ③ SIZING GUIDE -->\n  <div class=\"cnacc__item\" data-cnacc>\n    <button class=\"cnacc__trigger\" type=\"button\">\n      <div class=\"cnacc__badge cnacc__badge--purple\">\n        <svg stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\" viewBox=\"0 0 24 24\">\n          <rect x=\"3\" y=\"3\" width=\"18\" height=\"18\" rx=\"2\"/>\n          <line x1=\"3\" y1=\"9\" x2=\"21\" y2=\"9\"/>\n          <line x1=\"3\" y1=\"15\" x2=\"21\" y2=\"15\"/>\n          <line x1=\"9\" y1=\"3\" x2=\"9\" y2=\"21\"/>\n        </svg>\n      </div>\n      <span class=\"cnacc__label\">Sizing Guide</span>\n      <svg class=\"cnacc__chev\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" viewBox=\"0 0 24 24\">\n        <polyline points=\"6 9 12 15 18 9\"/>\n      </svg>\n    </button>\n    <div class=\"cnacc__body\">\n      <div class=\"cnacc__size-section\">\n        <p class=\"cnacc__size-heading\">Style — Classic</p>\n        <div class=\"cnacc__size-grid-4\">\n          <div class=\"cnacc__size-card\">\n            <div class=\"cnacc__size-letter\">S</div>\n            <div class=\"cnacc__size-dims\">20×16\"</div>\n            <div class=\"cnacc__size-weight\">≤20 lbs</div>\n          </div>\n          <div class=\"cnacc__size-card\">\n            <div class=\"cnacc__size-letter\">M</div>\n            <div class=\"cnacc__size-dims\">24×20\"</div>\n            <div class=\"cnacc__size-weight\">20–50 lbs</div>\n          </div>\n          <div class=\"cnacc__size-card pop\">\n            <span class=\"pop-tag\">Popular</span>\n            <div class=\"cnacc__size-letter\">L</div>\n            <div class=\"cnacc__size-dims\">28×22\"</div>\n            <div class=\"cnacc__size-weight\">50–80 lbs</div>\n          </div>\n          <div class=\"cnacc__size-card\">\n            <div class=\"cnacc__size-letter\">XL</div>\n            <div class=\"cnacc__size-dims\">39×28\"</div>\n            <div class=\"cnacc__size-weight\">80+ lbs</div>\n          </div>\n        </div>\n      </div>\n      <div class=\"cnacc__size-section\">\n        <p class=\"cnacc__size-heading\">Leaf Mat (S · M · L only)</p>\n        <div class=\"cnacc__size-grid-3\">\n          <div class=\"cnacc__size-card\">\n            <div class=\"cnacc__size-letter\">S</div>\n            <div class=\"cnacc__size-dims\">34×39\"</div>\n            <div class=\"cnacc__size-weight\">Up to 15 lbs</div>\n          </div>\n          <div class=\"cnacc__size-card\">\n            <div class=\"cnacc__size-letter\">M</div>\n            <div class=\"cnacc__size-dims\">48×51\"</div>\n            <div class=\"cnacc__size-weight\">15–40 lbs</div>\n          </div>\n          <div class=\"cnacc__size-card pop\">\n            <span class=\"pop-tag\">Popular</span>\n            <div class=\"cnacc__size-letter\">L</div>\n            <div class=\"cnacc__size-dims\">51×59\"</div>\n            <div class=\"cnacc__size-weight\">40–80 lbs</div>\n          </div>\n        </div>\n      </div>\n      <div class=\"cnacc__size-section\">\n        <p class=\"cnacc__size-heading\">Shell Mat (S · M · L only)</p>\n        <div class=\"cnacc__size-grid-3\">\n          <div class=\"cnacc__size-card\">\n            <div class=\"cnacc__size-letter\">S</div>\n            <div class=\"cnacc__size-dims\">36×34\"</div>\n            <div class=\"cnacc__size-weight\">Up to 15 lbs</div>\n          </div>\n          <div class=\"cnacc__size-card\">\n            <div class=\"cnacc__size-letter\">M</div>\n            <div class=\"cnacc__size-dims\">48×45\"</div>\n            <div class=\"cnacc__size-weight\">15–40 lbs</div>\n          </div>\n          <div class=\"cnacc__size-card pop\">\n            <span class=\"pop-tag\">Popular</span>\n            <div class=\"cnacc__size-letter\">L</div>\n            <div class=\"cnacc__size-dims\">55×51\"</div>\n            <div class=\"cnacc__size-weight\">40–80 lbs</div>\n          </div>\n        </div>\n        <p class=\"cnacc__size-note\">Note: XL is not available for Leaf & Shell shapes.</p>\n      </div>\n      <div class=\"cnacc__size-tip\">\n        <svg viewBox=\"0 0 24 24\">\n          <circle cx=\"12\" cy=\"12\" r=\"10\"/>\n          <line x1=\"12\" y1=\"8\" x2=\"12\" y2=\"8.5\" stroke-width=\"2.5\"/>\n          <line x1=\"12\" y1=\"11\" x2=\"12\" y2=\"16\"/>\n        </svg>\n        Between sizes? Size <strong>&nbsp;up&nbsp;</strong> for extra comfort.\n      </div>\n    </div>\n  </div>\n\n  <!-- ④ SHIPPING + RETURNS -->\n  <div class=\"cnacc__item\" data-cnacc>\n    <button class=\"cnacc__trigger\" type=\"button\">\n      <div class=\"cnacc__badge cnacc__badge--orange\">\n        <svg stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\" viewBox=\"0 0 24 24\">\n          <rect x=\"1\" y=\"3\" width=\"15\" height=\"13\" rx=\"1\"/>\n          <polygon points=\"16 8 20 8 23 11 23 16 16 16 16 8\"/>\n          <circle cx=\"5.5\" cy=\"18.5\" r=\"2.5\"/>\n          <circle cx=\"18.5\" cy=\"18.5\" r=\"2.5\"/>\n        </svg>\n      </div>\n      <span class=\"cnacc__label\">Shipping + Returns</span>\n      <svg class=\"cnacc__chev\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" viewBox=\"0 0 24 24\">\n        <polyline points=\"6 9 12 15 18 9\"/>\n      </svg>\n    </button>\n    <div class=\"cnacc__body\">\n      <div class=\"cnacc__ship-grid\">\n        <div class=\"cnacc__ship-card\">\n          <svg viewBox=\"0 0 24 24\">\n            <rect x=\"1\" y=\"3\" width=\"15\" height=\"13\" rx=\"1\"/>\n            <polygon points=\"16 8 20 8 23 11 23 16 16 16 16 8\"/>\n            <circle cx=\"5.5\" cy=\"18.5\" r=\"2.5\"/>\n            <circle cx=\"18.5\" cy=\"18.5\" r=\"2.5\"/>\n          </svg>\n          <div>\n            <div class=\"cnacc__ship-title\">Free Shipping</div>\n            <div class=\"cnacc__ship-sub\">On every U.S. order</div>\n          </div>\n        </div>\n        <div class=\"cnacc__ship-card\">\n          <svg viewBox=\"0 0 24 24\">\n            <polygon points=\"13 2 3 14 12 14 11 22 21 10 12 10 13 2\"/>\n          </svg>\n          <div>\n            <div class=\"cnacc__ship-title\">Ships in 2–4 Days</div>\n            <div class=\"cnacc__ship-sub\">Fast warehouse processing</div>\n          </div>\n        </div>\n        <div class=\"cnacc__ship-card\">\n          <svg viewBox=\"0 0 24 24\">\n            <rect x=\"1\" y=\"3\" width=\"15\" height=\"13\" rx=\"1\"/>\n            <polygon points=\"16 8 20 8 23 11 23 16 16 16 16 8\"/>\n            <circle cx=\"5.5\" cy=\"18.5\" r=\"2.5\"/>\n            <circle cx=\"18.5\" cy=\"18.5\" r=\"2.5\"/>\n          </svg>\n          <div>\n            <div class=\"cnacc__ship-title\">3–5 Day Delivery</div>\n            <div class=\"cnacc__ship-sub\">Full tracking included</div>\n          </div>\n        </div>\n        <div class=\"cnacc__ship-card\">\n          <svg viewBox=\"0 0 24 24\">\n            <polyline points=\"23 4 23 10 17 10\"/>\n            <path d=\"M20.49 15a9 9 0 1 1-2.12-9.36L23 10\"/>\n          </svg>\n          <div>\n            <div class=\"cnacc__ship-title\">30-Day Returns</div>\n            <div class=\"cnacc__ship-sub\">Hassle-free exchange</div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n</div>\n\n<script>\n(function(){\n  var items = document.querySelectorAll('[data-cnacc]');\n  items.forEach(function(item){\n    var btn = item.querySelector('.cnacc__trigger');\n    btn.addEventListener('click', function(){\n      var isOpen = item.classList.contains('open');\n      items.forEach(function(i){ i.classList.remove('open'); });\n      if(!isOpen) item.classList.add('open');\n    });\n  });\n})();\n</script>"
          }
        },
        "collapsible_text_7LqTqm": {
          "type": "collapsible_text",
          "disabled": true,
          "settings": {
            "icon": "none",
            "icon_width": 20,
            "title": "PFLEGE",
            "content": "<ol><li><strong>Bei 30°C in der Waschmaschine oder per Hand waschen</strong><br/>Beim Maschinenwaschen das Schonprogramm verwenden. Anders als billige Strumpfhosen die beim ersten Tragen reißen, sind diese für die Ewigkeit gemacht — kein Drama nötig.</li><li><strong>Normales Waschmittel verwenden (kein Bleichmittel, keine Weichspüler)</strong><br/>Ein mildes Waschmittel reicht völlig aus. Bleichmittel und Weichspüler beschädigen die formenden Fasern — und diese sind bereits angenehm weich.</li><li><strong>Liegend oder hängend trocknen (NIE in den Trockner)</strong><br/>Der Trockner ist dein Feind. Einfach normal aufhängen oder flach hinlegen. Direktes Sonnenlicht vermeiden, sonst kann die Farbe verblassen.</li><li><strong>Sorgfältig falten und in der Schublade aufbewahren</strong><br/>Keine komischen Falten, sonst verlieren sie die Form. Behandle sie wie dein Lieblingsteil — keine spezielle Aufbewahrung nötig, nur normale Pflege.</li><li><strong>Nur bei Bedarf ersetzen</strong><br/>Wenn das Kontrollband nicht mehr so gut hält oder der Stoff Verschleiß zeigt, ist es Zeit für ein neues Paar. Aber keine Sorge — diese halten VIEL länger als die 5€-Strumpfhosen die nach einmaligem Tragen reißen.</li></ol><p><strong>Profi-Tipp:</strong> Kauf 2-3 Paare und wechsle sie wöchentlich ab — so halten sie doppelt so lang.</p>",
            "page": ""
          }
        },
