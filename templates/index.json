        "liquid": "<style>\n  .sorelya-how,\n  .sorelya-how * {\n    box-sizing: border-box;\n  }\n\n  .sorelya-how {\n    width: 100%;\n    overflow: hidden;\n    padding: 42px 22px 38px;\n    background: #b88c66;\n    color: #fff;\n    font-family: Arial, Helvetica, sans-serif;\n  }\n\n  .sorelya-how__inner {\n    width: 100%;\n    max-width: 1500px;\n    margin: 0 auto;\n  }\n\n  /* =========================\n     HEADER\n  ========================= */\n\n  .sorelya-how__eyebrow {\n    margin: 0 0 18px;\n    color: rgba(255, 255, 255, 0.9);\n    font-size: 15px;\n    font-weight: 800;\n    line-height: 1.3;\n    text-align: center;\n    letter-spacing: 0.025em;\n  }\n\n  .sorelya-how__heading {\n    max-width: 1050px;\n    margin: 0 auto 38px;\n    color: #fff;\n    font-size: clamp(34px, 4.5vw, 64px);\n    font-weight: 900;\n    line-height: 1.02;\n    text-align: center;\n    letter-spacing: -0.045em;\n    text-transform: uppercase;\n  }\n\n  /* =========================\n     TRACK\n  ========================= */\n\n  .sorelya-how__track {\n    display: grid;\n    grid-template-columns: repeat(3, minmax(0, 1fr));\n    gap: 42px;\n    align-items: start;\n    width: 100%;\n  }\n\n  .sorelya-how__card {\n    min-width: 0;\n    text-align: center;\n    scroll-snap-align: start;\n    scroll-snap-stop: always;\n  }\n\n  /* =========================\n     IMAGE\n  ========================= */\n\n  .sorelya-how__image-wrap {\n    width: 100%;\n    overflow: hidden;\n    border-radius: 11px;\n    background: rgba(255, 255, 255, 0.12);\n  }\n\n  .sorelya-how__image {\n    display: block;\n    width: 100%;\n    aspect-ratio: 4 / 5;\n    object-fit: cover;\n  }\n\n  /* =========================\n     CONTENT\n  ========================= */\n\n  .sorelya-how__content {\n    padding: 22px 10px 0;\n  }\n\n  .sorelya-how__title {\n    margin: 0 0 11px;\n    color: #fff;\n    font-size: clamp(21px, 1.8vw, 29px);\n    font-weight: 900;\n    line-height: 1.12;\n    letter-spacing: -0.025em;\n    text-transform: uppercase;\n  }\n\n  .sorelya-how__text {\n    max-width: 450px;\n    margin: 0 auto;\n    color: rgba(255, 255, 255, 0.91);\n    font-size: clamp(14px, 1.15vw, 18px);\n    font-weight: 500;\n    line-height: 1.55;\n  }\n\n  /* =========================\n     MOBILE DOTS\n  ========================= */\n\n  .sorelya-how__dots {\n    display: none;\n    align-items: center;\n    justify-content: center;\n    gap: 9px;\n    margin-top: 23px;\n  }\n\n  .sorelya-how__dot {\n    width: 8px;\n    height: 8px;\n    padding: 0;\n    border: 0;\n    border-radius: 999px;\n    background: rgba(255, 255, 255, 0.42);\n    cursor: pointer;\n    transition:\n      width 0.2s ease,\n      background-color 0.2s ease;\n  }\n\n  .sorelya-how__dot.active {\n    width: 25px;\n    background: #fff;\n  }\n\n  /* =========================\n     MOBILE\n  ========================= */\n\n  @media (max-width: 749px) {\n    .sorelya-how {\n      padding: 31px 0 27px;\n    }\n\n    .sorelya-how__eyebrow {\n      margin-bottom: 12px;\n      padding: 0 20px;\n      font-size: 12px;\n    }\n\n    .sorelya-how__heading {\n      margin-bottom: 25px;\n      padding: 0 18px;\n      font-size: 31px;\n      line-height: 1.05;\n    }\n\n    .sorelya-how__track {\n      display: flex;\n      gap: 14px;\n      width: 100%;\n      padding: 0 18px;\n      overflow-x: auto;\n      overscroll-behavior-x: contain;\n      scroll-behavior: smooth;\n      scroll-snap-type: x mandatory;\n      scrollbar-width: none;\n      -webkit-overflow-scrolling: touch;\n      touch-action: pan-x;\n    }\n\n    .sorelya-how__track::-webkit-scrollbar {\n      display: none;\n    }\n\n    .sorelya-how__card {\n      flex: 0 0 100%;\n      width: 100%;\n    }\n\n    .sorelya-how__image-wrap {\n      border-radius: 10px;\n    }\n\n    .sorelya-how__content {\n      padding: 18px 9px 0;\n    }\n\n    .sorelya-how__title {\n      margin-bottom: 8px;\n      font-size: 22px;\n    }\n\n    .sorelya-how__text {\n      max-width: 340px;\n      font-size: 15px;\n      line-height: 1.48;\n    }\n\n    .sorelya-how__dots {\n      display: flex;\n    }\n  }\n\n  @media (prefers-reduced-motion: reduce) {\n    .sorelya-how__track {\n      scroll-behavior: auto;\n    }\n  }\n</style>\n\n<section class=\"sorelya-how\" data-sorelya-how>\n  <div class=\"sorelya-how__inner\">\n\n    <p class=\"sorelya-how__eyebrow\">\n      Apply → Let It Develop → Enjoy\n    </p>\n\n    <h2 class=\"sorelya-how__heading\">\n      Your Tint in 3 Simple Steps\n    </h2>\n\n    <div\n      class=\"sorelya-how__track\"\n      data-sorelya-how-track\n    >\n\n      <!-- STEP 1 -->\n      <article\n        class=\"sorelya-how__card\"\n        data-sorelya-how-card\n      >\n        <div class=\"sorelya-how__image-wrap\">\n          <img\n            class=\"sorelya-how__image\"\n            src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/ChatGPT_Image_21_juil._2026_03_53_11_430x.png?v=1784602409\"\n            alt=\"A mature woman applying SORELYA lipstick\"\n            loading=\"eager\"\n          >\n        </div>\n\n        <div class=\"sorelya-how__content\">\n          <h3 class=\"sorelya-how__title\">\n            1. Apply\n          </h3>\n\n          <p class=\"sorelya-how__text\">\n            Glide one light layer over clean lips, just like your\n            favorite balm.\n          </p>\n        </div>\n      </article>\n\n      <!-- STEP 2 -->\n      <article\n        class=\"sorelya-how__card\"\n        data-sorelya-how-card\n      >\n        <div class=\"sorelya-how__image-wrap\">\n          <img\n            class=\"sorelya-how__image\"\n            src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/ChatGPT_Image_21_juil._2026_03_52_50_430x.png?v=1784602412\"\n            alt=\"A mature woman revealing her developed lip tint\"\n            loading=\"lazy\"\n          >\n        </div>\n\n        <div class=\"sorelya-how__content\">\n          <h3 class=\"sorelya-how__title\">\n            2. Let It Develop\n          </h3>\n\n          <p class=\"sorelya-how__text\">\n            The nearly clear formula gradually develops over your\n            natural lip tone into a flattering-looking tint.\n          </p>\n        </div>\n      </article>\n\n      <!-- STEP 3 -->\n      <article\n        class=\"sorelya-how__card\"\n        data-sorelya-how-card\n      >\n        <div class=\"sorelya-how__image-wrap\">\n          <img\n            class=\"sorelya-how__image\"\n            src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/ChatGPT_Image_21_juil._2026_03_53_54_430x.png?v=1784602442\"\n            alt=\"A mature woman smiling with her finished SORELYA lip tint\"\n            loading=\"lazy\"\n          >\n        </div>\n\n        <div class=\"sorelya-how__content\">\n          <h3 class=\"sorelya-how__title\">\n            3. Wear Your Tint\n          </h3>\n\n          <p class=\"sorelya-how__text\">\n            Enjoy soft, comfortable color that looks naturally suited\n            to you—without a shade chart or the guesswork.\n          </p>\n        </div>\n      </article>\n\n    </div>\n\n    <div class=\"sorelya-how__dots\">\n      <button\n        class=\"sorelya-how__dot active\"\n        type=\"button\"\n        aria-label=\"Show step 1\"\n        data-sorelya-how-dot=\"0\"\n      ></button>\n\n      <button\n        class=\"sorelya-how__dot\"\n        type=\"button\"\n        aria-label=\"Show step 2\"\n        data-sorelya-how-dot=\"1\"\n      ></button>\n\n      <button\n        class=\"sorelya-how__dot\"\n        type=\"button\"\n        aria-label=\"Show step 3\"\n        data-sorelya-how-dot=\"2\"\n      ></button>\n    </div>\n\n  </div>\n</section>\n\n<script>\n  (function () {\n    document\n      .querySelectorAll('[data-sorelya-how]')\n      .forEach(function (section) {\n        var track = section.querySelector(\n          '[data-sorelya-how-track]'\n        );\n\n        var cards = Array.from(\n          section.querySelectorAll(\n            '[data-sorelya-how-card]'\n          )\n        );\n\n        var dots = Array.from(\n          section.querySelectorAll(\n            '[data-sorelya-how-dot]'\n          )\n        );\n\n        if (!track || !cards.length) return;\n\n        function setActiveDot(index) {\n          dots.forEach(function (dot, dotIndex) {\n            dot.classList.toggle(\n              'active',\n              dotIndex === index\n            );\n          });\n        }\n\n        function scrollToCard(index) {\n          var targetCard = cards[index];\n\n          if (!targetCard) return;\n\n          track.scrollTo({\n            left: targetCard.offsetLeft - track.offsetLeft,\n            behavior: 'smooth'\n          });\n\n          setActiveDot(index);\n        }\n\n        /* Start on first step */\n        requestAnimationFrame(function () {\n          track.scrollLeft = 0;\n          setActiveDot(0);\n        });\n\n        if ('IntersectionObserver' in window) {\n          var observer = new IntersectionObserver(\n            function (entries) {\n              entries.forEach(function (entry) {\n                if (\n                  entry.isIntersecting &&\n                  entry.intersectionRatio >= 0.65\n                ) {\n                  var index = cards.indexOf(entry.target);\n\n                  if (index >= 0) {\n                    setActiveDot(index);\n                  }\n                }\n              });\n            },\n            {\n              root: track,\n              threshold: [0.4, 0.65, 0.9]\n            }\n          );\n\n          cards.forEach(function (card) {\n            observer.observe(card);\n          });\n        }\n\n        dots.forEach(function (dot, index) {\n          dot.addEventListener('click', function () {\n            scrollToCard(index);\n          });\n        });\n      });\n  })();\n</script>",
