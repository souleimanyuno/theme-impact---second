        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": true,
        "liquid": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap');\n\n  .cool-dogs {\n    width: 100%;\n    padding: 38px 0;\n    text-align: center;\n    font-family: 'Inter', sans-serif;\n    background: #fff;\n    overflow: hidden;\n  }\n\n  .cool-dogs__title {\n    font-size: 30px;\n    font-weight: 900;\n    color: #0d1f3c;\n    text-transform: uppercase;\n    letter-spacing: -0.01em;\n    margin-bottom: 10px;\n    padding: 0 20px;\n  }\n\n  .cool-dogs__title span {\n    color: #1a5cff;\n  }\n\n  .cool-dogs__subtitle {\n    font-size: 15px;\n    color: #444;\n    margin-bottom: 16px;\n    padding: 0 20px;\n  }\n\n  .cool-dogs__trust {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 8px;\n    margin-bottom: 28px;\n    font-size: 15px;\n    font-weight: 700;\n    color: #0d1f3c;\n  }\n\n  .cool-dogs__tp-stars {\n    display: flex;\n    gap: 3px;\n  }\n\n  .cool-dogs__tp-star {\n    width: 26px;\n    height: 26px;\n    background: #00b67a;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    border-radius: 3px;\n  }\n\n  .cool-dogs__tp-star svg {\n    width: 16px;\n    height: 16px;\n    fill: #fff;\n  }\n\n  .cool-dogs__tp-logo {\n    display: flex;\n    align-items: center;\n    gap: 4px;\n    font-size: 14px;\n    font-weight: 600;\n    color: #333;\n  }\n\n  .cool-dogs__tp-logo svg {\n    width: 16px;\n    height: 16px;\n  }\n\n  .cool-dogs__track-wrapper {\n    overflow-x: scroll;\n    overflow-y: hidden;\n    width: 100%;\n    cursor: grab;\n    -webkit-overflow-scrolling: touch;\n    scrollbar-width: none;\n    -ms-overflow-style: none;\n  }\n\n  .cool-dogs__track-wrapper::-webkit-scrollbar {\n    display: none;\n  }\n\n  .cool-dogs__track-wrapper:active {\n    cursor: grabbing;\n  }\n\n  .cool-dogs__track {\n    display: flex;\n    gap: 14px;\n    padding: 0 20px 8px 20px;\n    width: max-content;\n  }\n\n  .cool-dogs__card {\n    flex-shrink: 0;\n    width: 300px;\n    border-radius: 18px;\n    overflow: hidden;\n    position: relative;\n    background: #f2f2f2;\n  }\n\n  .cool-dogs__card img {\n    width: 100%;\n    height: 360px;\n    object-fit: cover;\n    display: block;\n    pointer-events: none;\n    user-select: none;\n  }\n\n  .cool-dogs__card-label {\n    position: absolute;\n    top: 14px;\n    left: 14px;\n    background: rgba(255,255,255,0.95);\n    color: #0d1f3c;\n    font-size: 13px;\n    font-weight: 700;\n    padding: 6px 14px;\n    border-radius: 999px;\n    font-family: 'Inter', sans-serif;\n    backdrop-filter: blur(4px);\n    box-shadow: 0 2px 8px rgba(0,0,0,0.08);\n  }\n\n  @media (max-width: 768px) {\n    .cool-dogs__title {\n      font-size: 22px;\n    }\n    .cool-dogs__card {\n      width: 240px;\n    }\n    .cool-dogs__card img {\n      height: 290px;\n    }\n  }\n</style>\n\n<div class=\"cool-dogs\">\n  <h2 class=\"cool-dogs__title\">\n    Cool Dogs of <span>CHILLNEST™</span>\n  </h2>\n  <p class=\"cool-dogs__subtitle\">See how our furry friends stay chill with the ChillNest!</p>\n\n  <div class=\"cool-dogs__trust\">\n    <span>Excellent</span>\n    <div class=\"cool-dogs__tp-stars\">\n      {% for i in (1..5) %}\n        <div class=\"cool-dogs__tp-star\">\n          <svg viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\">\n            <path d=\"M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z\"/>\n          </svg>\n        </div>\n      {% endfor %}\n    </div>\n    <div class=\"cool-dogs__tp-logo\">\n      <svg viewBox=\"0 0 24 24\" fill=\"#00b67a\" xmlns=\"http://www.w3.org/2000/svg\">\n        <path d=\"M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z\"/>\n      </svg>\n      <span>Trustpilot</span>\n    </div>\n  </div>\n\n  <div class=\"cool-dogs__track-wrapper\" id=\"coolDogsWrapper\">\n    <div class=\"cool-dogs__track\" id=\"coolDogsTrack\">\n\n      <div class