entListener('mouseup', function() {\n    isDown = false;\n    wrapper.style.cursor = 'grab';\n  });\n\n  wrapper.addEventListener('mousemove', function(e) {\n    if (!isDown) return;\n    e.preventDefault();\n    const x = e.pageX - wrapper.offsetLeft;\n    const walk = (x - startX) * 1.5;\n    wrapper.scrollLeft = scrollLeft - walk;\n  });\n\n  // Infinite loop — reset au bon moment\n  const halfWidth = track.scrollWidth / 2;\n\n  wrapper.addEventListener('scroll', function() {\n    if (wrapper.scrollLeft >= halfWidth) {\n      wrapper.scrollLeft = wrapper.scrollLeft - halfWidth;\n    } else if (wrapper.scrollLeft <= 0) {\n      wrapper.scrollLeft = halfWidth;\n    }\n  });\n\n  // Init position au milieu pour permettre scroll gauche aussi\n  wrapper.scrollLeft = 1;\n})();\n</script>",
