            "liquid": "<div class=\"features-container\">\n  <div class=\"feature-item\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0891/4871/9429/files/NOUVEAU-SHIPPING1.svg?v=1744585896\" alt=\"Kostenloser Versand\">\n    <div class=\"feature-text\">\n      <p class=\"feature-title\">Kostenloser Versand</p>\n      <p class=\"feature-subtitle\">Versandfertig | Versand innerhalb 24h</p>\n    </div>\n  </div>\n  <div class=\"feature-item\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0891/4871/9429/files/NOUVEAU-check-shield.svg?v=1744586491\" alt=\"Sichere Zahlung\">\n    <div class=\"feature-text\">\n      <p class=\"feature-title\">Sichere Zahlung</p>\n      <p class=\"feature-subtitle\">via SSL & 3D Secure</p>\n    </div>\n  </div>\n  <div class=\"feature-item\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0891/4871/9429/files/NOUVEAU-RETOUR.svg?v=1744585755\" alt=\"Geld-zurück-Garantie\">\n    <div class=\"feature-text\">\n      <p class=\"feature-title\">Geld-zurück-Garantie</p>\n      <p class=\"feature-subtitle\">30 Tage – keine Fragen gestellt</p>\n    </div>\n  </div>\n  <div class=\"feature-item\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0795/2754/3033/files/headset_mic_45dp_000000_FILL0_wght400_GRAD0_opsz48_430x.svg?v=1770042933\" alt=\"Kundensupport\">\n    <div class=\"feature-text\">\n      <p class=\"feature-title\">Kundensupport</p>\n      <p class=\"feature-subtitle\">7 Tage die Woche erreichbar</p>\n    </div>\n  </div>\n</div>\n<style>\n.features-container {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 20px 10px;\n  padding: 20px 0;\n}\n.feature-item {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n}\n.feature-item img {\n  width: 28px;\n  height: 28px;\n  object-fit: contain;\n}\n.feature-text {\n  display: flex;\n  flex-direction: column;\n}\n.feature-title {\n  font-weight: 600;\n  font-size: 15px;\n  color: #1c1c1c;\n  margin: 0;\n}\n.feature-subtitle {\n  font-size: 13px;\n  color: #555;\n  margin: 0;\n}\n</style>"
