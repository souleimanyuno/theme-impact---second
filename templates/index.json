            "liquid": "<div style=\"display: flex; align-items: center; background-color: #FFFFFF; padding: px px; border-radius: 8px; width: fit-content; margin: 1px 0; text-align: left;\">\n  <img src=\"https://cdn.shopify.com/s/files/1/0891/4871/9429/files/stars-4.5-trust-pilot.svg?v=1747080316\" alt=\"5 stars\" style=\"width: 66px; margin-right: 8px;\">\n  <div style=\"color: #4A4A4A; font-size: 13px; text-align: left; white-space: nowrap;\">\n    <span style=\"font-weight: 200;\">Rated</span> <span style=\"color: #000000; font-weight: 700;\">4.7</span> <span style=\"font-weight: 200;\">based on</span> <span style=\"color: #000000; font-weight: 700;\">10,000+ Reviews</span>\n  </div>\n</div>\n\n<div class=\"sv-desc-block\">\n\n  <p class=\"sv-product-name\">SORELYA SkinVeil™</p>\n\n  <h2 class=\"sv-main-title\">Thread veins, stretch marks, imperfections. Covered. For 48 hours.</h2>\n  <p class=\"sv-sub-title\">Legs that wear the dress. Not the other way around.</p>\n\n  <div class=\"sv-icons-grid\">\n    <div class=\"sv-icon-row\">\n      <div class=\"sv-icon-wrap\">\n        <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#c9a84c\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z\"/></svg>\n      </div>\n      <span>Feels like nothing on your skin.</span>\n    </div>\n    <div class=\"sv-icon-row\">\n      <div class=\"sv-icon-wrap\">\n        <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#c9a84c\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 22V8\"/><path d=\"M5 12H2a10 10 0 0 0 20 0h-3\"/><path d=\"M12 2a4 4 0 0 1 4 4v2H8V6a4 4 0 0 1 4-4z\"/></svg>\n      </div>\n      <span>Waterproof. Zero transfer.</span>\n    </div>\n    <div class=\"sv-icon-row\">\n      <div class=\"sv-icon-wrap\">\n        <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#c9a84c\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"3\"/><path d=\"M3 12h1m16 0h1M12 3v1m0 16v1m-6.4-3.6.7-.7m11.4-11.4.7-.7M5.6 5.6l.7.7m11.4 11.4.7.7\"/></svg>\n      </div>\n      <span>6 shades. Find your perfect match.</span>\n    </div>\n    <div class=\"sv-icon-row\">\n      <div class=\"sv-icon-wrap\">\n        <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#c9a84c\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><polyline points=\"12 6 12 12 16 14\"/></svg>\n      </div>\n      <span>Apply in 10 minutes.</span>\n    </div>\n  </div>\n\n  <div class=\"sv-divider\"></div>\n\n</div>\n\n<style>\n.sv-desc-block {\n  padding: 12px 4px 0;\n  font-family: 'Montserrat', -apple-system, 'Helvetica Neue', Arial, sans-serif;\n}\n\n.sv-product-name {\n  font-family: 'Montserrat', -apple-system, sans-serif;\n  font-size: 26px;\n  font-weight: 800;\n  color: #1a1a2e;\n  margin: 0 0 10px;\n  letter-spacing: -0.3px;\n  line-height: 1.2;\n}\n\n.sv-main-title {\n  font-size: 17px;\n  font-weight: 700;\n  color: #1a1a2e;\n  line-height: 1.45;\n  margin: 0 0 6px;\n}\n\n.sv-sub-title {\n  font-size: 15px;\n  color: #555;\n  font-weight: 400;\n  margin: 0 0 16px;\n  line-height: 1.5;\n}\n\n.sv-icons-grid {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 12px 14px;\n  margin-bottom: 14px;\n}\n\n.sv-icon-row {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n}\n\n.sv-icon-wrap {\n  width: 36px;\n  height: 36px;\n  background: #fdf3ea;\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  flex-shrink: 0;\n}\n\n.sv-icon-row span {\n  font-size: 13px;\n  color: #2a2a2a;\n  line-height: 1.4;\n}\n\n.sv-divider {\n  height: 1px;\n  background: #efe8e2;\n  margin-bottom: 10px;\n}\n</style>\n\n<!-- SHADE FINDER TRIGGER -->\n<div class=\"sf-trigger-wrap\">\n  <div class=\"sf-trigger\" id=\"sfTrigger\">\n    <div class=\"sf-swatch\" style=\"background: linear-gradient(135deg, #e8c9a0, #c4956a, #8b5e3c);\"></div>\n    <div class=\"sf-trigger-text\">\n      <em>Find your shade</em>\n      <span>GUIDED QUIZ · 60 SECONDS</span>\n    </div>\n    <span class=\"sf-arrow\">→</span>\n  </div>\n</div>\n\n<!-- MODAL OVERLAY -->\n<div class=\"sf-overlay\" id=\"sfOverlay\">\n  <div class=\"sf-modal\" id=\"sfModal\">\n    <div class=\"sf-header\">\n      <button class=\"sf-back\" id=\"sfBack\" style=\"visibility:hidden\">‹</button>\n      <div class=\"sf-progress-bar\">\n        <div class=\"sf-progress-fill\" id=\"sfProgressFill\"></div>\n      </div>\n      <button class=\"sf-close\" id=\"sfClose\">✕</button>\n    </div>\n    <div class=\"sf-body\" id=\"sfBody\"></div>\n  </div>\n</div>\n\n<style>\n.sf-trigger-wrap {\n  margin: 0 0 16px;\n}\n.sf-trigger {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  background: #fff;\n  border: 1px solid #e8ddd6;\n  border-radius: 12px;\n  padding: 14px 16px;\n  cursor: pointer;\n  transition: box-shadow 0.2s;\n}\n.sf-trigger:hover {\n  box-shadow: 0 2px 12px rgba(0,0,0,0.08);\n}\n.sf-swatch {\n  width: 40px;\n  height: 40px;\n  border-radius: 50%;\n  flex-shrink: 0;\n}\n.sf-trigger-text {\n  display: flex;\n  flex-direction: column;\n  gap: 2px;\n}\n.sf-trigger-text em {\n  font-family: Georgia, serif;\n  font-size: 16px;\n  font-style: italic;\n  color: #1a1a2e;\n}\n.sf-trigger-text span {\n  font-size: 10px;\n  color: #aaa;\n  text-transform: uppercase;\n  letter-spacing: 0.8px;\n}\n.sf-arrow {\n  margin-left: auto;\n  font-size: 20px;\n  color: #c9a84c;\n}\n.sf-overlay {\n  display: none;\n  position: fixed;\n  inset: 0;\n  background: rgba(0,0,0,0.5);\n  z-index: 99999;\n  align-items: flex-end;\n  justify-content: center;\n}\n.sf-overlay.open { display: flex; }\n@media (min-width: 600px) {\n  .sf-overlay { align-items: center; }\n}\n.sf-modal {\n  background: #fff;\n  width: 100%;\n  max-width: 560px;\n  max-height: 92vh;\n  border-radius: 20px 20px 0 0;\n  overflow: hidden;\n  display: flex;\n  flex-direction: column;\n}\n@media (min-width: 600px) {\n  .sf-modal { border-radius: 20px; max-height: 85vh; }\n}\n.sf-header {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  padding: 16px 16px 12px;\n  flex-shrink: 0;\n}\n.sf-back, .sf-close {\n  background: none;\n  border: none;\n  font-size: 18px;\n  cursor: pointer;\n  color: #666;\n  padding: 4px 8px;\n  border-radius: 6px;\n  flex-shrink: 0;\n}\n.sf-back:hover, .sf-close:hover { background: #f5f5f5; }\n.sf-progress-bar {\n  flex: 1;\n  height: 4px;\n  background: #efe8e2;\n  border-radius: 4px;\n  overflow: hidden;\n}\n.sf-progress-fill {\n  height: 100%;\n  background: linear-gradient(90deg, #c9a84c, #e8c98a);\n  border-radius: 4px;\n  transition: width 0.4s ease;\n  width: 0%;\n}\n.sf-body {\n  overflow-y: auto;\n  padding: 0 20px 28px;\n  flex: 1;\n}\n.sf-step-label {\n  font-size: 12px;\n  font-weight: 600;\n  color: #c9a84c;\n  text-transform: uppercase;\n  letter-spacing: 1px;\n  margin-bottom: 8px;\n}\n.sf-step-title {\n  font-family: Georgia, serif;\n  font-size: 26px;\n  font-style: italic;\n  color: #1a1a2e;\n  margin-bottom: 6px;\n  line-height: 1.3;\n}\n.sf-step-sub {\n  font-size: 13px;\n  color: #888;\n  margin-bottom: 20px;\n  line-height: 1.5;\n}\n.sf-grid-3 {\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  gap: 10px;\n}\n.sf-grid-2 {\n  display: grid;\n  grid-template-columns: repeat(2, 1fr);\n  gap: 10px;\n}\n.sf-option {\n  border: 2px solid #efe8e2;\n  border-radius: 12px;\n  overflow: hidden;\n  cursor: pointer;\n  transition: border-color 0.2s, transform 0.15s;\n  background: #fff;\n}\n.sf-option:hover { border-color: #c9a84c; transform: translateY(-1px); }\n.sf-option.selected { border-color: #c9a84c; background: #fffaf4; }\n.sf-option img {\n  width: 100%;\n  aspect-ratio: 1/1;\n  object-fit: cover;\n  display: block;\n}\n.sf-option-label { padding: 8px 10px 10px; }\n.sf-option-label strong { display: block; font-size: 13px; color: #1a1a2e; margin-bottom: 2px; }\n.sf-option-label span { font-size: 11px; color: #999; }\n.sf-text-option {\n  border: 2px solid #efe8e2;\n  border-radius: 12px;\n  padding: 16px;\n  cursor: pointer;\n  margin-bottom: 10px;\n  transition: border-color 0.2s;\n}\n.sf-text-option:hover { border-color: #c9a84c; }\n.sf-text-option.featured { background: #fffaf4; border-color: #e8c98a; }\n.sf-text-option .sf-featured-badge {\n  display: inline-block;\n  background: #1a1a2e;\n  color: #fff;\n  font-size: 10px;\n  font-weight: 700;\n  text-transform: uppercase;\n  letter-spacing: 0.5px;\n  padding: 3px 8px;\n  border-radius: 4px;\n  margin-bottom: 8px;\n}\n.sf-text-option strong {\n  display: block;\n  font-family: Georgia, serif;\n  font-size: 16px;\n  font-style: italic;\n  color: #1a1a2e;\n  margin-bottom: 4px;\n}\n.sf-text-option p { font-size: 13px; color: #777; margin: 0; line-height: 1.4; }\n.sf-text-option .sf-bonus {\n  margin-top: 10px;\n  background: linear-gradient(90deg, #e8c98a33, #c9a84c22);\n  border-radius: 6px;\n  padding: 6px 10px;\n  font-size: 12px;\n  color: #a07830;\n  font-weight: 600;\n}\n.sf-result-title {\n  font-family: Georgia, serif;\n  font-size: 24px;\n  font-style: italic;\n  text-align: center;\n  color: #1a1a2e;\n  margin-bottom: 4px;\n}\n.sf-result-sub { text-align: center; font-size: 13px; color: #aaa; margin-bottom: 20px; }\n.sf-shade-card {\n  border: 2px solid #efe8e2;\n  border-radius: 14px;\n  padding: 14px 16px;\n  display: flex;\n  align-items: center;\n  gap: 14px;\n  margin-bottom: 10px;\n}\n.sf-shade-card.primary { border-color: #c9a84c; background: #fffaf4; }\n.sf-shade-card.secondary { border-style: dashed; border-color: #c9a84c88; }\n.sf-shade-dot {\n  width: 52px;\n  height: 52px;\n  border-radius: 50%;\n  flex-shrink: 0;\n  border: 2px solid #efe8e2;\n}\n.sf-shade-info .sf-shade-tag {\n  font-size: 10px;\n  text-transform: uppercase;\n  letter-spacing: 0.8px;\n  color: #c9a84c;\n  font-weight: 600;\n  margin-bottom: 2px;\n}\n.sf-shade-info strong { display: block; font-size: 16px; color: #1a1a2e; margin-bottom: 2px; }\n.sf-shade-info span { font-size: 12px; color: #999; }\n.sf-why-box {\n  background: #fffaf4;\n  border-radius: 12px;\n  padding: 14px 16px;\n  margin: 14px 0;\n  font-size: 13px;\n  color: #5a4030;\n  line-height: 1.6;\n}\n.sf-why-box strong {\n  display: block;\n  font-size: 11px;\n  text-transform: uppercase;\n  letter-spacing: 0.8px;\n  color: #c9a84c;\n  margin-bottom: 6px;\n}\n.sf-cta-btn {\n  width: 100%;\n  background: linear-gradient(135deg, #c9a84c, #e8c98a);\n  color: #fff;\n  border: none;\n  border-radius: 12px;\n  padding: 16px;\n  font-size: 16px;\n  font-weight: 700;\n  cursor: pointer;\n  margin-bottom: 8px;\n  transition: opacity 0.2s;\n}\n.sf-cta-btn:hover { opacity: 0.9; }\n.sf-cta-sub { text-align: center; font-size: 12px; color: #aaa; margin-bottom: 16px; }\n.sf-trust-row {\n  display: grid;\n  grid-template-columns: repeat(4, 1fr);\n  gap: 8px;\n  border-top: 1px solid #f0e8e0;\n  padding-top: 16px;\n  margin-top: 4px;\n}\n.sf-trust-item { text-align: center; }\n.sf-trust-item em {\n  display: block;\n  font-family: Georgia, serif;\n  font-size: 15px;\n  font-style: italic;\n  color: #c9a84c;\n  margin-bottom: 2px;\n}\n.sf-trust-item span { font-size: 10px; color: #aaa; line-height: 1.3; }\n.sf-restart {\n  display: block;\n  text-align: center;\n  font-size: 13px;\n  color: #aaa;\n  cursor: pointer;\n  margin-top: 16px;\n  text-decoration: underline;\n}\n</style>\n\n<script>\n(function() {\n  const SHADES = [\n    { id: 'pm', name: 'Porcelain Mist',  hex: '#f5e6d8', desc: 'For very fair, cool-toned skin',   sun: [0,1],    vein: [0,2,3] },\n    { id: 'ig', name: 'Ivory Glow',      hex: '#ebd5b8', desc: 'For fair to light skin',            sun: [0,1],    vein: [0,1,2,3] },\n    { id: 'ws', name: 'Warm Sand',       hex: '#d4a97a', desc: 'For light to medium warm skin',     sun: [1,2],    vein: [1,2,3] },\n    { id: 'bh', name: 'Bare Honey',      hex: '#c08a50', desc: 'For medium to olive skin',          sun: [1,2],    vein: [1,2] },\n    { id: 'gd', name: 'Golden Dusk',     hex: '#9a6535', desc: 'For medium-deep warm skin',         sun: [2,3],    vein: [1,2] },\n    { id: 'cs', name: 'Cocoa Silk',      hex: '#5c3418', desc: 'For deep to rich dark skin',        sun: [2,3],    vein: [0,1,2,3] }\n  ];\n\n  let answers = { skin: null, vein: null, sun: null, usage: null };\n  let step = 1;\n\n  const trigger  = document.getElementById('sfTrigger');\n  const overlay  = document.getElementById('sfOverlay');\n  const body     = document.getElementById('sfBody');\n  const fill     = document.getElementById('sfProgressFill');\n  const backBtn  = document.getElementById('sfBack');\n  const closeBtn = document.getElementById('sfClose');\n\n  trigger.addEventListener('click', () => { step=1; open(); });\n  closeBtn.addEventListener('click', close);\n  overlay.addEventListener('click', e => { if(e.target===overlay) close(); });\n  backBtn.addEventListener('click', () => { step = Math.max(1, step-1); render(); });\n\n  function open()  { overlay.classList.add('open'); render(); }\n  function close() { overlay.classList.remove('open'); }\n\n  function setProgress(s, total) {\n    fill.style.width = ((s-1)/total*100) + '%';\n    backBtn.style.visibility = s > 1 ? 'visible' : 'hidden';\n  }\n\n  function computeResult() {\n    const scores = SHADES.map((sh, idx) => {\n      let score = 0;\n      if (answers.skin !== null) score += Math.max(0, 10 - Math.abs(idx - answers.skin) * 3);\n      if (answers.vein !== null && sh.vein.includes(answers.vein)) score += 4;\n      if (answers.sun !== null  && sh.sun.includes(answers.sun))  score += 4;\n      return { sh, idx, score };\n    });\n    scores.sort((a,b) => b.score - a.score);\n    const primary   = scores[0].sh;\n    const secIdx    = Math.min(scores[0].idx + 1, SHADES.length - 1);\n    const secondary = SHADES[secIdx];\n    const pct       = Math.round(88 + Math.random() * 9);\n    return { primary, secondary, pct };\n  }\n\n  function render() {\n    if      (step === 1) renderQ1();\n    else if (step === 2) renderQ2();\n    else if (step === 3) renderQ3();\n    else if (step === 4) renderQ4();\n    else                 renderResult();\n    body.scrollTop = 0;\n  }\n\n  function renderQ1() {\n    setProgress(1, 4);\n    const imgs = [\n      'https://cdn.shopify.com/s/files/1/0992/0384/2370/files/bzf-skin-1-porcellana_430x.jpg?v=1780980552',\n      'https://cdn.shopify.com/s/files/1/0992/0384/2370/files/bzf-skin-2-avorio_430x.jpg?v=1780980552',\n      'https://cdn.shopify.com/s/files/1/0992/0384/2370/files/bzf-skin-3-beige_430x.jpg?v=1780980552',\n      'https://cdn.shopify.com/s/files/1/0992/0384/2370/files/bzf-skin-4-dorata_430x.jpg?v=1780980552',\n      'https://cdn.shopify.com/s/files/1/0992/0384/2370/files/bzf-skin-5-caramello_430x.jpg?v=1780980552',\n      'https://cdn.shopify.com/s/files/1/0992/0384/2370/files/bzf-skin-6-olivastra_430x.jpg?v=1780980627'\n    ];\n    const labels = [\n      ['Porcelain','Very fair'],['Ivory','Fair'],['Beige','Light medium'],\n      ['Golden','Mediterranean'],['Caramel','Deep bronze'],['Olive','Dark natural']\n    ];\n    body.innerHTML = `\n      <p class=\"sf-step-label\">QUESTION 1 OF 4</p>\n      <h2 class=\"sf-step-title\">Your skin right now.</h2>\n      <p class=\"sf-step-sub\">Tap the photo closest to your skin today · without any tan.</p>\n      <div class=\"sf-grid-3\">\n        ${imgs.map((img,i) => `\n          <div class=\"sf-option${answers.skin===i?' selected':''}\" data-idx=\"${i}\">\n            <img src=\"${img}\" alt=\"${labels[i][0]}\" loading=\"lazy\">\n            <div class=\"sf-option-label\">\n              <strong>${labels[i][0]}</strong>\n              <span>${labels[i][1]}</span>\n            </div>\n          </div>`).join('')}\n      </div>`;\n    body.querySelectorAll('.sf-option').forEach(el => {\n      el.addEventListener('click', () => { answers.skin = parseInt(el.dataset.idx); step=2; render(); });\n    });\n  }\n\n  function renderQ2() {\n    setProgress(2, 4);\n    const imgs = [\n      'https://cdn.shopify.com/s/files/1/0992/0384/2370/files/bzf-veins-wrist_blue_430x.jpg?v=1780980707',\n      'https://cdn.shopify.com/s/files/1/0992/0384/2370/files/bzf-veins-wrist_green_430x.jpg?v=1780980707',\n      'https://cdn.shopify.com/s/files/1/0992/0384/2370/files/bzf-veins-wrist_mixed_430x.jpg?v=1780980707',\n      'https://cdn.shopify.com/s/files/1/0992/0384/2370/files/bzf-veins-wrist_faint_430x.jpg?v=1780980707'\n    ];\n    const labels = [\n      ['Blue or purple','Cool undertone'],['Green','Warm undertone'],\n      ['Mix of both','Neutral undertone'],['Hard to tell','Neutral undertone']\n    ];\n    body.innerHTML = `\n      <p class=\"sf-step-label\">QUESTION 2 OF 4</p>\n      <h2 class=\"sf-step-title\">Look at your wrist veins.</h2>\n      <p class=\"sf-step-sub\">Inner wrist, palm up, in natural window light. What colour do you mainly see?</p>\n      <div class=\"sf-grid-2\">\n        ${imgs.map((img,i) => `\n          <div class=\"sf-option${answers.vein===i?' selected':''}\" data-idx=\"${i}\">\n            <img src=\"${img}\" alt=\"${labels[i][0]}\" loading=\"lazy\">\n            <div class=\"sf-option-label\">\n              <strong>${labels[i][0]}</strong>\n              <span>${labels[i][1]}</span>\n            </div>\n          </div>`).join('')}\n      </div>`;\n    body.querySelectorAll('.sf-option').forEach(el => {\n      el.addEventListener('click', () => { answers.vein = parseInt(el.dataset.idx); step=3; render(); });\n    });\n  }\n\n  function renderQ3() {\n    setProgress(3, 4);\n    const imgs = [\n      'https://cdn.shopify.com/s/files/1/0992/0384/2370/files/bzf-sun-0-burn_430x.jpg?v=1780980761',\n      'https://cdn.shopify.com/s/files/1/0992/0384/2370/files/bzf-sun-1-light-tan_430x.jpg?v=1780980761',\n      'https://cdn.shopify.com/s/files/1/0992/0384/2370/files/bzf-sun-2-easy-tan_430x.jpg?v=1780980761',\n      'https://cdn.shopify.com/s/files/1/0992/0384/2370/files/bzf-sun-3-deep-tan_430x.jpg?v=1780980761'\n    ];\n    const labels = [\n      ['I burn easily','Redness, no colour'],['Burn then tan','Light golden colour'],\n      ['Tan easily','Rarely burn'],['Tan straight away','Fast and deep']\n    ];\n    body.innerHTML = `\n      <p class=\"sf-step-label\">QUESTION 3 OF 4</p>\n      <h2 class=\"sf-step-title\">When you're in the sun, what happens?</h2>\n      <p class=\"sf-step-sub\">Think about a summer weekend at the beach · no high SPF.</p>\n      <div class=\"sf-grid-2\">\n        ${imgs.map((img,i) => `\n          <div class=\"sf-option${answers.sun===i?' selected':''}\" data-idx=\"${i}\">\n            <img src=\"${img}\" alt=\"${labels[i][0]}\" loading=\"lazy\">\n            <div class=\"sf-option-label\">\n              <strong>${labels[i][0]}</strong>\n              <span>${labels[i][1]}</span>\n            </div>\n          </div>`).join('')}\n      </div>`;\n    body.querySelectorAll('.sf-option').forEach(el => {\n      el.addEventListener('click', () => { answers.sun = parseInt(el.dataset.idx); step=4; render(); });\n    });\n  }\n\n  function renderQ4() {\n    setProgress(4, 4);\n    body.innerHTML = `\n      <p class=\"sf-step-label\">QUESTION 4 OF 4</p>\n      <h2 class=\"sf-step-title\">When will you wear it?</h2>\n      <p class=\"sf-step-sub\">This helps us recommend one shade or a duo for all seasons.</p>\n      <div class=\"sf-text-option featured\" data-val=\"both\">\n        <span class=\"sf-featured-badge\">BEST VALUE</span>\n        <strong>Every day + special occasions</strong>\n        <p>One shade for daily life · one for when you want that just-back-from-holiday glow.</p>\n        <div class=\"sf-bonus\">+ Kabuki Brush included free</div>\n      </div>\n      <div class=\"sf-text-option\" data-val=\"daily\">\n        <strong>Every day</strong>\n        <p>One shade · for work, gym, errands and weekends.</p>\n      </div>\n      <div class=\"sf-text-option\" data-val=\"occasions\">\n        <strong>Special occasions only</strong>\n        <p>Weddings · holidays · nights out — when you need to be there.</p>\n      </div>`;\n    body.querySelectorAll('.sf-text-option').forEach(el => {\n      el.addEventListener('click', () => { answers.usage = el.dataset.val; step=5; render(); });\n    });\n  }\n\n  function renderResult() {\n    setProgress(5, 4);\n    fill.style.width = '100%';\n    const { primary, secondary, pct } = computeResult();\n    const showDuo   = answers.usage === 'both' || answers.usage === 'occasions';\n    const resultTitle = showDuo ? `${primary.name} + ${secondary.name}` : primary.name;\n    const whyText = showDuo\n      ? `One shade for your everyday skin. One shade warmer for when you want a sun-kissed glow. Same formula, same hold. Flawless skin all year round.`\n      : `The closest match to your natural skin tone. Apply in 10 minutes for an even, natural finish that lasts 48 hours through sweat, water and everything in between.`;\n\n    body.innerHTML = `\n      <h2 class=\"sf-result-title\">${resultTitle}</h2>\n      <p class=\"sf-result-sub\">Your shade is ready · ${pct}% match</p>\n      <div class=\"sf-shade-card primary\">\n        <div class=\"sf-shade-dot\" style=\"background:${primary.hex};\"></div>\n        <div class=\"sf-shade-info\">\n          <div class=\"sf-shade-tag\">RECOMMENDED FOR YOU</div>\n          <strong>${primary.name}</strong>\n          <span>${primary.desc}</span>\n        </div>\n      </div>\n      ${showDuo ? `\n      <div class=\"sf-shade-card secondary\">\n        <div class=\"sf-shade-dot\" style=\"background:${secondary.hex};\"></div>\n        <div class=\"sf-shade-info\">\n          <div class=\"sf-shade-tag\">SECOND SHADE · YOUR BRONZED SELF</div>\n          <strong>${secondary.name}</strong>\n          <span>${secondary.desc}</span>\n        </div>\n      </div>` : ''}\n      <div class=\"sf-why-box\">\n        <strong>WHY THIS ${showDuo ? 'DUO' : 'SHADE'}</strong>\n        ${whyText}\n      </div>\n      <button class=\"sf-cta-btn\" id=\"sfAddBtn\">Add my shade${showDuo ? 's' : ''} to cart</button>\n      <p class=\"sf-cta-sub\">${showDuo ? 'Kabuki Brush included free' : 'Free delivery on orders over £40'}</p>\n      <div class=\"sf-trust-row\">\n        <div class=\"sf-trust-item\"><em>48h</em><span>Sun, water, clothes</span></div>\n        <div class=\"sf-trust-item\"><em>10 min</em><span>Kabuki Brush included</span></div>\n        <div class=\"sf-trust-item\"><em>30 days</em><span>Money-back guarantee</span></div>\n        <div class=\"sf-trust-item\"><em>✓</em><span>Dermo tested · DHA-free</span></div>\n      </div>\n      <span class=\"sf-restart\" id=\"sfRestart\">↺ Restart the quiz</span>`;\n\n    document.getElementById('sfAddBtn').addEventListener('click', () => {\n      close();\n      const atcBtn = document.querySelector('[name=\"add\"], .product-form__submit, #AddToCart');\n      if (atcBtn) atcBtn.scrollIntoView({ behavior: 'smooth', block: 'center' });\n    });\n    document.getElementById('sfRestart').addEventListener('click', () => {\n      answers = { skin: null, vein: null, sun: null, usage: null };\n      step = 1; render();\n    });\n  }\n\n  render();\n})();\n</script>"
          }
