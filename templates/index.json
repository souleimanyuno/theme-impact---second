    "custom_liquid_q4d3Ea": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": true,
        "liquid": "<style>\n  .sorelya-social-proof,\n  .sorelya-social-proof * {\n    box-sizing: border-box;\n  }\n\n  .sorelya-social-proof {\n    width: 100%;\n    max-width: 1500px;\n    margin: 0 auto;\n    padding: 20px 20px 24px;\n    overflow: hidden;\n    background: #fff;\n    font-family: Arial, Helvetica, sans-serif;\n    color: #111;\n  }\n\n  /* =============================\n     TRACK\n  ============================= */\n\n  .sorelya-social-proof__track {\n    display: grid;\n    grid-template-columns: repeat(3, minmax(0, 1fr));\n    gap: 44px;\n    align-items: stretch;\n    width: 100%;\n  }\n\n  /* =============================\n     CARD\n  ============================= */\n\n  .sorelya-social-card {\n    display: flex;\n    flex-direction: column;\n    min-width: 0;\n    padding: 20px 22px 12px;\n    overflow: hidden;\n    background: #fff;\n    border: 1px solid #d9d9d9;\n    border-radius: 18px;\n    box-shadow:\n      0 2px 5px rgba(0, 0, 0, 0.04),\n      0 6px 14px rgba(0, 0, 0, 0.06);\n    scroll-snap-align: start;\n    scroll-snap-stop: always;\n  }\n\n  /* =============================\n     PROFILE\n  ============================= */\n\n  .sorelya-social-card__header {\n    display: flex;\n    align-items: center;\n    gap: 13px;\n    margin-bottom: 15px;\n  }\n\n  .sorelya-social-card__avatar {\n    display: block;\n    flex: 0 0 auto;\n    width: 54px;\n    height: 54px;\n    object-fit: cover;\n    border-radius: 50%;\n  }\n\n  .sorelya-social-card__identity {\n    min-width: 0;\n  }\n\n  .sorelya-social-card__name {\n    margin: 0 0 3px;\n    color: #090909;\n    font-size: 20px;\n    font-weight: 800;\n    line-height: 1.1;\n    letter-spacing: -0.02em;\n  }\n\n  .sorelya-social-card__time {\n    margin: 0;\n    color: #333;\n    font-size: 15px;\n    font-weight: 400;\n    line-height: 1.25;\n  }\n\n  /* =============================\n     REVIEW COPY\n  ============================= */\n\n  .sorelya-social-card__copy {\n    flex: 1;\n    margin: 0 0 18px;\n    color: #111;\n    font-size: 18px;\n    font-weight: 400;\n    line-height: 1.45;\n    letter-spacing: -0.01em;\n  }\n\n  /* =============================\n     FACEBOOK-STYLE FOOTER\n  ============================= */\n\n  .sorelya-social-card__footer {\n    margin-top: auto;\n  }\n\n  .sorelya-social-card__stats {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    min-height: 30px;\n    padding: 2px 0 9px;\n    color: #222;\n    font-size: 14px;\n    line-height: 1;\n  }\n\n  .sorelya-social-card__reaction-group {\n    display: flex;\n    align-items: center;\n    gap: 7px;\n  }\n\n  .sorelya-social-card__reaction-image {\n    display: block;\n    width: 68px;\n    max-width: 68px;\n    height: auto;\n    object-fit: contain;\n  }\n\n  .sorelya-social-card__reaction-count,\n  .sorelya-social-card__comment-count {\n    color: #222;\n    font-size: 14px;\n    font-weight: 400;\n    white-space: nowrap;\n  }\n\n  .sorelya-social-card__separator {\n    width: 100%;\n    height: 1px;\n    background: #b9c1cb;\n  }\n\n  .sorelya-social-card__actions {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    height: 40px;\n    overflow: hidden;\n  }\n\n  .sorelya-social-card__actions-image {\n    display: block;\n    width: 100%;\n    max-width: 315px;\n    height: 31px;\n    object-fit: contain;\n  }\n\n  /* =============================\n     DOTS\n  ============================= */\n\n  .sorelya-social-proof__dots {\n    display: none;\n    align-items: center;\n    justify-content: center;\n    gap: 9px;\n    margin-top: 17px;\n  }\n\n  .sorelya-social-proof__dot {\n    width: 8px;\n    height: 8px;\n    padding: 0;\n    border: 0;\n    border-radius: 50%;\n    background: #bdbdbd;\n    cursor: pointer;\n    transition:\n      background-color 0.2s ease,\n      transform 0.2s ease;\n  }\n\n  .sorelya-social-proof__dot.active {\n    background: #050505;\n    transform: scale(1.08);\n  }\n\n  /* =============================\n     MOBILE\n  ============================= */\n\n  @media (max-width: 749px) {\n    .sorelya-social-proof {\n      padding: 12px 12px 16px;\n    }\n\n    .sorelya-social-proof__track {\n      display: flex;\n      gap: 12px;\n      width: 100%;\n      overflow-x: auto;\n      overscroll-behavior-x: contain;\n      scroll-behavior: smooth;\n      scroll-snap-type: x mandatory;\n      scrollbar-width: none;\n      -webkit-overflow-scrolling: touch;\n      touch-action: pan-x;\n    }\n\n    .sorelya-social-proof__track::-webkit-scrollbar {\n      display: none;\n    }\n\n    .sorelya-social-card {\n      flex: 0 0 100%;\n      width: 100%;\n      padding: 16px 16px 10px;\n      border-radius: 17px;\n    }\n\n    .sorelya-social-card__header {\n      gap: 11px;\n      margin-bottom: 14px;\n    }\n\n    .sorelya-social-card__avatar {\n      width: 47px;\n      height: 47px;\n    }\n\n    .sorelya-social-card__name {\n      font-size: 17px;\n    }\n\n    .sorelya-social-card__time {\n      font-size: 13px;\n    }\n\n    .sorelya-social-card__copy {\n      margin-bottom: 17px;\n      font-size: 15.5px;\n      line-height: 1.48;\n      letter-spacing: -0.012em;\n    }\n\n    .sorelya-social-card__stats {\n      min-height: 27px;\n      padding-bottom: 8px;\n    }\n\n    .sorelya-social-card__reaction-image {\n      width: 54px;\n      max-width: 54px;\n    }\n\n    .sorelya-social-card__reaction-count,\n    .sorelya-social-card__comment-count {\n      font-size: 12.5px;\n    }\n\n    .sorelya-social-card__actions {\n      height: 38px;\n    }\n\n    .sorelya-social-card__actions-image {\n      width: 100%;\n      max-width: 290px;\n      height: 28px;\n    }\n\n    .sorelya-social-proof__dots {\n      display: flex;\n    }\n  }\n</style>\n\n<div class=\"sorelya-social-proof\" data-sorelya-social-proof>\n\n  <div\n    class=\"sorelya-social-proof__track\"\n    data-sorelya-social-track\n  >\n\n    <!-- REVIEW 1 -->\n    <article\n      class=\"sorelya-social-card\"\n      data-sorelya-social-card\n    >\n      <header class=\"sorelya-social-card__header\">\n        <img\n          class=\"sorelya-social-card__avatar\"\n          src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/1748551321-image_63_430x.jpg?v=1784600276\"\n          alt=\"Sofia M.\"\n          loading=\"lazy\"\n        >\n\n        <div class=\"sorelya-social-card__identity\">\n          <p class=\"sorelya-social-card__name\">Sofia M.</p>\n          <p class=\"sorelya-social-card__time\">1 day ago</p>\n        </div>\n      </header>\n\n      <p class=\"sorelya-social-card__copy\">\n        I had a whole drawer of lipsticks that looked beautiful in the\n        store and completely wrong on me. Every nude seemed to turn\n        orange. SORELYA developed into the softest pink-rose not too\n        bright and not too nude. My daughter tried the same tube and\n        hers looked warmer and more coral. Same lipstick, two\n        different-looking shades. I finally stopped buying colors that\n        end up unused in a drawer.\n      </p>\n\n      <footer class=\"sorelya-social-card__footer\">\n        <div class=\"sorelya-social-card__stats\">\n          <div class=\"sorelya-social-card__reaction-group\">\n            <img\n              class=\"sorelya-social-card__reaction-image\"\n              src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/e98d7178-1e69-4534-a9b7-61259c8938a0_430x.png?v=1784600276\"\n              alt=\"\"\n              aria-hidden=\"true\"\n              loading=\"lazy\"\n            >\n            <span class=\"sorelya-social-card__reaction-count\">30</span>\n          </div>\n\n          <span class=\"sorelya-social-card__comment-count\">\n            7 comments\n          </span>\n        </div>\n\n        <div class=\"sorelya-social-card__separator\"></div>\n\n        <div class=\"sorelya-social-card__actions\">\n          <img\n            class=\"sorelya-social-card__actions-image\"\n            src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/ee0bbe9c-f2b3-40fd-83b9-2d4279cffa2e_430x.png?v=1784600276\"\n            alt=\"Like, Comment and Share\"\n            loading=\"lazy\"\n          >\n        </div>\n      </footer>\n    </article>\n\n    <!-- REVIEW 2 -->\n    <article\n      class=\"sorelya-social-card\"\n      data-sorelya-social-card\n    >\n      <header class=\"sorelya-social-card__header\">\n        <img\n          class=\"sorelya-social-card__avatar\"\n          src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/1748552506-image_63_1_430x.jpg?v=1784600276\"\n          alt=\"Natalie R.\"\n          loading=\"lazy\"\n        >\n\n        <div class=\"sorelya-social-card__identity\">\n          <p class=\"sorelya-social-card__name\">Natalie R.</p>\n          <p class=\"sorelya-social-card__time\">6 hours ago</p>\n        </div>\n      </header>\n\n      <p class=\"sorelya-social-card__copy\">\n        I stopped wearing lipstick three years ago because everything\n        made my lips feel dry and tight. SORELYA feels completely\n        different more like a tinted balm, but with real color. Mine\n        develops into a beautiful coral-rose and my lips still feel\n        soft after coffee and lunch. There is no heavy matte feeling\n        and no cracked-looking finish by the afternoon. My menopause\n        lips finally feel comfortable wearing color again.\n      </p>\n\n      <footer class=\"sorelya-social-card__footer\">\n        <div class=\"sorelya-social-card__stats\">\n          <div class=\"sorelya-social-card__reaction-group\">\n            <img\n              class=\"sorelya-social-card__reaction-image\"\n              src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/e98d7178-1e69-4534-a9b7-61259c8938a0_430x.png?v=1784600276\"\n              alt=\"\"\n              aria-hidden=\"true\"\n              loading=\"lazy\"\n            >\n            <span class=\"sorelya-social-card__reaction-count\">27</span>\n          </div>\n\n          <span class=\"sorelya-social-card__comment-count\">\n            5 comments\n          </span>\n        </div>\n\n        <div class=\"sorelya-social-card__separator\"></div>\n\n        <div class=\"sorelya-social-card__actions\">\n          <img\n            class=\"sorelya-social-card__actions-image\"\n            src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/ee0bbe9c-f2b3-40fd-83b9-2d4279cffa2e_430x.png?v=1784600276\"\n            alt=\"Like, Comment and Share\"\n            loading=\"lazy\"\n          >\n        </div>\n      </footer>\n    </article>\n\n    <!-- REVIEW 3 -->\n    <article\n      class=\"sorelya-social-card\"\n      data-sorelya-social-card\n    >\n      <header class=\"sorelya-social-card__header\">\n        <img\n          class=\"sorelya-social-card__avatar\"\n          src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/1748431982-r5_430x.jpg?v=1784600276\"\n          alt=\"Camilla D.\"\n          loading=\"lazy\"\n        >\n\n        <div class=\"sorelya-social-card__identity\">\n          <p class=\"sorelya-social-card__name\">Camilla D.</p>\n          <p class=\"sorelya-social-card__time\">2 hours ago</p>\n        </div>\n      </header>\n\n      <p class=\"sorelya-social-card__copy\">\n        I used to check my lipstick after every coffee because the\n        center disappeared and the color crept into the lines around\n        my mouth. Now I apply SORELYA in the morning and barely think\n        about it again. It stayed soft and even through a meeting,\n        errands and dinner. Best of all, the edges still looked neat.\n        My husband even told me I looked beautiful for no particular\n        reason after twelve years of marriage.\n      </p>\n\n      <footer class=\"sorelya-social-card__footer\">\n        <div class=\"sorelya-social-card__stats\">\n          <div class=\"sorelya-social-card__reaction-group\">\n            <img\n              class=\"sorelya-social-card__reaction-image\"\n              src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/e98d7178-1e69-4534-a9b7-61259c8938a0_430x.png?v=1784600276\"\n              alt=\"\"\n              aria-hidden=\"true\"\n              loading=\"lazy\"\n            >\n            <span class=\"sorelya-social-card__reaction-count\">76</span>\n          </div>\n\n          <span class=\"sorelya-social-card__comment-count\">\n            10 comments\n          </span>\n        </div>\n\n        <div class=\"sorelya-social-card__separator\"></div>\n\n        <div class=\"sorelya-social-card__actions\">\n          <img\n            class=\"sorelya-social-card__actions-image\"\n            src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/ee0bbe9c-f2b3-40fd-83b9-2d4279cffa2e_430x.png?v=1784600276\"\n            alt=\"Like, Comment and Share\"\n            loading=\"lazy\"\n          >\n        </div>\n      </footer>\n    </article>\n\n  </div>\n\n  <div\n    class=\"sorelya-social-proof__dots\"\n    data-sorelya-social-dots\n  >\n    <button\n      class=\"sorelya-social-proof__dot active\"\n      type=\"button\"\n      aria-label=\"Show review 1\"\n      data-sorelya-social-dot=\"0\"\n    ></button>\n\n    <button\n      class=\"sorelya-social-proof__dot\"\n      type=\"button\"\n      aria-label=\"Show review 2\"\n      data-sorelya-social-dot=\"1\"\n    ></button>\n\n    <button\n      class=\"sorelya-social-proof__dot\"\n      type=\"button\"\n      aria-label=\"Show review 3\"\n      data-sorelya-social-dot=\"2\"\n    ></button>\n  </div>\n\n</div>\n\n<script>\n  (function () {\n    document\n      .querySelectorAll('[data-sorelya-social-proof]')\n      .forEach(function (section) {\n        var track = section.querySelector(\n          '[data-sorelya-social-track]'\n        );\n\n        var cards = Array.from(\n          section.querySelectorAll(\n            '[data-sorelya-social-card]'\n          )\n        );\n\n        var dots = Array.from(\n          section.querySelectorAll(\n            '[data-sorelya-social-dot]'\n          )\n        );\n\n        if (!track || !cards.length) return;\n\n        function setActiveDot(index) {\n          dots.forEach(function (dot, dotIndex) {\n            dot.classList.toggle(\n              'active',\n              dotIndex === index\n            );\n          });\n        }\n\n        /* Toujours démarrer sur le premier avis */\n        requestAnimationFrame(function () {\n          track.scrollLeft = 0;\n          setActiveDot(0);\n        });\n\n        if ('IntersectionObserver' in window) {\n          var observer = new IntersectionObserver(\n            function (entries) {\n              entries.forEach(function (entry) {\n                if (\n                  entry.isIntersecting &&\n                  entry.intersectionRatio >= 0.65\n                ) {\n                  var index = cards.indexOf(entry.target);\n\n                  if (index >= 0) {\n                    setActiveDot(index);\n                  }\n                }\n              });\n            },\n            {\n              root: track,\n              threshold: [0.4, 0.65, 0.9]\n            }\n          );\n\n          cards.forEach(function (card) {\n            observer.observe(card);\n          });\n        }\n\n        dots.forEach(function (dot, index) {\n          dot.addEventListener('click', function () {\n            var targetCard = cards[index];\n\n            if (!targetCard) return;\n\n            track.scrollTo({\n              left: targetCard.offsetLeft - track.offsetLeft,\n              behavior: 'smooth'\n            });\n\n            setActiveDot(index);\n          });\n        });\n      });\n  })();\n</script>",
