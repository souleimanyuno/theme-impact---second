            "liquid": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');\n\n  /* ─────────────────────────────\n     TRUST + PAYMENTS\n  ───────────────────────────── */\n\n  .sorelya-acc-trust {\n    font-family: 'Inter', sans-serif;\n    text-align: center;\n    padding: 16px 0 10px;\n  }\n\n  .sorelya-acc-trust__text {\n    font-size: 11px;\n    font-weight: 700;\n    color: #111;\n    margin: 0 0 12px;\n    letter-spacing: -0.01em;\n  }\n\n  .sorelya-acc-trust__payments img {\n    width: 100%;\n    max-width: 420px;\n    height: auto;\n    display: block;\n    margin: 0 auto;\n  }\n\n  /* ─────────────────────────────\n     ACCORDION\n  ───────────────────────────── */\n\n  .sorelya-acc {\n    font-family: 'Inter', sans-serif;\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n    padding: 16px 0;\n    width: 100%;\n  }\n\n  .sorelya-acc__item {\n    border: 1.5px solid #e3e6df;\n    border-radius: 16px;\n    background: #fff;\n    overflow: hidden;\n    transition:\n      border-color 0.25s ease,\n      box-shadow 0.25s ease;\n  }\n\n  .sorelya-acc__item.open {\n    border-color: #78a953;\n    box-shadow: 0 6px 20px rgba(120, 169, 83, 0.09);\n  }\n\n  .sorelya-acc__trigger {\n    width: 100%;\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    padding: 14px 16px;\n    background: transparent;\n    border: none;\n    cursor: pointer;\n    text-align: left;\n    font-family: 'Inter', sans-serif;\n  }\n\n  .sorelya-acc__badge {\n    width: 40px;\n    height: 40px;\n    border-radius: 10px;\n    background: #f0f6ec;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    flex-shrink: 0;\n  }\n\n  .sorelya-acc__badge svg {\n    width: 20px;\n    height: 20px;\n    stroke: #78a953;\n    fill: none;\n    stroke-width: 1.9;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n\n  .sorelya-acc__label {\n    flex: 1;\n    font-size: 15px;\n    font-weight: 800;\n    color: #111;\n    letter-spacing: -0.01em;\n  }\n\n  .sorelya-acc__chevron {\n    width: 18px;\n    height: 18px;\n    flex-shrink: 0;\n    stroke: #8e948a;\n    fill: none;\n    transition:\n      transform 0.3s ease,\n      stroke 0.2s ease;\n  }\n\n  .sorelya-acc__item.open .sorelya-acc__chevron {\n    transform: rotate(180deg);\n    stroke: #78a953;\n  }\n\n  .sorelya-acc__body {\n    display: none;\n    padding: 2px 16px 18px;\n  }\n\n  .sorelya-acc__item.open .sorelya-acc__body {\n    display: block;\n  }\n\n  .sorelya-acc__intro {\n    font-size: 13.5px;\n    color: #4b4b4b;\n    line-height: 1.65;\n    margin: 0 0 16px;\n  }\n\n  /* ─────────────────────────────\n     HOW IT WORKS\n  ───────────────────────────── */\n\n  .sorelya-steps {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 8px;\n  }\n\n  .sorelya-step {\n    border: 1.5px solid #e4e8e0;\n    border-radius: 13px;\n    padding: 14px 9px 12px;\n    text-align: center;\n    background: #fff;\n  }\n\n  .sorelya-step__number {\n    width: 27px;\n    height: 27px;\n    border-radius: 50%;\n    background: #78a953;\n    color: #fff;\n    font-size: 12px;\n    font-weight: 900;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    margin: 0 auto 9px;\n  }\n\n  .sorelya-step__title {\n    font-size: 12.5px;\n    font-weight: 800;\n    color: #111;\n    margin-bottom: 4px;\n  }\n\n  .sorelya-step__text {\n    font-size: 11.5px;\n    color: #666;\n    line-height: 1.4;\n  }\n\n  .sorelya-step__time {\n    display: inline-block;\n    margin-top: 7px;\n    padding: 4px 8px;\n    border-radius: 999px;\n    background: #f0f6ec;\n    color: #5f873f;\n    font-size: 9.5px;\n    font-weight: 800;\n    text-transform: uppercase;\n    letter-spacing: 0.04em;\n  }\n\n  .sorelya-replace-note {\n    margin-top: 12px;\n    padding: 11px 13px;\n    border-radius: 11px;\n    background: #f5f8f2;\n    display: flex;\n    align-items: flex-start;\n    gap: 8px;\n    font-size: 12.5px;\n    color: #485143;\n    line-height: 1.5;\n  }\n\n  .sorelya-replace-note svg {\n    width: 16px;\n    height: 16px;\n    flex-shrink: 0;\n    margin-top: 1px;\n    stroke: #78a953;\n    fill: none;\n    stroke-width: 2;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n\n  /* ─────────────────────────────\n     PRODUCT DETAILS\n  ───────────────────────────── */\n\n  .sorelya-detail-grid {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 6px;\n    margin-bottom: 16px;\n  }\n\n  .sorelya-detail {\n    text-align: center;\n    padding: 10px 5px;\n    border-radius: 10px;\n    background: #f7f9f5;\n  }\n\n  .sorelya-detail svg {\n    width: 23px;\n    height: 23px;\n    stroke: #78a953;\n    fill: none;\n    stroke-width: 1.8;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n    margin-bottom: 5px;\n  }\n\n  .sorelya-detail span {\n    display: block;\n    font-size: 10.5px;\n    line-height: 1.3;\n    font-weight: 800;\n    color: #151515;\n  }\n\n  .sorelya-section-title {\n    font-size: 13px;\n    font-weight: 900;\n    color: #111;\n    margin: 16px 0 9px;\n  }\n\n  .sorelya-ingredient-pills {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 7px;\n    margin-bottom: 14px;\n  }\n\n  .sorelya-ingredient-pill {\n    display: inline-flex;\n    align-items: center;\n    gap: 5px;\n    background: #edf5e8;\n    color: #5c823e;\n    padding: 6px 10px;\n    border-radius: 999px;\n    font-size: 10.5px;\n    font-weight: 700;\n  }\n\n  .sorelya-ingredient-pill svg {\n    width: 12px;\n    height: 12px;\n    stroke: #78a953;\n    fill: none;\n    stroke-width: 2;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n\n  .sorelya-detail-copy {\n    font-size: 13px;\n    color: #555;\n    line-height: 1.6;\n    margin: 0;\n  }\n\n  .sorelya-safety {\n    margin-top: 14px;\n    border-top: 1px solid #eceee9;\n    padding-top: 13px;\n    font-size: 11.5px;\n    color: #777;\n    line-height: 1.55;\n  }\n\n  /* ─────────────────────────────\n     VET REVIEWS\n  ───────────────────────────── */\n\n  .sorelya-vets__intro {\n    font-size: 13.5px;\n    color: #4b4b4b;\n    line-height: 1.65;\n    margin: 0 0 20px;\n  }\n\n  .sorelya-vets__list {\n    display: flex;\n    flex-direction: column;\n    gap: 0;\n    text-align: left;\n  }\n\n  .sorelya-vets__card {\n    display: flex;\n    flex-direction: column;\n    gap: 12px;\n    padding: 0 0 22px;\n  }\n\n  .sorelya-vets__card + .sorelya-vets__card {\n    padding-top: 22px;\n    border-top: 1px solid #eceee9;\n  }\n\n  .sorelya-vets__top {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n  }\n\n  .sorelya-vets__card:nth-child(even) .sorelya-vets__top {\n    flex-direction: row-reverse;\n    text-align: right;\n  }\n\n  .sorelya-vets__card:nth-child(even) .sorelya-vets__verified {\n    justify-content: flex-end;\n  }\n\n  .sorelya-vets__photo {\n    width: 72px;\n    height: 72px;\n    border-radius: 50%;\n    object-fit: cover;\n    flex-shrink: 0;\n    display: block;\n    border: 2.5px solid #e8f0e2;\n  }\n\n  .sorelya-vets__identity {\n    flex: 1;\n  }\n\n  .sorelya-vets__name {\n    font-size: 13.5px;\n    font-weight: 800;\n    color: #0d1f3c;\n    margin-bottom: 2px;\n    line-height: 1.3;\n  }\n\n  .sorelya-vets__specialty {\n    font-size: 11.5px;\n    color: #888;\n    margin-bottom: 5px;\n    line-height: 1.4;\n  }\n\n  .sorelya-vets__verified {\n    display: inline-flex;\n    align-items: center;\n    gap: 4px;\n    font-size: 11px;\n    font-weight: 700;\n    color: #5f873f;\n  }\n\n  .sorelya-vets__verified svg {\n    width: 13px;\n    height: 13px;\n    stroke: #5f873f;\n    fill: none;\n    stroke-width: 2.5;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n\n  .sorelya-vets__quote {\n    border-left: 3px solid #78a953;\n    padding-left: 14px;\n    font-size: 13.5px;\n    font-style: italic;\n    color: #333;\n    line-height: 1.7;\n    margin: 0;\n  }\n\n  .sorelya-vets__highlight {\n    font-style: normal;\n    font-weight: 700;\n    color: #111;\n  }\n\n  .sorelya-vets__note {\n    margin-top: 16px;\n    padding: 11px 13px;\n    border-radius: 11px;\n    background: #f5f8f2;\n    display: flex;\n    align-items: flex-start;\n    gap: 8px;\n    font-size: 12px;\n    color: #485143;\n    line-height: 1.5;\n  }\n\n  .sorelya-vets__note svg {\n    width: 16px;\n    height: 16px;\n    flex-shrink: 0;\n    margin-top: 1px;\n    stroke: #78a953;\n    fill: none;\n    stroke-width: 2;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n\n  /* ─────────────────────────────\n     DELIVERY\n  ───────────────────────────── */\n\n  .sorelya-delivery-message {\n    background: #f5f8f2;\n    border-left: 4px solid #78a953;\n    border-radius: 10px;\n    padding: 13px 14px;\n    margin-bottom: 14px;\n    font-size: 13.5px;\n    color: #384332;\n    line-height: 1.55;\n  }\n\n  .sorelya-delivery-message strong {\n    color: #111;\n    font-weight: 800;\n  }\n\n  .sorelya-delivery-grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 8px;\n  }\n\n  .sorelya-delivery-card {\n    background: #f7f9f5;\n    border: 1px solid #e4e8e0;\n    border-radius: 12px;\n    padding: 12px 8px;\n    text-align: center;\n  }\n\n  .sorelya-delivery-card svg {\n    width: 22px;\n    height: 22px;\n    stroke: #78a953;\n    fill: none;\n    stroke-width: 1.8;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n    margin-bottom: 6px;\n  }\n\n  .sorelya-delivery-card__title {\n    font-size: 11.5px;\n    font-weight: 800;\n    color: #111;\n    line-height: 1.3;\n    margin-bottom: 3px;\n  }\n\n  .sorelya-delivery-card__sub {\n    font-size: 10.5px;\n    color: #70756d;\n    line-height: 1.35;\n  }\n\n  /* ─────────────────────────────\n     MOBILE\n  ───────────────────────────── */\n\n  @media (max-width: 480px) {\n    .sorelya-steps {\n      grid-template-columns: 1fr;\n    }\n\n    .sorelya-step {\n      display: grid;\n      grid-template-columns: 34px 1fr;\n      column-gap: 10px;\n      text-align: left;\n      padding: 12px;\n    }\n\n    .sorelya-step__number {\n      grid-row: 1 / 4;\n      margin: 0;\n    }\n\n    .sorelya-step__time {\n      width: fit-content;\n    }\n\n    .sorelya-detail-grid {\n      grid-template-columns: repeat(2, 1fr);\n      gap: 7px;\n    }\n\n    .sorelya-acc__label {\n      font-size: 14.5px;\n    }\n\n    .sorelya-delivery-grid {\n      grid-template-columns: 1fr;\n    }\n\n    .sorelya-delivery-card {\n      display: flex;\n      align-items: center;\n      text-align: left;\n      gap: 10px;\n      padding: 11px 12px;\n    }\n\n    .sorelya-delivery-card svg {\n      flex-shrink: 0;\n      margin-bottom: 0;\n    }\n  }\n</style>\n\n<!-- GUARANTEE + PAYMENT LOGOS -->\n<div class=\"sorelya-acc-trust\">\n  <p class=\"sorelya-acc-trust__text\">\n    30-Day Money Back Guarantee • Free Shipping on All Orders\n  </p>\n\n  <div class=\"sorelya-acc-trust__payments\">\n    <img\n      src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/Capture_d_ecran_le_2026-06-26_a_14.45.12_430x.png?v=1782481530\"\n      alt=\"Secure payment methods\"\n      loading=\"lazy\"\n    >\n  </div>\n</div>\n\n<!-- ACCORDIONS -->\n<div class=\"sorelya-acc\" data-sorelya-root>\n\n  <!-- ═══════════════════════════════\n       1. HOW IT WORKS\n  ═══════════════════════════════ -->\n  <div class=\"sorelya-acc__item\" data-sorelya-accordion>\n    <button class=\"sorelya-acc__trigger\" type=\"button\" aria-expanded=\"false\">\n      <div class=\"sorelya-acc__badge\">\n        <svg viewBox=\"0 0 24 24\">\n          <circle cx=\"12\" cy=\"12\" r=\"9\"/>\n          <polyline points=\"12 7 12 12 15 14\"/>\n        </svg>\n      </div>\n      <span class=\"sorelya-acc__label\">How It Works</span>\n      <svg class=\"sorelya-acc__chevron\" viewBox=\"0 0 24 24\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n        <polyline points=\"6 9 12 15 18 9\"/>\n      </svg>\n    </button>\n\n    <div class=\"sorelya-acc__body\">\n      <p class=\"sorelya-acc__intro\">\n        One small tag. One simple monthly routine. More freedom for every walk, trail and backyard adventure.\n      </p>\n\n      <div class=\"sorelya-steps\">\n        <div class=\"sorelya-step\">\n          <div class=\"sorelya-step__number\">1</div>\n          <div class=\"sorelya-step__title\">Slide It On</div>\n          <div class=\"sorelya-step__text\">Attach SORELYA securely to your dog's existing collar.</div>\n          <span class=\"sorelya-step__time\">Takes seconds</span>\n        </div>\n        <div class=\"sorelya-step\">\n          <div class=\"sorelya-step__number\">2</div>\n          <div class=\"sorelya-step__title\">Let It Work</div>\n          <div class=\"sorelya-step__text\">The protected plant-based liquid gradually releases from inside the tag.</div>\n          <span class=\"sorelya-step__time\">Day & night</span>\n        </div>\n        <div class=\"sorelya-step\">\n          <div class=\"sorelya-step__number\">3</div>\n          <div class=\"sorelya-step__title\">Replace Monthly</div>\n          <div class=\"sorelya-step__text\">Use one fresh SORELYA tag every 30 days to maintain its active effect.</div>\n          <span class=\"sorelya-step__time\">30-day use</span>\n        </div>\n      </div>\n\n      <div class=\"sorelya-replace-note\">\n        <svg viewBox=\"0 0 24 24\">\n          <polyline points=\"23 4 23 10 17 10\"/>\n          <path d=\"M20.49 15a9 9 0 1 1-2.12-9.36L23 10\"/>\n        </svg>\n        <span>The liquid remains sealed inside the tag, but its active effect lasts for approximately 30 days. Replace the tag monthly.</span>\n      </div>\n    </div>\n  </div>\n\n  <!-- ═══════════════════════════════\n       2. PRODUCT DETAILS & INGREDIENTS\n  ═══════════════════════════════ -->\n  <div class=\"sorelya-acc__item\" data-sorelya-accordion>\n    <button class=\"sorelya-acc__trigger\" type=\"button\" aria-expanded=\"false\">\n      <div class=\"sorelya-acc__badge\">\n        <svg viewBox=\"0 0 24 24\">\n          <path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/>\n          <polyline points=\"9 12 11 14 15 10\"/>\n        </svg>\n      </div>\n      <span class=\"sorelya-acc__label\">Product Details & Ingredients</span>\n      <svg class=\"sorelya-acc__chevron\" viewBox=\"0 0 24 24\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n        <polyline points=\"6 9 12 15 18 9\"/>\n      </svg>\n    </button>\n\n    <div class=\"sorelya-acc__body\">\n      <div class=\"sorelya-detail-grid\">\n        <div class=\"sorelya-detail\">\n          <svg viewBox=\"0 0 24 24\">\n            <circle cx=\"12\" cy=\"12\" r=\"9\"/>\n            <polyline points=\"12 7 12 12 15 14\"/>\n          </svg>\n          <span>30-Day Active Effect</span>\n        </div>\n        <div class=\"sorelya-detail\">\n          <svg viewBox=\"0 0 24 24\">\n            <path d=\"M12 2s6 7 6 12a6 6 0 0 1-12 0c0-5 6-12 6-12z\"/>\n          </svg>\n          <span>Water-Resistant</span>\n        </div>\n        <div class=\"sorelya-detail\">\n          <svg viewBox=\"0 0 24 24\">\n            <path d=\"M20 4C10 4 5 9 5 17c5 0 10-5 15-13z\"/>\n            <path d=\"M5 17c3-4 6-6 10-8\"/>\n          </svg>\n          <span>Plant-Based Formula</span>\n        </div>\n        <div class=\"sorelya-detail\">\n          <svg viewBox=\"0 0 24 24\">\n            <path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/>\n            <polyline points=\"9 12 11 14 15 10\"/>\n          </svg>\n          <span>Sealed Liquid Inside</span>\n        </div>\n      </div>\n\n      <div class=\"sorelya-section-title\">Plant-Based Ingredients</div>\n      <div class=\"sorelya-ingredient-pills\">\n        <span class=\"sorelya-ingredient-pill\">\n          <svg viewBox=\"0 0 24 24\"><path d=\"M20 4C10 4 5 9 5 17\"/></svg>\n          Citronella Oil\n        </span>\n        <span class=\"sorelya-ingredient-pill\">\n          <svg viewBox=\"0 0 24 24\"><path d=\"M20 4C10 4 5 9 5 17\"/></svg>\n          Cedarwood Oil\n        </span>\n        <span class=\"sorelya-ingredient-pill\">\n          <svg viewBox=\"0 0 24 24\"><path d=\"M20 4C10 4 5 9 5 17\"/></svg>\n          Lemongrass Oil\n        </span>\n        <span class=\"sorelya-ingredient-pill\">\n          <svg viewBox=\"0 0 24 24\"><path d=\"M20 4C10 4 5 9 5 17\"/></svg>\n          Peppermint Oil\n        </span>\n        <span class=\"sorelya-ingredient-pill\">\n          <svg viewBox=\"0 0 24 24\"><path d=\"M20 4C10 4 5 9 5 17\"/></svg>\n          Geranium Oil\n        </span>\n        <span class=\"sorelya-ingredient-pill\">\n          <svg viewBox=\"0 0 24 24\"><path d=\"M20 4C10 4 5 9 5 17\"/></svg>\n          Rosemary Oil\n        </span>\n      </div>\n\n      <div class=\"sorelya-section-title\">What You Receive</div>\n      <p class=\"sorelya-detail-copy\">\n        Your selected quantity of SORELYA™ collar tags. Each individual tag provides approximately 30 days of active use and fits directly onto your dog's existing collar.\n      </p>\n\n      <div class=\"sorelya-safety\">\n        Keep the tag sealed. Do not cut, open or allow your dog to chew it. Remove the tag if irritation occurs and keep it out of reach of children.\n      </div>\n    </div>\n  </div>\n\n  <!-- ═══════════════════════════════\n       3. WHAT VETERINARIANS SAY\n  ═══════════════════════════════ -->\n  <div class=\"sorelya-acc__item\" data-sorelya-accordion>\n    <button class=\"sorelya-acc__trigger\" type=\"button\" aria-expanded=\"false\">\n      <div class=\"sorelya-acc__badge\">\n        <svg viewBox=\"0 0 24 24\">\n          <path d=\"M22 12h-4l-3 9L9 3l-3 9H2\"/>\n        </svg>\n      </div>\n      <span class=\"sorelya-acc__label\">What Veterinarians Say</span>\n      <svg class=\"sorelya-acc__chevron\" viewBox=\"0 0 24 24\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n        <polyline points=\"6 9 12 15 18 9\"/>\n      </svg>\n    </button>\n\n    <div class=\"sorelya-acc__body\">\n      <p class=\"sorelya-vets__intro\">\n        Veterinary professionals share how a simple outdoor layer can give owners back the walks they used to enjoy — without the post-trail anxiety.\n      </p>\n\n      <div class=\"sorelya-vets__list\">\n\n        <!-- VET 1 — photo LEFT -->\n        <div class=\"sorelya-vets__card\">\n          <div class=\"sorelya-vets__top\">\n            <img class=\"sorelya-vets__photo\" src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/vet-1_430x.jpg?v=1782491118\" alt=\"Dr. Sarah Mitchell DVM\" loading=\"lazy\">\n            <div class=\"sorelya-vets__identity\">\n              <p class=\"sorelya-vets__name\">Dr. Sarah Mitchell, DVM</p>\n              <p class=\"sorelya-vets__specialty\">Small Animal Medicine — 14 Years Practice</p>\n              <span class=\"sorelya-vets__verified\">\n                <svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n                Verified Veterinarian\n              </span>\n            </div>\n          </div>\n          <p class=\"sorelya-vets__quote\">\"The owners I worry about most aren't the ones who skip prevention — they're the ones who do everything right and <span class=\"sorelya-vets__highlight\">still can't stop checking their dog's neck after every walk.</span> A simple plant-based layer on the collar gives them one more reason to relax when they get home.\"</p>\n        </div>\n\n        <!-- VET 2 — photo RIGHT -->\n        <div class=\"sorelya-vets__card\">\n          <div class=\"sorelya-vets__top\">\n            <img class=\"sorelya-vets__photo\" src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/vet-2_430x.jpg?v=1782491118\" alt=\"Dr. Emily Warren DVM\" loading=\"lazy\">\n            <div class=\"sorelya-vets__identity\">\n              <p class=\"sorelya-vets__name\">Dr. Emily Warren, DVM, DACVIM</p>\n              <p class=\"sorelya-vets__specialty\">Veterinary Parasitology Specialist</p>\n              <span class=\"sorelya-vets__verified\">\n                <svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n                Verified Veterinarian\n              </span>\n            </div>\n          </div>\n          <p class=\"sorelya-vets__quote\">\"Oral preventatives work systemically — they act after contact. What pet owners actually want is to <span class=\"sorelya-vets__highlight\">see fewer ticks climbing on in the first place.</span> Adding a plant-based collar layer for outdoor exposure is a sensible complement, not a replacement.\"</p>\n        </div>\n\n        <!-- VET 3 — photo LEFT -->\n        <div class=\"sorelya-vets__card\">\n          <div class=\"sorelya-vets__top\">\n            <img class=\"sorelya-vets__photo\" src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/vet-3_430x.jpg?v=1782491118\" alt=\"Dr. Rachel Hodgson DVM\" loading=\"lazy\">\n            <div class=\"sorelya-vets__identity\">\n              <p class=\"sorelya-vets__name\">Dr. Rachel Hodgson, DVM</p>\n              <p class=\"sorelya-vets__specialty\">Canine Behavioral Medicine</p>\n              <span class=\"sorelya-vets__verified\">\n                <svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n                Verified Veterinarian\n              </span>\n            </div>\n          </div>\n          <p class=\"sorelya-vets__quote\">\"I see dogs who start avoiding their owners' hands because <span class=\"sorelya-vets__highlight\">every petting session became a tick inspection.</span> Anything that helps the owner feel more prepared before the walk — so the dog can come home and be touched normally — is good for the bond.\"</p>\n        </div>\n\n        <!-- VET 4 — photo RIGHT -->\n        <div class=\"sorelya-vets__card\">\n          <div class=\"sorelya-vets__top\">\n            <img class=\"sorelya-vets__photo\" src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/vet-4_430x.jpg?v=1782491118\" alt=\"Dr. David Reyes DVM\" loading=\"lazy\">\n            <div class=\"sorelya-vets__identity\">\n              <p class=\"sorelya-vets__name\">Dr. David Reyes, DVM, PhD</p>\n              <p class=\"sorelya-vets__specialty\">Veterinary Toxicology, UC Davis</p>\n              <span class=\"sorelya-vets__verified\">\n                <svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n                Verified Veterinarian\n              </span>\n            </div>\n          </div>\n          <p class=\"sorelya-vets__quote\">\"Citronella, cedarwood and lemongrass have well-documented repellent properties in peer-reviewed literature. <span class=\"sorelya-vets__highlight\">A sealed delivery format on the collar is safer than open topical application</span> — no residue on hands, furniture or children.\"</p>\n        </div>\n\n        <!-- VET 5 — photo LEFT -->\n        <div class=\"sorelya-vets__card\">\n          <div class=\"sorelya-vets__top\">\n            <img class=\"sorelya-vets__photo\" src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/vet-5_430x.jpg?v=1782491118\" alt=\"Dr. Lauren Torres DVM\" loading=\"lazy\">\n            <div class=\"sorelya-vets__identity\">\n              <p class=\"sorelya-vets__name\">Dr. Lauren Torres, DVM</p>\n              <p class=\"sorelya-vets__specialty\">General Practice — 18 Years Experience</p>\n              <span class=\"sorelya-vets__verified\">\n                <svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n                Verified Veterinarian\n              </span>\n            </div>\n          </div>\n          <p class=\"sorelya-vets__quote\">\"I tell my clients: <span class=\"sorelya-vets__highlight\">keep giving the prevention your vet prescribed. Then add the outdoor layer.</span> One doesn't replace the other — but together, you walk out the door with less to second-guess and more to enjoy.\"</p>\n        </div>\n\n      </div>\n\n      <div class=\"sorelya-vets__note\">\n        <svg viewBox=\"0 0 24 24\">\n          <circle cx=\"12\" cy=\"12\" r=\"10\"/>\n          <line x1=\"12\" y1=\"16\" x2=\"12\" y2=\"12\"/>\n          <line x1=\"12\" y1=\"8\" x2=\"12.01\" y2=\"8\"/>\n        </svg>\n        <span>SORELYA is a plant-based outdoor layer. It does not replace veterinary-recommended tick and flea prevention. Continue your dog's existing prevention plan and regular post-walk checks.</span>\n      </div>\n    </div>\n  </div>\n\n  <!-- ═══════════════════════════════\n       4. FREE SHIPPING & DELIVERY\n  ═══════════════════════════════ -->\n  <div class=\"sorelya-acc__item\" data-sorelya-accordion>\n    <button class=\"sorelya-acc__trigger\" type=\"button\" aria-expanded=\"false\">\n      <div class=\"sorelya-acc__badge\">\n        <svg viewBox=\"0 0 24 24\">\n          <rect x=\"1\" y=\"3\" width=\"15\" height=\"13\" rx=\"1\"/>\n          <polygon points=\"16 8 20 8 23 11 23 16 16 16 16 8\"/>\n          <circle cx=\"5.5\" cy=\"18.5\" r=\"2.5\"/>\n          <circle cx=\"18.5\" cy=\"18.5\" r=\"2.5\"/>\n        </svg>\n      </div>\n      <span class=\"sorelya-acc__label\">Free Shipping & Delivery</span>\n      <svg class=\"sorelya-acc__chevron\" viewBox=\"0 0 24 24\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n        <polyline points=\"6 9 12 15 18 9\"/>\n      </svg>\n    </button>\n\n    <div class=\"sorelya-acc__body\">\n      <div class=\"sorelya-delivery-message\">\n        Order today, <strong data-sorelya-order-date>today</strong>.\n        Your order is expected to ship by\n        <strong data-sorelya-ship-date>within 48 hours</strong>\n        and arrive by\n        <strong data-sorelya-delivery-date>within 8 days</strong>.\n      </div>\n\n      <div class=\"sorelya-delivery-grid\">\n        <div class=\"sorelya-delivery-card\">\n          <svg viewBox=\"0 0 24 24\">\n            <path d=\"M20 12v8H4v-8\"/>\n            <polyline points=\"2 7 12 2 22 7\"/>\n            <path d=\"M5 9v3a7 7 0 0 0 14 0V9\"/>\n          </svg>\n          <div>\n            <div class=\"sorelya-delivery-card__title\">Free Shipping</div>\n            <div class=\"sorelya-delivery-card__sub\">Included with every order</div>\n          </div>\n        </div>\n\n        <div class=\"sorelya-delivery-card\">\n          <svg viewBox=\"0 0 24 24\">\n            <circle cx=\"12\" cy=\"12\" r=\"9\"/>\n            <polyline points=\"12 7 12 12 15 14\"/>\n          </svg>\n          <div>\n            <div class=\"sorelya-delivery-card__title\">Ships Within 48 Hours</div>\n            <div class=\"sorelya-delivery-card__sub\">Fast order processing</div>\n          </div>\n        </div>\n\n        <div class=\"sorelya-delivery-card\">\n          <svg viewBox=\"0 0 24 24\">\n            <rect x=\"3\" y=\"5\" width=\"18\" height=\"16\" rx=\"2\"/>\n            <line x1=\"16\" y1=\"3\" x2=\"16\" y2=\"7\"/>\n            <line x1=\"8\" y1=\"3\" x2=\"8\" y2=\"7\"/>\n            <line x1=\"3\" y1=\"11\" x2=\"21\" y2=\"11\"/>\n            <polyline points=\"9 16 11 18 15 14\"/>\n          </svg>\n          <div>\n            <div class=\"sorelya-delivery-card__title\">Expected Within 8 Days</div>\n            <div class=\"sorelya-delivery-card__sub\">Full tracking included</div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n</div>\n\n<script>\n  (function () {\n    var roots = document.querySelectorAll('[data-sorelya-root]');\n\n    roots.forEach(function (root) {\n      var accordionItems = root.querySelectorAll('[data-sorelya-accordion]');\n\n      /* FORCE ALL CLOSED ON LOAD */\n      accordionItems.forEach(function (item) {\n        item.classList.remove('open');\n        var trigger = item.querySelector('.sorelya-acc__trigger');\n        if (trigger) trigger.setAttribute('aria-expanded', 'false');\n      });\n\n      /* ACCORDION CLICKS */\n      accordionItems.forEach(function (item) {\n        var trigger = item.querySelector('.sorelya-acc__trigger');\n        if (!trigger) return;\n\n        trigger.addEventListener('click', function () {\n          var wasOpen = item.classList.contains('open');\n\n          accordionItems.forEach(function (otherItem) {\n            otherItem.classList.remove('open');\n            var otherTrigger = otherItem.querySelector('.sorelya-acc__trigger');\n            if (otherTrigger) otherTrigger.setAttribute('aria-expanded', 'false');\n          });\n\n          if (!wasOpen) {\n            item.classList.add('open');\n            trigger.setAttribute('aria-expanded', 'true');\n          }\n        });\n      });\n\n      /* DYNAMIC DELIVERY DATES */\n      function addCalendarDays(date, days) {\n        var result = new Date(date);\n        result.setDate(result.getDate() + days);\n        return result;\n      }\n\n      function formatDate(date) {\n        return new Intl.DateTimeFormat('en-US', {\n          weekday: 'long',\n          month: 'long',\n          day: 'numeric'\n        }).format(date);\n      }\n\n      var orderDate = new Date();\n      var shipDate = addCalendarDays(orderDate, 2);\n      var deliveryDate = addCalendarDays(shipDate, 6);\n\n      root.querySelectorAll('[data-sorelya-order-date]').forEach(function (el) {\n        el.textContent = formatDate(orderDate);\n      });\n      root.querySelectorAll('[data-sorelya-ship-date]').forEach(function (el) {\n        el.textContent = formatDate(shipDate);\n      });\n      root.querySelectorAll('[data-sorelya-delivery-date]').forEach(function (el) {\n        el.textContent = formatDate(deliveryDate);\n      });\n    });\n  })();\n</script>"
          }
        },
        "collapsible_text_7LqTqm": {
          "type": "collapsible_text",
          "disabled": true,
          "settings": {
            "icon": "none",
            "icon_width": 20,
            "title": "PFLEGE",
            "content": "<ol><li><strong>Bei 30°C in der Waschmaschine oder per Hand waschen</strong><br/>Beim Maschinenwaschen das Schonprogramm verwenden. Anders als billige Strumpfhosen die beim ersten Tragen reißen, sind diese für die Ewigkeit gemacht — kein Drama nötig.</li><li><strong>Normales Waschmittel verwenden (kein Bleichmittel, keine Weichspüler)</strong><br/>Ein mildes Waschmittel reicht völlig aus. Bleichmittel und Weichspüler beschädigen die formenden Fasern — und diese sind bereits angenehm weich.</li><li><strong>Liegend oder hängend trocknen (NIE in den Trockner)</strong><br/>Der Trockner ist dein Feind. Einfach normal aufhängen oder flach hinlegen. Direktes Sonnenlicht vermeiden, sonst kann die Farbe verblassen.</li><li><strong>Sorgfältig falten und in der Schublade aufbewahren</strong><br/>Keine komischen Falten, sonst verlieren sie die Form. Behandle sie wie dein Lieblingsteil — keine spezielle Aufbewahrung nötig, nur normale Pflege.</li><li><strong>Nur bei Bedarf ersetzen</strong><br/>Wenn das Kontrollband nicht mehr so gut hält oder der Stoff Verschleiß zeigt, ist es Zeit für ein neues Paar. Aber keine Sorge — diese halten VIEL länger als die 5€-Strumpfhosen die nach einmaligem Tragen reißen.</li></ol><p><strong>Profi-Tipp:</strong> Kauf 2-3 Paare und wechsle sie wöchentlich ab — so halten sie doppelt so lang.</p>",
            "page": ""
          }
        },
        "collapsible_text_7tUrHT": {
          "type": "collapsible_text",
          "disabled": true,
          "settings": {
            "icon": "none",
            "icon_width": 20,
            "title": "Versandinformationen",
            "content": "<p>Bestellung aufgegeben? 🎉 Gute Wahl! Unser Team macht sich sofort an die Arbeit um dein Paket sorgfältig vorzubereiten.</p><p>⏱️ Bearbeitungszeit: Innerhalb von 24-48 Stunden<br/>🚚 Lieferung: 7-10 Werktage (kostenloser Versand)</p><p>Sobald deine Bestellung verschickt wurde, erhältst du eine Bestätigungs-E-Mail mit deiner Sendungsverfolgungsnummer. Mit einem Klick kannst du dein Paket bis zur Haustür verfolgen.</p><p>Hinweis: In Stoßzeiten sind beliebte Farbtöne wie Ivory Kiss und Golden Desire schnell ausverkauft.</p><p>Fragen? Unser Kundensupport ist 7 Tage die Woche für dich da.</p>",
            "page": ""
          }
        },
        "collapsible_text_VtxJgU": {
          "type": "collapsible_text",
          "disabled": true,
          "settings": {
            "icon": "none",
            "icon_width": 20,
            "title": "Risikofreie Garantie",
            "content": "<p>Teste Sorelya 30 Tage risikofrei. Nicht begeistert? Vollständige Rückerstattung — keine Fragen gestellt.</p><p><strong>Kostenloser Größen- & Farbtausch</strong><br/>Falsche Farbe oder Größe bestellt? Wir tauschen kostenlos. Du zahlst nur den Rückversand.</p><p><strong>Lebenslange Ersatzgarantie</strong><br/>Wenn sie je reißen oder die formende Wirkung nachlässt, ersetzen wir sie. Kostenlos. Für immer.</p><p>Kein Risiko. Nur Selbstbewusstsein.</p>",
            "page": ""
          }
        }
      },
