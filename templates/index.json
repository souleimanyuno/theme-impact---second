        "liquid_b9QNnR": {
          "type": "liquid",
          "settings": {
            "liquid": "<div class=\"sv-ugc-section\">\n  <h2 class=\"sv-ugc-title\">No Photoshop. No filters.</h2>\n  <p class=\"sv-ugc-sub\">Just SkinVeil™, ten minutes later.</p>\n\n  <div class=\"sv-ugc-scroll\" id=\"svUgcScroll\">\n    <div class=\"sv-ugc-track\" id=\"svUgcTrack\">\n      <div class=\"sv-ugc-card\">\n        <video src=\"https://cdn.shopify.com/videos/c/o/v/a72001712ee7406a87f2942cdb5702d9.mp4\"\n          autoplay muted loop playsinline preload=\"metadata\"></video>\n      </div>\n      <div class=\"sv-ugc-card\">\n        <video src=\"https://cdn.shopify.com/videos/c/o/v/fc5bed58169b40c381c2f75203fc5956.mp4\"\n          autoplay muted loop playsinline preload=\"metadata\"></video>\n      </div>\n      <div class=\"sv-ugc-card\">\n        <video src=\"https://cdn.shopify.com/videos/c/o/v/8f76cfbf5796444ba3cf9b51631ab66b.mp4\"\n          autoplay muted loop playsinline preload=\"metadata\"></video>\n      </div>\n      <div class=\"sv-ugc-card\">\n        <video src=\"https://cdn.shopify.com/videos/c/o/v/3fadc61f2c0244578d6fb273ce8ef32c.mp4\"\n          autoplay muted loop playsinline preload=\"metadata\"></video>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"sv-ugc-dots\" id=\"svUgcDots\">\n    <span class=\"sv-dot active\" data-idx=\"0\"></span>\n    <span class=\"sv-dot\" data-idx=\"1\"></span>\n    <span class=\"sv-dot\" data-idx=\"2\"></span>\n    <span class=\"sv-dot\" data-idx=\"3\"></span>\n  </div>\n</div>\n\n<style>\n.sv-ugc-section {\n  padding: 32px 0 24px;\n  background: #f5ede6;\n  text-align: center;\n  overflow: hidden;\n}\n.sv-ugc-title {\n  font-family: Georgia, serif;\n  font-size: 26px;\n  font-style: italic;\n  color: #1a1a2e;\n  margin: 0 0 6px;\n  padding: 0 16px;\n  line-height: 1.3;\n}\n.sv-ugc-sub {\n  font-size: 14px;\n  color: #888;\n  margin: 0 0 20px;\n  padding: 0 16px;\n}\n.sv-ugc-scroll {\n  width: 100%;\n  overflow: hidden;\n  position: relative;\n}\n.sv-ugc-track {\n  display: flex;\n  transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n  will-change: transform;\n  gap: 12px;\n  padding: 0;\n}\n.sv-ugc-card {\n  flex: 0 0 78vw;\n  max-width: 300px;\n  border-radius: 16px;\n  overflow: hidden;\n  background: #000;\n  aspect-ratio: 9/16;\n  position: relative;\n  box-shadow: 0 8px 24px rgba(0,0,0,0.14);\n}\n.sv-ugc-card video {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  display: block;\n}\n.sv-ugc-dots {\n  display: flex;\n  justify-content: center;\n  gap: 8px;\n  margin-top: 18px;\n}\n.sv-dot {\n  width: 8px;\n  height: 8px;\n  border-radius: 50%;\n  background: #d4c4b8;\n  cursor: pointer;\n  transition: background 0.3s, transform 0.2s;\n}\n.sv-dot.active {\n  background: #c9a84c;\n  transform: scale(1.3);\n}\n@media (min-width: 768px) {\n  .sv-ugc-card {\n    flex: 0 0 calc(25% - 12px);\n    max-width: 280px;\n  }\n  .sv-ugc-title { font-size: 32px; }\n}\n</style>\n\n<script>\n(function() {\n  const track   = document.getElementById('svUgcTrack');\n  const scroll  = document.getElementById('svUgcScroll');\n  const dots    = document.querySelectorAll('.sv-dot');\n  const cards   = document.querySelectorAll('.sv-ugc-card');\n  const total   = cards.length;\n  let current   = 0;\n  let startX    = 0;\n  let isDragging = false;\n  let autoTimer;\n\n  function getCardWidth() {\n    return cards[0].offsetWidth + 12;\n  }\n\n  function getCenterOffset() {\n    const scrollWidth = scroll.offsetWidth;\n    const cardWidth   = cards[0].offsetWidth;\n    return (scrollWidth - cardWidth) / 2;\n  }\n\n  function goTo(idx) {\n    current = ((idx % total) + total) % total;\n    const offset = current * getCardWidth() - getCenterOffset();\n    track.style.transform = `translateX(${-Math.max(0, offset)}px)`;\n    dots.forEach((d, i) => d.classList.toggle('active', i === current));\n  }\n\n  function next() { goTo(current + 1); }\n\n  function startAuto() { autoTimer = setInterval(next, 3500); }\n  function stopAuto()  { clearInterval(autoTimer); }\n\n  dots.forEach(dot => {\n    dot.addEventListener('click', () => {\n      stopAuto();\n      goTo(parseInt(dot.dataset.idx));\n      startAuto();\n    });\n  });\n\n  track.addEventListener('touchstart', e => {\n    startX = e.touches[0].clientX;\n    isDragging = true;\n    stopAuto();\n  }, { passive: true });\n\n  track.addEventListener('touchend', e => {\n    if (!isDragging) return;\n    const diff = startX - e.changedTouches[0].clientX;\n    if (Math.abs(diff) > 40) {\n      diff > 0 ? next() : goTo(current - 1);\n    }\n    isDragging = false;\n    startAuto();\n  }, { passive: true });\n\n  // Init après chargement complet pour avoir les bonnes dimensions\n  function init() {\n    goTo(0);\n    startAuto();\n  }\n\n  if (document.readyState === 'complete') {\n    init();\n  } else {\n    window.addEventListener('load', init);\n  }\n})();\n</script>"
          }
        },
        "collapsible_text_7LqTqm": {
