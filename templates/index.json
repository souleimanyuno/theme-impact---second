        "remove_horizontal_spacing": true,
        "liquid": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');\n\n  .cn-rev {\n    font-family: 'Inter', sans-serif;\n    padding: 48px 0 0;\n    text-align: center;\n  }\n\n  .cn-rev__header {\n    padding: 0 20px;\n    margin-bottom: 28px;\n  }\n\n  .cn-rev__title {\n    font-size: 24px;\n    font-weight: 900;\n    color: #0d1f3c;\n    margin-bottom: 6px;\n    letter-spacing: -0.02em;\n  }\n\n  .cn-rev__trust {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    gap: 6px;\n    font-size: 13px;\n    font-weight: 600;\n    color: #444;\n  }\n\n  .cn-rev__tp-stars {\n    display: inline-flex;\n    gap: 2px;\n  }\n\n  .cn-rev__tp-star {\n    width: 20px;\n    height: 20px;\n    background: #00b67a;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    border-radius: 2px;\n  }\n\n  .cn-rev__tp-star svg {\n    width: 12px;\n    height: 12px;\n    fill: #fff;\n  }\n\n  .cn-rev__wrapper {\n    overflow: hidden;\n    width: 100%;\n    padding: 0 16px;\n    box-sizing: border-box;\n  }\n\n  .cn-rev__track {\n    display: flex;\n    transition: transform 0.42s cubic-bezier(0.25, 0.46, 0.45, 0.94);\n    will-change: transform;\n    cursor: grab;\n    align-items: stretch;\n    gap: 12px;\n  }\n\n  .cn-rev__track:active { cursor: grabbing; }\n\n  .cn-rev__card {\n    flex-shrink: 0;\n    width: 100%;\n    min-width: 100%;\n    background: #fff;\n    border: 1.5px solid #ebebeb;\n    border-radius: 16px;\n    overflow: hidden;\n    box-sizing: border-box;\n    display: flex;\n    flex-direction: column;\n  }\n\n  .cn-rev__img-wrap {\n    width: 100%;\n    aspect-ratio: 4/3;\n    overflow: hidden;\n    background: #f5f5f5;\n    flex-shrink: 0;\n  }\n\n  .cn-rev__img-wrap img {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    object-position: center;\n    display: block;\n  }\n\n  .cn-rev__body {\n    padding: 16px 18px 20px;\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n    flex: 1;\n  }\n\n  .cn-rev__stars {\n    color: #f5a623;\n    font-size: 16px;\n    letter-spacing: 2px;\n  }\n\n  .cn-rev__text {\n    font-size: 13.5px;\n    line-height: 1.65;\n    color: #222;\n    font-style: italic;\n    margin: 0;\n    flex: 1;\n  }\n\n  .cn-rev__footer {\n    border-top: 1px solid #f0f0f0;\n    padding-top: 10px;\n    display: flex;\n    flex-direction: column;\n    gap: 3px;\n  }\n\n  .cn-rev__name {\n    font-size: 13px;\n    font-weight: 800;\n    color: #0d1f3c;\n    display: flex;\n    align-items: center;\n    gap: 6px;\n  }\n\n  .cn-rev__name-verified {\n    font-size: 11px;\n    font-weight: 700;\n    color: #1a7a3f;\n    display: inline-flex;\n    align-items: center;\n    gap: 3px;\n  }\n\n  .cn-rev__name-verified svg {\n    width: 11px;\n    height: 11px;\n    stroke: #1a7a3f;\n    fill: none;\n    stroke-width: 2.5;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n\n  .cn-rev__product {\n    font-size: 11.5px;\n    color: #999;\n    display: flex;\n    align-items: center;\n    gap: 4px;\n  }\n\n  .cn-rev__dots {\n    display: flex;\n    justify-content: center;\n    gap: 6px;\n    padding: 20px 0 8px;\n  }\n\n  .cn-rev__dot {\n    width: 7px;\n    height: 7px;\n    border-radius: 50%;\n    background: #d0d0d0;\n    cursor: pointer;\n    transition: background 0.25s, transform 0.25s;\n  }\n\n  .cn-rev__dot.active {\n    background: #0d1f3c;\n    transform: scale(1.35);\n  }\n\n  @media (min-width: 640px) {\n    .cn-rev__card {\n      width: calc(50% - 6px);\n      min-width: calc(50% - 6px);\n    }\n  }\n\n  @media (min-width: 960px) {\n    .cn-rev__card {\n      width: calc(33.333% - 8px);\n      min-width: calc(33.333% - 8px);\n    }\n  }\n</style>\n\n<div class=\"cn-rev\">\n  <div class=\"cn-rev__header\">\n    <h2 class=\"cn-rev__title\">What Dog Owners Are Saying</h2>\n    <div class=\"cn-rev__trust\">\n      <div class=\"cn-rev__tp-stars\">\n        {% for i in (1..5) %}\n          <div class=\"cn-rev__tp-star\">\n            <svg viewBox=\"0 0 24 24\"><path d=\"M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z\"/></svg>\n          </div>\n        {% endfor %}\n      </div>\n      <span>4.8 · 8,000+ Verified Reviews</span>\n    </div>\n  </div>\n\n  <div class=\"cn-rev__wrapper\">\n    <div class=\"cn-rev__track\" id=\"cnRevTrack\">\n\n      <div class=\"cn-rev__card\">\n        <div class=\"cn-rev__img-wrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/review-9_1_430x.jpg?v=1782589094\" alt=\"Review\" loading=\"lazy\">\n        </div>\n        <div class=\"cn-rev__body\">\n          <div class=\"cn-rev__stars\">★★★★★</div>\n          <p class=\"cn-rev__text\">\"Put this in my lab's crate for the summer and honestly it was the best call. She used to pace and whine when it got hot — now she goes straight in and just settles. No gel, nothing to worry about. Zero mess.\"</p>\n          <div class=\"cn-rev__footer\">\n            <span class=\"cn-rev__name\">Sarah M. <span class=\"cn-rev__name-verified\"><svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg>Verified</span></span>\n            <span class=\"cn-rev__product\">🐾 ChillNest Classic · Size M</span>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"cn-rev__card\">\n        <div class=\"cn-rev__img-wrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/review-8_1_430x.jpg?v=1782589094\" alt=\"Review\" loading=\"lazy\">\n        </div>\n        <div class=\"cn-rev__body\">\n          <div class=\"cn-rev__stars\">★★★★★</div>\n          <p class=\"cn-rev__text\">\"My boy has zero interest in his regular bed once it gets above 80°F. He literally walked past his $150 orthopedic bed to lay on this. I don't know what to say except it works and he hasn't gone back.\"</p>\n          <div class=\"cn-rev__footer\">\n            <span class=\"cn-rev__name\">Derek T. <span class=\"cn-rev__name-verified\"><svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg>Verified</span></span>\n            <span class=\"cn-rev__product\">🐾 ChillNest Classic · Size L</span>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"cn-rev__card\">\n        <div class=\"cn-rev__img-wrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/review-7_1_430x.jpg?v=1782589094\" alt=\"Review\" loading=\"lazy\">\n        </div>\n        <div class=\"cn-rev__body\">\n          <div class=\"cn-rev__stars\">★★★★★</div>\n          <p class=\"cn-rev__text\">\"My chocolate lab has the darkest coat and she struggles so much in summer. I put the ChillNest on the patio so she can still be outside with me. She went from panting constantly to just lying there calm. Game changer.\"</p>\n          <div class=\"cn-rev__footer\">\n            <span class=\"cn-rev__name\">Melissa K. <span class=\"cn-rev__name-verified\"><svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg>Verified</span></span>\n            <span class=\"cn-rev__product\">🐾 ChillNest Classic · Size L</span>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"cn-rev__card\">\n        <div class=\"cn-rev__img-wrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/review-6_1_430x.jpg?v=1782589094\" alt=\"Review\" loading=\"lazy\">\n        </div>\n        <div class=\"cn-rev__body\">\n          <div class=\"cn-rev__stars\">★★★★★</div>\n          <p class=\"cn-rev__text\">\"We have two dogs and bought one mat to start. The little one claimed it the second it hit the floor. My other dog has been giving me the side-eye ever since. Already ordering a second one. The one using it stopped hunting for the cold bathroom floor.\"</p>\n          <div class=\"cn-rev__footer\">\n            <span class=\"cn-rev__name\">Jamie R. <span class=\"cn-rev__name-verified\"><svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg>Verified</span></span>\n            <span class=\"cn-rev__product\">🐾 ChillNest Classic · Size M</span>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"cn-rev__card\">\n        <div class=\"cn-rev__img-wrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/review-4_2_430x.jpg?v=1782589094\" alt=\"Review\" loading=\"lazy\">\n        </div>\n        <div class=\"cn-rev__body\">\n          <div class=\"cn-rev__stars\">★★★★★</div>\n          <p class=\"cn-rev__text\">\"Ordered this to lay flat inside his existing dog bed — fits perfectly without any adjustments. No water, no freezing, no plugging anything in. He wasn't sure at first but now he chooses it every single time.\"</p>\n          <div class=\"cn-rev__footer\">\n            <span class=\"cn-rev__name\">Tom B. <span class=\"cn-rev__name-verified\"><svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg>Verified</span></span>\n            <span class=\"cn-rev__product\">🐾 ChillNest Classic · Size L</span>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"cn-rev__card\">\n        <div class=\"cn-rev__img-wrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/review-15_1_430x.jpg?v=1782589093\" alt=\"Review\" loading=\"lazy\">\n        </div>\n        <div class=\"cn-rev__body\">\n          <div class=\"cn-rev__stars\">★★★★★</div>\n          <p class=\"cn-rev__text\">\"My boy is 11 and all black — I'm always worried about him overheating. He basically lives on this mat from June through September now. He doesn't pant at night anymore. I actually sleep. For a senior dog this has been everything.\"</p>\n          <div class=\"cn-rev__footer\">\n            <span class=\"cn-rev__name\">Linda W. <span class=\"cn-rev__name-verified\"><svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg>Verified</span></span>\n            <span class=\"cn-rev__product\">🐾 ChillNest Classic · Size XL</span>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"cn-rev__card\">\n        <div class=\"cn-rev__img-wrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/review-14_1_430x.jpg?v=1782589093\" alt=\"Review\" loading=\"lazy\">\n        </div>\n        <div class=\"cn-rev__body\">\n          <div class=\"cn-rev__stars\">★★★★★</div>\n          <p class=\"cn-rev__text\">\"Bought for my husky — he's basically a walking furnace. But my little guy claimed half of it too. They both squeeze on and neither one is panting anymore. First summer in two years I haven't had to run the AC all night.\"</p>\n          <div class=\"cn-rev__footer\">\n            <span class=\"cn-rev__name\">Chris P. <span class=\"cn-rev__name-verified\"><svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg>Verified</span></span>\n            <span class=\"cn-rev__product\">🐾 ChillNest Classic · Size XL</span>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"cn-rev__card\">\n        <div class=\"cn-rev__img-wrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/review-13_1_430x.jpg?v=1782589094\" alt=\"Review\" loading=\"lazy\">\n        </div>\n        <div class=\"cn-rev__body\">\n          <div class=\"cn-rev__stars\">★★★★★</div>\n          <p class=\"cn-rev__text\">\"My schnauzer is dramatic about heat. The second it warms up she just stops moving and gives me a look. Put this down next to her toys and she found it within 3 minutes. She's been on it ever since. 10/10.\"</p>\n          <div class=\"cn-rev__footer\">\n            <span class=\"cn-rev__name\">Amy S. <span class=\"cn-rev__name-verified\"><svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg>Verified</span></span>\n            <span class=\"cn-rev__product\">🐾 ChillNest Classic · Size M</span>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"cn-rev__card\">\n        <div class=\"cn-rev__img-wrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/review-12_1_430x.jpg?v=1782589093\" alt=\"Review\" loading=\"lazy\">\n        </div>\n        <div class=\"cn-rev__body\">\n          <div class=\"cn-rev__stars\">★★★★★</div>\n          <p class=\"cn-rev__text\">\"Huskies and summer are not a great combo. I tried frozen kongs, ice water, fans — he still struggled during the day. This mat he actually uses on his own without me having to bribe him. And it genuinely stays cool even after hours.\"</p>\n          <div class=\"cn-rev__footer\">\n            <span class=\"cn-rev__name\">Ryan H. <span class=\"cn-rev__name-verified\"><svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg>Verified</span></span>\n            <span class=\"cn-rev__product\">🐾 ChillNest Classic · Size L</span>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"cn-rev__card\">\n        <div class=\"cn-rev__img-wrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/cool-dog-81vxsvlrr-l_430x.jpg?v=1782589094\" alt=\"Review\" loading=\"lazy\">\n        </div>\n        <div class=\"cn-rev__body\">\n          <div class=\"cn-rev__stars\">★★★★★</div>\n          <p class=\"cn-rev__text\">\"Went with the Shell shape because I wanted something that looked good in the apartment — and it honestly does. My dog has really thick fur and was really struggling this summer. Chose it over his regular bed within 5 minutes.\"</p>\n          <div class=\"cn-rev__footer\">\n            <span class=\"cn-rev__name\">Priya N. <span class=\"cn-rev__name-verified\"><svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg>Verified</span></span>\n            <span class=\"cn-rev__product\">🐾 ChillNest Shell · Size L</span>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"cn-rev__card\">\n        <div class=\"cn-rev__img-wrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/cool-dog-81at8n8cokl_430x.jpg?v=1782589094\" alt=\"Review\" loading=\"lazy\">\n        </div>\n        <div class=\"cn-rev__body\">\n          <div class=\"cn-rev__stars\">★★★★★</div>\n          <p class=\"cn-rev__text\">\"I was skeptical — tried two other cooling mats that did absolutely nothing. This one is different. My pup ran straight to it, flopped down, and didn't move for two hours. It actually stays cool to the touch. Nothing else I tried came close.\"</p>\n          <div class=\"cn-rev__footer\">\n            <span class=\"cn-rev__name\">Kayla M. <span class=\"cn-rev__name-verified\"><svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg>Verified</span></span>\n            <span class=\"cn-rev__product\">🐾 ChillNest Shell · Size M</span>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"cn-rev__card\">\n        <div class=\"cn-rev__img-wrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/cool-dog-817wtnonyjl_430x.jpg?v=1782589094\" alt=\"Review\" loading=\"lazy\">\n        </div>\n        <div class=\"cn-rev__body\">\n          <div class=\"cn-rev__stars\">★★★★★</div>\n          <p class=\"cn-rev__text\">\"Got the Leaf in sage green and it looks so cute. My little guy usually camps next to the AC vent all day — since putting this down he's on it instead. Saves me from running the AC constantly. He's completely knocked out on it right now.\"</p>\n          <div class=\"cn-rev__footer\">\n            <span class=\"cn-rev__name\">Brittany C. <span class=\"cn-rev__name-verified\"><svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg>Verified</span></span>\n            <span class=\"cn-rev__product\">🐾 ChillNest Leaf · Size S</span>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"cn-rev__card\">\n        <div class=\"cn-rev__img-wrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/cool-dog-816sp57fp2l_430x.jpg?v=1782589094\" alt=\"Review\" loading=\"lazy\">\n        </div>\n        <div class=\"cn-rev__body\">\n          <div class=\"cn-rev__stars\">★★★★★</div>\n          <p class=\"cn-rev__text\">\"My rescue Luna chews literally everything — I was nervous. She's never once tried to mess with this mat. I think because she values it too much lol. She runs straight to it after every walk. It's fully become her spot.\"</p>\n          <div class=\"cn-rev__footer\">\n            <span class=\"cn-rev__name\">Maria G. <span class=\"cn-rev__name-verified\"><svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg>Verified</span></span>\n            <span class=\"cn-rev__product\">🐾 ChillNest Leaf · Size L</span>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"cn-rev__card\">\n        <div class=\"cn-rev__img-wrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/review-11_1_430x.jpg?v=1782589094\" alt=\"Review\" loading=\"lazy\">\n        </div>\n        <div class=\"cn-rev__body\">\n          <div class=\"cn-rev__stars\">★★★★★</div>\n          <p class=\"cn-rev__text\">\"Two standard poodles sharing one mat — and they both want to be on it. I put it on the bed and they take turns. Their thick coats make summer rough. No more panting at 2am keeping me awake. Best thing I've bought for them in years.\"</p>\n          <div class=\"cn-rev__footer\">\n            <span class=\"cn-rev__name\">Catherine L. <span class=\"cn-rev__name-verified\"><svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg>Verified</span></span>\n            <span class=\"cn-rev__product\">🐾 ChillNest Classic · Size XL</span>\n          </div>\n        </div>\n      </div>\n\n    </div>\n  </div>\n\n  <div class=\"cn-rev__dots\" id=\"cnRevDots\"></div>\n</div>\n\n<script>\n(function() {\n  var track = document.getElementById('cnRevTrack');\n  var dotsWrap = document.getElementById('cnRevDots');\n  var cards = track.querySelectorAll('.cn-rev__card');\n  var total = cards.length;\n  var current = 0;\n  var startX = 0;\n  var isDragging = false;\n  var autoTimer;\n\n  function perView() {\n    if (window.innerWidth >= 960) return 3;\n    if (window.innerWidth >= 640) return 2;\n    return 1;\n  }\n\n  function maxIdx() { return total - perView(); }\n\n  function getCardW() {\n    return cards[0].offsetWidth + 12;\n  }\n\n  function buildDots() {\n    dotsWrap.innerHTML = '';\n    var count = maxIdx() + 1;\n    for (var i = 0; i < count; i++) {\n      var d = document.createElement('div');\n      d.className = 'cn-rev__dot' + (i === 0 ? ' active' : '');\n      (function(idx){ d.addEventListener('click', function(){ goTo(idx); }); })(i);\n      dotsWrap.appendChild(d);\n    }\n  }\n\n  function updateDots() {\n    dotsWrap.querySelectorAll('.cn-rev__dot').forEach(function(d, i){\n      d.classList.toggle('active', i === current);\n    });\n  }\n\n  function goTo(idx) {\n    var max = maxIdx();\n    current = ((idx % (max + 1)) + (max + 1)) % (max + 1);\n    track.style.transform = 'translateX(-' + (getCardW() * current) + 'px)';\n    updateDots();\n  }\n\n  function next() { goTo(current + 1); }\n\n  function startAuto() {\n    clearInterval(autoTimer);\n    autoTimer = setInterval(next, 4000);\n  }\n\n  track.addEventListener('touchstart', function(e) {\n    startX = e.touches[0].clientX;\n    clearInterval(autoTimer);\n  }, { passive: true });\n\n  track.addEventListener('touchend', function(e) {\n    var diff = startX - e.changedTouches[0].clientX;\n    if (Math.abs(diff) > 40) diff > 0 ? next() : goTo(current - 1);\n    startAuto();\n  }, { passive: true });\n\n  track.addEventListener('mousedown', function(e) {\n    isDragging = true;\n    startX = e.clientX;\n    clearInterval(autoTimer);\n  });\n\n  window.addEventListener('mouseup', function(e) {\n    if (!isDragging) return;\n    isDragging = false;\n    var diff = startX - e.clientX;\n    if (Math.abs(diff) > 40) diff > 0 ? next() : goTo(current - 1);\n    startAuto();\n  });\n\n  window.addEventListener('resize', function() {\n    buildDots();\n    goTo(current > maxIdx() ? maxIdx() : current);\n  });\n\n  buildDots();\n  goTo(0);\n  startAuto();\n})();\n</script>",
