      "settings": {
        "full_width": true,
        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": true,
        "liquid": "{% comment %}\n  SORELYA LipVeil — Before/After Carousel\n  Version plus grande et plus compacte\n  Mobile-first · scroll-snap centre · swipe natif\n{% endcomment %}\n\n<section\n  id=\"sorelya-ba-{{ section.id }}\"\n  class=\"ba-section\"\n>\n  <div class=\"ba-header\">\n    <p class=\"ba-eyebrow\">Real Results</p>\n    <h2 class=\"ba-title\">See the Difference</h2>\n  </div>\n\n  <div class=\"ba-carousel\" data-ba-carousel>\n\n    <article class=\"ba-slide\">\n      <div class=\"ba-imgwrap\">\n        <img\n          src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/avant_apres_1_430x.png?v=1784596454\"\n          alt=\"Before and after: Hydration and Comfort\"\n          loading=\"lazy\"\n          width=\"430\"\n          height=\"430\"\n        >\n      </div>\n\n      <p class=\"ba-caption\">Hydration &amp; Comfort</p>\n    </article>\n\n    <article class=\"ba-slide\">\n      <div class=\"ba-imgwrap\">\n        <img\n          src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/avant_apres_2_430x.png?v=1784596469\"\n          alt=\"Before and after: Keep Color Out of Lip Lines\"\n          loading=\"lazy\"\n          width=\"430\"\n          height=\"430\"\n        >\n      </div>\n\n      <p class=\"ba-caption\">Keep Color Out of Lip Lines</p>\n    </article>\n\n    <article class=\"ba-slide\">\n      <div class=\"ba-imgwrap\">\n        <img\n          src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/avant_apres_3_430x.png?v=1784596469\"\n          alt=\"Before and after: Stop Guessing Your Shade\"\n          loading=\"lazy\"\n          width=\"430\"\n          height=\"430\"\n        >\n      </div>\n\n      <p class=\"ba-caption\">Stop Guessing Your Shade</p>\n    </article>\n\n    <article class=\"ba-slide\">\n      <div class=\"ba-imgwrap\">\n        <img\n          src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/avant_apres_4_430x.png?v=1784596470\"\n          alt=\"Before and after: Made for Mature Lips\"\n          loading=\"lazy\"\n          width=\"430\"\n          height=\"430\"\n        >\n      </div>\n\n      <p class=\"ba-caption\">Made for Mature Lips</p>\n    </article>\n\n  </div>\n\n  <div class=\"ba-dots\" data-ba-dots>\n    <button\n      type=\"button\"\n      class=\"ba-dot ba-dot--active\"\n      data-idx=\"0\"\n      aria-label=\"Show slide 1\"\n    ></button>\n\n    <button\n      type=\"button\"\n      class=\"ba-dot\"\n      data-idx=\"1\"\n      aria-label=\"Show slide 2\"\n    ></button>\n\n    <button\n      type=\"button\"\n      class=\"ba-dot\"\n      data-idx=\"2\"\n      aria-label=\"Show slide 3\"\n    ></button>\n\n    <button\n      type=\"button\"\n      class=\"ba-dot\"\n      data-idx=\"3\"\n      aria-label=\"Show slide 4\"\n    ></button>\n  </div>\n</section>\n\n<style>\n  #sorelya-ba-{{ section.id }} {\n    --ba-accent: #B88C66;\n    --ba-card-width: 82%;\n\n    width: 100%;\n    overflow: hidden;\n    box-sizing: border-box;\n    background: #ffffff;\n    padding: 24px 0 20px;\n\n    font-family:\n      -apple-system,\n      BlinkMacSystemFont,\n      \"Helvetica Neue\",\n      Arial,\n      sans-serif;\n  }\n\n  #sorelya-ba-{{ section.id }} *,\n  #sorelya-ba-{{ section.id }} *::before,\n  #sorelya-ba-{{ section.id }} *::after {\n    box-sizing: border-box;\n  }\n\n  #sorelya-ba-{{ section.id }} .ba-header {\n    padding: 0 16px 22px;\n    text-align: center;\n  }\n\n  #sorelya-ba-{{ section.id }} .ba-eyebrow {\n    margin: 0 0 7px;\n    color: var(--ba-accent);\n    font-size: 11px;\n    font-weight: 700;\n    line-height: 1.2;\n    letter-spacing: 0.16em;\n    text-transform: uppercase;\n  }\n\n  #sorelya-ba-{{ section.id }} .ba-title {\n    margin: 0;\n    color: #111111;\n\n    font-family: \"Playfair Display\", Georgia, serif;\n    font-size: clamp(27px, 7vw, 36px);\n    font-weight: 500;\n    line-height: 1.08;\n    letter-spacing: -0.02em;\n  }\n\n  #sorelya-ba-{{ section.id }} .ba-carousel {\n    display: flex;\n    gap: 14px;\n\n    width: 100%;\n    padding: 4px 7%;\n    overflow-x: auto;\n    overflow-y: hidden;\n\n    scroll-padding-inline: 7%;\n    scroll-snap-type: x mandatory;\n    scrollbar-width: none;\n    overscroll-behavior-x: contain;\n    -webkit-overflow-scrolling: touch;\n  }\n\n  #sorelya-ba-{{ section.id }} .ba-carousel::-webkit-scrollbar {\n    display: none;\n  }\n\n  #sorelya-ba-{{ section.id }} .ba-slide {\n    flex: 0 0 var(--ba-card-width);\n    min-width: 0;\n\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n\n    scroll-snap-align: center;\n    scroll-snap-stop: always;\n  }\n\n  #sorelya-ba-{{ section.id }} .ba-imgwrap {\n    width: 100%;\n    aspect-ratio: 1 / 1;\n    overflow: hidden;\n\n    background: #f5f5f5;\n    border-radius: 14px;\n  }\n\n  #sorelya-ba-{{ section.id }} .ba-imgwrap img {\n    display: block;\n    width: 100%;\n    height: 100%;\n\n    object-fit: cover;\n    object-position: center;\n  }\n\n  #sorelya-ba-{{ section.id }} .ba-caption {\n    margin: 11px 0 0;\n    padding: 0 3px;\n\n    color: #111111;\n    font-size: 14px;\n    font-weight: 650;\n    line-height: 1.25;\n    letter-spacing: 0.01em;\n    text-align: center;\n  }\n\n  #sorelya-ba-{{ section.id }} .ba-dots {\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    gap: 8px;\n\n    margin-top: 16px;\n    padding: 0 20px;\n  }\n\n  #sorelya-ba-{{ section.id }} .ba-dot {\n    width: 8px;\n    height: 8px;\n    padding: 0;\n\n    border: 0;\n    border-radius: 50%;\n    background: #DDD5CD;\n    cursor: pointer;\n\n    transition:\n      background-color 0.2s ease,\n      transform 0.2s ease;\n  }\n\n  #sorelya-ba-{{ section.id }} .ba-dot--active {\n    background: var(--ba-accent);\n    transform: scale(1.25);\n  }\n\n  @media (min-width: 750px) {\n    #sorelya-ba-{{ section.id }} {\n      --ba-card-width: 62%;\n\n      padding: 38px 0 30px;\n    }\n\n    #sorelya-ba-{{ section.id }} .ba-header {\n      padding-bottom: 28px;\n    }\n\n    #sorelya-ba-{{ section.id }} .ba-carousel {\n      gap: 18px;\n      padding-inline: 18%;\n      scroll-padding-inline: 18%;\n    }\n\n    #sorelya-ba-{{ section.id }} .ba-caption {\n      margin-top: 13px;\n      font-size: 15px;\n    }\n\n    #sorelya-ba-{{ section.id }} .ba-dots {\n      margin-top: 18px;\n    }\n  }\n\n  @media (min-width: 1100px) {\n    #sorelya-ba-{{ section.id }} {\n      --ba-card-width: 48%;\n    }\n\n    #sorelya-ba-{{ section.id }} .ba-carousel {\n      padding-inline: 26%;\n      scroll-padding-inline: 26%;\n    }\n  }\n\n  @media (prefers-reduced-motion: reduce) {\n    #sorelya-ba-{{ section.id }} .ba-carousel {\n      scroll-behavior: auto;\n    }\n\n    #sorelya-ba-{{ section.id }} .ba-dot {\n      transition: none;\n    }\n  }\n</style>\n\n<script>\n  (function () {\n    var root = document.getElementById('sorelya-ba-{{ section.id }}');\n    if (!root) return;\n\n    var carousel = root.querySelector('[data-ba-carousel]');\n    var slides = Array.prototype.slice.call(\n      root.querySelectorAll('.ba-slide')\n    );\n    var dots = Array.prototype.slice.call(\n      root.querySelectorAll('[data-ba-dots] .ba-dot')\n    );\n\n    if (!carousel || !slides.length || !dots.length) return;\n\n    var frame;\n\n    function setActive(index) {\n      dots.forEach(function (dot, dotIndex) {\n        var active = dotIndex === index;\n\n        dot.classList.toggle('ba-dot--active', active);\n        dot.setAttribute('aria-current', active ? 'true' : 'false');\n      });\n    }\n\n    function updateActive() {\n      var carouselRect = carousel.getBoundingClientRect();\n      var carouselCenter =\n        carouselRect.left + carouselRect.width / 2;\n\n      var activeIndex = 0;\n      var shortestDistance = Infinity;\n\n      slides.forEach(function (slide, index) {\n        var slideRect = slide.getBoundingClientRect();\n        var slideCenter = slideRect.left + slideRect.width / 2;\n        var distance = Math.abs(slideCenter - carouselCenter);\n\n        if (distance < shortestDistance) {\n          shortestDistance = distance;\n          activeIndex = index;\n        }\n      });\n\n      setActive(activeIndex);\n    }\n\n    function centerSlide(index) {\n      var slide = slides[index];\n      if (!slide) return;\n\n      var targetLeft =\n        slide.offsetLeft -\n        (carousel.clientWidth - slide.clientWidth) / 2;\n\n      carousel.scrollTo({\n        left: targetLeft,\n        behavior: window.matchMedia(\n          '(prefers-reduced-motion: reduce)'\n        ).matches ? 'auto' : 'smooth'\n      });\n    }\n\n    carousel.addEventListener(\n      'scroll',\n      function () {\n        window.cancelAnimationFrame(frame);\n        frame = window.requestAnimationFrame(updateActive);\n      },\n      { passive: true }\n    );\n\n    dots.forEach(function (dot) {\n      dot.addEventListener('click', function () {\n        var index = parseInt(dot.getAttribute('data-idx'), 10);\n\n        setActive(index);\n        centerSlide(index);\n      });\n    });\n\n    window.addEventListener('resize', function () {\n      window.cancelAnimationFrame(frame);\n      frame = window.requestAnimationFrame(updateActive);\n    });\n\n    updateActive();\n  })();\n</script>",
