n  letter-spacing: 0.8px;\n  color: #c9a84c;\n  font-weight: 600;\n  margin-bottom: 2px;\n}\n.sf-shade-info strong { display: block; font-size: 16px; color: #1a1a2e; margin-bottom: 2px; }\n.sf-shade-info span { font-size: 12px; color: #999; }\n.sf-why-box {\n  background: #fffaf4;\n  border-radius: 12px;\n  padding: 14px 16px;\n  margin: 14px 0;\n  font-size: 13px;\n  color: #5a4030;\n  line-height: 1.6;\n}\n.sf-why-box strong {\n  display: block;\n  font-size: 11px;\n  text-transform: uppercase;\n  letter-spacing: 0.8px;\n  color: #c9a84c;\n  margin-bottom: 6px;\n}\n.sf-cta-btn {\n  width: 100%;\n  background: linear-gradient(135deg, #c9a84c, #e8c98a);\n  color: #fff;\n  border: none;\n  border-radius: 12px;\n  padding: 16px;\n  font-size: 16px;\n  font-weight: 700;\n  cursor: pointer;\n  margin-bottom: 8px;\n  transition: opacity 0.2s;\n}\n.sf-cta-btn:hover { opacity: 0.9; }\n.sf-cta-sub { text-align: center; font-size: 12px; color: #aaa; margin-bottom: 16px; }\n.sf-trust-row {\n  display: grid;\n  grid-template-columns: repeat(4, 1fr);\n  gap: 8px;\n  border-top: 1px solid #f0e8e0;\n  padding-top: 16px;\n  margin-top: 4px;\n}\n.sf-trust-item { text-align: center; }\n.sf-trust-item em {\n  display: block;\n  font-family: Georgia, serif;\n  font-size: 15px;\n  font-style: italic;\n  color: #c9a84c;\n  margin-bottom: 2px;\n}\n.sf-trust-item span { font-size: 10px; color: #aaa; line-height: 1.3; }\n.sf-restart {\n  display: block;\n  text-align: center;\n  font-size: 13px;\n  color: #aaa;\n  cursor: pointer;\n  margin-top: 16px;\n  text-decoration: underline;\n}\n</style>\n\n<script>\n(function() {\n  const SHADES = [\n    { id: 'pm', name: 'Porcelain Mist',  hex: '#f5e6d8', desc: 'For very fair, cool-toned skin',   sun: [0,1],    vein: [0,2,3] },\n    { id: 'ig', name: 'Ivory Glow',      hex: '#ebd5b8', desc: 'For fair to light skin',            sun: [0,1],    vein: [0,1,2,3] },\n    { id: 'ws', name: 'Warm Sand',       hex: '#d4a97a', desc: 'For light to medium warm skin',     sun: [1,2],    vein: [1,2,3] },\n    { id: 'bh', name: 'Bare Honey',      hex: '#c08a50', desc: 'For medium to olive skin',          sun: [1,2],    vein: [1,2] },\n    { id: 'gd', name: 'Golden Dusk',     hex: '#9a6535', desc: 'For medium-deep warm skin',         sun: [2,3],    vein: [1,2] },\n    { id: 'cs', name: 'Cocoa Silk',      hex: '#5c3418', desc: 'For deep to rich dark skin',        sun: [2,3],    vein: [0,1,2,3] }\n  ];\n\n  let answers = { skin: null, vein: null, sun: null, usage: null };\n  let step = 1;\n\n  const trigger  = document.getElementById('sfTrigger');\n  const overlay  = document.getElementById('sfOverlay');\n  const body     = document.getElementById('sfBody');\n  const fill     = document.getElementById('sfProgressFill');\n  const backBtn  = document.getElementById('sfBack');\n  const closeBtn = document.getElementById('sfClose');\n\n  trigger.addEventListener('click', () => { step=1; open(); });\n  closeBtn.addEventListener('click', close);\n  overlay.addEventListener('click', e => { if(e.target===overlay) close(); });\n  backBtn.addEventListener('click', () => { step = Math.max(1, step-1); render(); });\n\n  function open()  { overlay.classList.add('open'); render(); }\n  function close() { overlay.classList.remove('open'); }\n\n  function setProgress(s, total) {\n    fill.style.width = ((s-1)/total*100) + '%';\n    backBtn.style.visibility = s > 1 ? 'visible' : 'hidden';\n  }\n\n  function computeResult() {\n    const scores = SHADES.map((sh, idx) => {\n      let score = 0;\n      if (answers.skin !== null) score += Math.max(0, 10 - Math.abs(idx - answers.skin) * 3);\n      if (answers.vein !== null && sh.vein.includes(answers.vein)) score += 4;\n      if (answers.sun !== null  && sh.sun.includes(answers.sun))  score += 4;\n      return { sh, idx, score };\n    });\n    scores.sort((a,b) => b.score - a.score);\n    const primary   = scores[0].sh;\n    const secIdx    = Math.min(scores[0].idx + 1, SHADES.length - 1);\n    const secondary = SHADES[secIdx];\n    const pct       = Math.round(88 + Math.random() * 9);\n    return { primary, secondary, pct };\n  }\n\n  function render() {\n    if      (step === 1) renderQ1();\n    else if (step === 2) renderQ2();\n    else if (step === 3) renderQ3();\n    else if (step === 4) renderQ4();\n    else                 renderResult();\n    body.scrollTop = 0;\n  }\n\n  function renderQ1() {\n    setProgress(1, 4);\n    const imgs = [\n      'https://cdn.shopify.com/s/files/1/0992/0384/2370/files/bzf-skin-1-porcellana_430x.jpg?v=1780980552',\n      'https://cdn.shopify.com/s/files/1/0992/0384/2370/files/bzf-skin-2-avorio_430x.jpg?v=1780980552',\n      'https://cdn.shopify.com/s/files/1/0992/0384/2370/files/bzf-skin-3-beige_430x.jpg?v=1780980552',\n      'https://cdn.shopify.com/s/files/1/0992/0384/2370/files/bzf-skin-4-dorata_430x.jpg?v=1780980552',\n      'https://cdn.shopify.com/s/files/1/0992/0384/2370/files/bzf-skin-5-caramello_430x.jpg?v=1780980552',\n      'https://cdn.shopify.com/s/files/1/0992/0384/2370/files/bzf-skin-6-olivastra_430x.jpg?v=1780980627'\n    ];\n    const labels = [\n      ['Porcelain','Very fair'],['Ivory','Fair'],['Beige','Light medium'],\n      ['Golden','Mediterranean'],['Caramel','Deep bronze'],['Olive','Dark natural']\n    ];\n    body.innerHTML = `\n      <p class=\"sf-step-label\">QUESTION 1 OF 4</p>\n      <h2 class=\"sf-step-title\">Your skin right now.</h2>\n      <p class=\"sf-step-sub\">Tap the photo closest to your skin today · without any tan.</p>\n      <div class=\"sf-grid-3\">\n        ${imgs.map((img,i) => `\n          <div class=\"sf-option${answers.skin===i?' selected':''}\" data-idx=\"${i}\">\n            <img src=\"${img}\" alt=\"${labels[i][0]}\" loading=\"lazy\">\n            <div class=\"sf-option-label\">\n              <strong>${labels[i][0]}</strong>\n              <span>${labels[i][1]}</span>\n            </div>\n          </div>`).join('')}\n      </div>`;\n    body.querySelectorAll('.sf-option').forEach(el => {\n      el.addEventListener('click', () => { answers.skin = parseInt(el.dataset.idx); step=2; render(); });\n    });\n  }\n\n  function renderQ2() {\n    setProgress(2, 4);\n    const imgs = [\n      'https://cdn.shopify.com/s/files/1/0992/0384/2370/files/bzf-veins-wrist_blue_430x.jpg?v=1780980707',\n      'https://cdn.shopify.com/s/files/1/0992/0384/2370/files/bzf-veins-wrist_green_430x.jpg?v=1780980707',\n      'https://cdn.shopify.com/s/files/1/0992/0384/2370/files/bzf-veins-wrist_mixed_430x.jpg?v=1780980707',\n      'https://cdn.shopify.com/s/files/1/0992/0384/2370/files/bzf-veins-wrist_faint_430x.jpg?v=1780980707'\n    ];\n    const labels = [\n      ['Blue or purple','Cool undertone'],['Green','Warm undertone'],\n      ['Mix of both','Neutral undertone'],['Hard to tell','Neutral undertone']\n    ];\n    body.innerHTML = `\n      <p class=\"sf-step-label\">QUESTION 2 OF 4</p>\n      <h2 class=\"sf-step-title\">Look at your wrist veins.</h2>\n      <p class=\"sf-step-sub\">Inner wrist, palm up, in natural window light. What colour do you mainly see?</p>\n      <div class=\"sf-grid-2\">\n        ${imgs.map((img,i) => `\n          <div class=\"sf-option${answers.vein===i?' selected':''}\" data-idx=\"${i}\">\n            <img src=\"${img}\" alt=\"${labels[i][0]}\" loading=\"lazy\">\n            <div class=\"sf-option-label\">\n              <strong>${labels[i][0]}</strong>\n              <span>${labels[i][1]}</span>\n            </div>\n          </div>`).join('')}\n      </div>`;\n    body.querySelectorAll('.sf-option').forEach(el => {\n      el.addEventListener('click', () => { answers.vein = parseInt(el.dataset.idx); step=3; render(); });\n    });\n  }\n\n  function renderQ3() {\n    setProgress(3, 4);\n    const imgs = [\n      'https://cdn.shopify.com/s/files/1/0992/0384/2370/files/bzf-sun-0-burn_430x.jpg?v=1780980761',\n      'https://cdn.shopify.com/s/files/1/0992/0384/2370/files/bzf-sun-1-light-tan_430x.jpg?v=1780980761',\n      'https://cdn.shopify.com/s/files/1/0992/0384/2370/files/bzf-sun-2-easy-tan_430x.jpg?v=1780980761',\n      'https://cdn.shopify.com/s/files/1/0992/0384/2370/files/bzf-sun-3-deep-tan_430x.jpg?v=1780980761'\n    ];\n    const labels = [\n      ['I burn easily','Redness, no colour'],['Burn then tan','Light golden colour'],\n      ['Tan easily','Rarely burn'],['Tan straight away','Fast and deep']\n    ];\n    body.innerHTML = `\n      <p class=\"sf-step-label\">QUESTION 3 OF 4</p>\n      <h2 class=\"sf-step-title\">When you're in the sun, what happens?</h2>\n      <p class=\"sf-step-sub\">Think about a summer weekend at the beach · no high SPF.</p>\n      <div class=\"sf-grid-2\">\n        ${imgs.map((img,i) => `\n          <div class=\"sf-option${answers.sun===i?' selected':''}\" data-idx=\"${i}\">\n            <img src=\"${img}\" alt=\"${labels[i][0]}\" loading=\"lazy\">\n            <div class=\"sf-option-label\">\n              <strong>${labels[i][0]}</strong>\n              <span>${labels[i][1]}</span>\n            </div>\n          </div>`).join('')}\n      </div>`;\n    body.querySelectorAll('.sf-option').forEach(el => {\n      el.addEventListener('click', () => { answers.sun = parseInt(el.dataset.idx); step=4; render(); });\n    });\n  }\n\n  function renderQ4() {\n    setProgress(4, 4);\n    body.innerHTML = `\n      <p class=\"sf-step-label\">QUESTION 4 OF 4</p>\n      <h2 class=\"sf-step-title\">When will you wear it?</h2>\n      <p class=\"sf-step-sub\">This helps us recommend one shade or a duo for all seasons.</p>\n      <div class=\"sf-text-option featured\" data-val=\"both\">\n        <span class=\"sf-featured-badge\">BEST VALUE</span>\n        <strong>Every day + special occasions</strong>\n        <p>One shade for daily life · one for when you want that just-back-from-holiday glow.</p>\n        <div class=\"sf-bonus\">+ Kabuki Brush included free</div>\n      </div>\n      <div class=\"sf-text-option\" data-val=\"daily\">\n        <strong>Every day</strong>\n        <p>One shade · for work, gym, errands and weekends.</p>\n      </div>\n      <div class=\"sf-text-option\" data-val=\"occasions\">\n        <strong>Special occasions only</strong>\n        <p>Weddings · holidays · nights out — when you need to be there.</p>\n      </div>`;\n    body.querySelectorAll('.sf-text-option').forEach(el => {\n      el.addEventListener('click', () => { answers.usage = el.dataset.val; step=5; render(); });\n    });\n  }\n\n  function renderResult() {\n    setProgress(5, 4);\n    fill.style.width = '100%';\n    const { primary, secondary, pct } = computeResult();\n    const showDuo   = answers.usage === 'both' || answers.usage === 'occasions';\n    const resultTitle = showDuo ? `${primary.name} + ${secondary.name}` : primary.name;\n    const whyText = showDuo\n      ? `One shade for your everyday skin. One shade warmer for when you want a sun-kissed glow. Same formula, same hold. Flawless skin all year round.`\n      : `The closest match to your natural skin tone. Apply in 10 minutes for an even, natural finish that lasts 48 hours through sweat, water and everything in between.`;\n\n    body.innerHTML = `\n      <h2 class=\"sf-result-title\">${resultTitle}</h2>\n      <p class=\"sf-result-sub\">Your shade is ready · ${pct}% match</p>\n      <div class=\"sf-shade-card primary\">\n        <div class=\"sf-shade-dot\" style=\"background:${primary.hex};\"></div>\n        <div class=\"sf-shade-info\">\n          <div class=\"sf-shade-tag\">RECOMMENDED FOR YOU</div>\n          <strong>${primary.name}</strong>\n          <span>${primary.desc}</span>\n        </div>\n      </div>\n      ${showDuo ? `\n      <div class=\"sf-shade-card secondary\">\n        <div class=\"sf-shade-dot\" style=\"background:${secondary.hex};\"></div>\n        <div class=\"sf-shade-info\">\n          <div class=\"sf-shade-tag\">SECOND SHADE · YOUR BRONZED SELF</div>\n          <strong>${secondary.name}</strong>\n          <span>${secondary.desc}</span>\n        </div>\n      </div>` : ''}\n      <div class=\"sf-why-box\">\n        <strong>WHY THIS ${showDuo ? 'DUO' : 'SHADE'}</strong>\n        ${whyText}\n      </div>\n      <button class=\"sf-cta-btn\" id=\"sfAddBtn\">Add my shade${showDuo ? 's' : ''} to cart</button>\n      <p class=\"sf-cta-sub\">${showDuo ? 'Kabuki Brush included free' : 'Free delivery on orders over £40'}</p>\n      <div class=\"sf-trust-row\">\n        <div class=\"sf-trust-item\"><em>48h</em><span>Sun, water, clothes</span></div>\n        <div class=\"sf-trust-item\"><em>10 min</em><span>Kabuki Brush included</span></div>\n        <div class=\"sf-trust-item\"><em>30 days</em><span>Money-back guarantee</span></div>\n        <div class=\"sf-trust-item\"><em>✓</em><span>Dermo tested · DHA-free</span></div>\n      </div>\n      <span class=\"sf-restart\" id=\"sfRestart\">↺ Restart the quiz</span>`;\n\n    document.getElementById('sfAddBtn').addEventListener('click', () => {\n      close();\n      const atcBtn = document.querySelector('[name=\"add\"], .product-form__submit, #AddToCart');\n      if (atcBtn) atcBtn.scrollIntoView({ behavior: 'smooth', block: 'center' });\n    });\n    document.getElementById('sfRestart').addEventListener('click', () => {\n      answers = { skin: null, vein: null, sun: null, usage: null };\n      step = 1; render();\n    });\n  }\n\n  render();\n})();\n</script>"
          }
        },
