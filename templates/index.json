        "liquid": "<style>\n  .logo-bar {\n    width: 100%;\n    background: #f9f9f9;\n    padding: 18px 0 ;\n    overflow: hidden;\n    border-top: 1px solid #ebebeb;\n    border-bottom: 1px solid #ebebeb;\n  }\n\n  .logo-bar__label {\n    text-align: center;\n    font-size: 11px;\n    font-weight: 600;\n    letter-spacing: 0.12em;\n    color: #aaaaaa;\n    text-transform: uppercase;\n    margin-bottom: 14px;\n    font-family: sans-serif;\n  }\n\n  .logo-bar__track-wrapper {\n    overflow: hidden;\n    width: 100%;\n  }\n\n  .logo-bar__track {\n    display: flex;\n    width: max-content;\n    animation: scroll-logos 18s linear infinite;\n  }\n\n  .logo-bar__track:hover {\n    animation-play-state: paused;\n  }\n\n  .logo-bar__set {\n    display: flex;\n    align-items: center;\n    gap: 60px;\n    padding-right: 60px;\n  }\n\n  .logo-bar__item {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    flex-shrink: 0;\n  }\n\n  .logo-bar__item img {\n    height: 28px;\n    width: auto;\n    object-fit: contain;\n    filter: grayscale(100%) opacity(45%);\n    transition: filter 0.3s ease;\n  }\n\n  .logo-bar__item img:hover {\n    filter: grayscale(0%) opacity(100%);\n  }\n\n  @keyframes scroll-logos {\n    0%   { transform: translateX(0); }\n    100% { transform: translateX(-50%); }\n  }\n\n  @media (max-width: 768px) {\n    .logo-bar__item img {\n      height: 22px;\n    }\n    .logo-bar__set {\n      gap: 40px;\n      padding-right: 40px;\n    }\n    .logo-bar__track {\n      animation-duration: 14s;\n    }\n  }\n</style>\n\n<div class=\"logo-bar\">\n  <p class=\"logo-bar__label\">As Seen In</p>\n  <div class=\"logo-bar__track-wrapper\">\n    <div class=\"logo-bar__track\">\n\n      <div class=\"logo-bar__set\">\n        <div class=\"logo-bar__item\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/pupbowl-chewy_430x.svg?v=1782476774\" alt=\"Chewy\" loading=\"lazy\">\n        </div>\n        <div class=\"logo-bar__item\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/pupbowl-thedodo_430x.svg?v=1782476805\" alt=\"The Dodo\" loading=\"lazy\">\n        </div>\n        <div class=\"logo-bar__item\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/pupbowl-brand3_430x.png?v=1782476806\" alt=\"Brand\" loading=\"lazy\">\n        </div>\n        <div class=\"logo-bar__item\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/pupbowl-akc_430x.png?v=1782476807\" alt=\"American Kennel Club\" loading=\"lazy\">\n        </div>\n      </div>\n\n      <div class=\"logo-bar__set\">\n        <div class=\"logo-bar__item\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/pupbowl-chewy_430x.svg?v=1782476774\" alt=\"Chewy\" loading=\"lazy\">\n        </div>\n        <div class=\"logo-bar__item\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/pupbowl-thedodo_430x.svg?v=1782476805\" alt=\"The Dodo\" loading=\"lazy\">\n        </div>\n        <div class=\"logo-bar__item\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/pupbowl-brand3_430x.png?v=1782476806\" alt=\"Brand\" loading=\"lazy\">\n        </div>\n        <div class=\"logo-bar__item\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/pupbowl-akc_430x.png?v=1782476807\" alt=\"American Kennel Club\" loading=\"lazy\">\n        </div>\n      </div>\n\n      <div class=\"logo-bar__set\">\n        <div class=\"logo-bar__item\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/pupbowl-chewy_430x.svg?v=1782476774\" alt=\"Chewy\" loading=\"lazy\">\n        </div>\n        <div class=\"logo-bar__item\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/pupbowl-thedodo_430x.svg?v=1782476805\" alt=\"The Dodo\" loading=\"lazy\">\n        </div>\n        <div class=\"logo-bar__item\">\n          <i