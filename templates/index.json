ass=\"sg-section-head sg-section-head--green\">\n      <svg viewBox=\"0 0 24 24\"><path d=\"M17 8C8 10 5.9 16.17 3.82 22c1.5-3 3.5-5 6.18-5 .7 0 1.35.1 2 .28C13 14 16 10.5 17 8z\"/></svg>\n      Leaf Style\n    </div>\n    <table class=\"sg-table\">\n      <thead>\n        <tr>\n          <th>Size</th>\n          <th>Dimensions</th>\n          <th>Dog Weight</th>\n          <th>Best For</th>\n        </tr>\n      </thead>\n      <tbody>\n        <tr>\n          <td><span class=\"sg-size-badge\">S</span></td>\n          <td>34\" × 39\"</td>\n          <td>Up to 20 lbs</td>\n          <td>Cats, Chihuahuas, Yorkies, Maltese</td>\n        </tr>\n        <tr>\n          <td><span class=\"sg-size-badge\">M</span></td>\n          <td>48\" × 51\"</td>\n          <td>20 – 50 lbs</td>\n          <td>French Bulldogs, Beagles, Corgis</td>\n        </tr>\n        <tr>\n          <td><span class=\"sg-size-badge\">L</span></td>\n          <td>51\" × 59\"</td>\n          <td>50 – 80 lbs</td>\n          <td>Goldens, Labs, Huskies, Collies</td>\n        </tr>\n      </tbody>\n    </table>\n\n    <!-- SHELL -->\n    <div class=\"sg-section-head sg-section-head--blue\">\n      <svg viewBox=\"0 0 24 24\"><circle cx=\"12\" cy=\"12\" r=\"10\"/></svg>\n      Shell Style\n    </div>\n    <table class=\"sg-table\">\n      <thead>\n        <tr>\n          <th>Size</th>\n          <th>Dimensions</th>\n          <th>Dog Weight</th>\n          <th>Best For</th>\n        </tr>\n      </thead>\n      <tbody>\n        <tr>\n          <td><span class=\"sg-size-badge\">S</span></td>\n          <td>36\" × 34\"</td>\n          <td>Up to 20 lbs</td>\n          <td>Cats, Chihuahuas, Yorkies, Maltese</td>\n        </tr>\n        <tr>\n          <td><span class=\"sg-size-badge\">M</span></td>\n          <td>48\" × 45\"</td>\n          <td>20 – 50 lbs</td>\n          <td>French Bulldogs, Beagles, Corgis</td>\n        </tr>\n        <tr>\n          <td><span class=\"sg-size-badge\">L</span></td>\n          <td>55\" × 51\"</td>\n          <td>50 – 80 lbs</td>\n          <td>Goldens, Labs, Huskies, Collies</td>\n        </tr>\n      </tbody>\n    </table>\n\n    <div class=\"sg-tip\">\n      <svg viewBox=\"0 0 24 24\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n        <circle cx=\"12\" cy=\"12\" r=\"10\"/>\n        <line x1=\"12\" y1=\"8\" x2=\"12\" y2=\"8.5\" stroke-width=\"2.5\"/>\n        <line x1=\"12\" y1=\"11\" x2=\"12\" y2=\"16\"/>\n      </svg>\n      <span><strong>Pro Tip:</strong> If your pup is between sizes, we recommend sizing up for maximum comfort and coverage.</span>\n    </div>\n  </div>\n</div>\n\n<script>\n(function() {\n  // Timer\n  var total = 5 * 60;\n  function pad(n) { return n < 10 ? '0' + n : '' + n; }\n  function tick() {\n    if (total <= 0) { total = 5 * 60; }\n    var m = Math.floor(total / 60);\n    var s = total % 60;\n    var mEl = document.getElementById('cnMins');\n    var sEl = document.getElementById('cnSecs');\n    if (mEl) mEl.textContent = pad(m);\n    if (sEl) sEl.textContent = pad(s);\n    total--;\n  }\n  tick();\n  setInterval(tick, 1000);\n\n  // Modal\n  var btn = document.getElementById('cnSizeGuideBtn');\n  var overlay = document.getElementById('sgOverlay');\n  var closeBtn = document.getElementById('sgClose');\n\n  btn.addEventListener('click', function() {\n    overlay.classList.add('active');\n    document.body.style.overflow = 'hidden';\n  });\n\n  closeBtn.addEventListener('click', function() {\n    overlay.classList.remove('active');\n    document.body.style.overflow = '';\n  });\n\n  overlay.addEventListener('click', function(e) {\n    if (e.target === overlay) {\n      overlay.classList.remove('active');\n      document.body.style.overflow = '';\n    }\n  });\n})();\n</script>"
