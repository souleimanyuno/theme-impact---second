        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": true,
        "liquid": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap');\n\n  .cool-dogs {\n    width: 100%;\n    padding: 38px 0;\n    text-align: center;\n    font-family: 'Inter', sans-serif;\n    background: #fff;\n    overflow: hidden;\n  }\n\n  .cool-dogs__title {\n    font-size: 30px;\n    font-weight: 900;\n    color: #0d1f3c;\n    text-transform: uppercase;\n    letter-spacing: -0.01em;\n    margin-bottom: 10px;\n    padding: 0 20px;\n  }\n\n  .cool-dogs__title span {\n    color: #1a5cff;\n  }\n\n  .cool-dogs__subtitle {\n    font-size: 15px;\n    color: #444;\n    margin-bottom: 16px;\n    padding: 0 20px;\n  }\n\n  .cool-dogs__trust {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 8px;\n    margin-bottom: 28px;\n    font-size: 15px;\n    font-weight: 700;\n    color: #0d1f3c;\n  }\n\n  .cool-dogs__tp-stars {\n    display: flex;\n    gap: 3px;\n  }\n\n  .cool-dogs__tp-star {\n    width: 26px;\n    height: 26px;\n    background: #00b67a;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    border-radius: 3px;\n  }\n\n  .cool-dogs__tp-star svg {\n    width: 16px;\n    height: 16px;\n    fill: #fff;\n  }\n\n  .cool-dogs__tp-logo {\n    display: flex;\n    align-items: center;\n    gap: 4px;\n    font-size: 14px;\n    font-weight: 600;\n    color: #333;\n  }\n\n  .cool-dogs__tp-logo svg {\n    width: 16px;\n    height: 16px;\n  }\n\n  .cool-dogs__track-wrapper {\n    overflow-x: scroll;\n    overflow-y: hidden;\n    width: 100%;\n    cursor: grab;\n    -webkit-overflow-scrolling: touch;\n    scrollbar-width: none;\n    -ms-overflow-style: none;\n  }\n\n  .cool-dogs__track-wrapper::-webkit-scrollbar {\n    display: none;\n  }\n\n  .cool-dogs__track-wrapper:active {\n    cursor: grabbing;\n  }\n\n  .cool-dogs__track {\n    display: flex;\n    gap: 14px;\n    padding: 0 20px 8px 20px;\n    width: max-content;\n  }\n\n  .cool-dogs__card {\n    f