    "custom_liquid_gnJhNY": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": true,
        "liquid": "<div class=\"ugc-carousel-wrapper\">\n  <div class=\"ugc-track\" id=\"ugcTrack\">\n\n    <div class=\"ugc-card\">\n      <div class=\"ugc-img-wrap\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/IMG_6919_430x.jpg?v=1780978075\" alt=\"Emma review\" loading=\"lazy\">\n      </div>\n      <div class=\"ugc-review\">\n        <div class=\"ugc-stars\">★★★★★</div>\n        <p class=\"ugc-text\">\"I've had dark spots on my legs for years and always covered up. Applied SkinVeil™ before a BBQ and my sister asked if I'd had laser treatment. I haven't — it's just this.\"</p>\n        <div class=\"ugc-author\">\n          <span class=\"ugc-name\">Emma R.</span>\n          <span class=\"ugc-tag\">Verified Buyer · London</span>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"ugc-card\">\n      <div class=\"ugc-img-wrap\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/e1780d28-86f3-4820-833d-ffcd64e441ed_430x.jpg?v=1780978073\" alt=\"Sophie review\" loading=\"lazy\">\n      </div>\n      <div class=\"ugc-review\">\n        <div class=\"ugc-stars\">★★★★★</div>\n        <p class=\"ugc-text\">\"Thread veins behind my knees have stopped me wearing dresses for 4 summers. Wore a midi dress to my friend's wedding last weekend. Nobody noticed — including me after the first hour.\"</p>\n        <div class=\"ugc-author\">\n          <span class=\"ugc-name\">Sophie M.</span>\n          <span class=\"ugc-tag\">Verified Buyer · Manchester</span>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"ugc-card\">\n      <div class=\"ugc-img-wrap\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/IMG_6920_430x.jpg?v=1780978074\" alt=\"Claire review\" loading=\"lazy\">\n      </div>\n      <div class=\"ugc-review\">\n        <div class=\"ugc-stars\">★★★★★</div>\n        <p class=\"ugc-text\">\"I have a tattoo on my calf I regret. Applied two layers of SkinVeil™ before a job interview — completely invisible. Wore a skirt for the first time in 3 years.\"</p>\n        <div class=\"ugc-author\">\n          <span class=\"ugc-name\">Claire T.</span>\n          <span class=\"ugc-tag\">Verified Buyer · Birmingham</span>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"ugc-card\">\n      <div class=\"ugc-img-wrap\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/12712c8e3ad23d53bf99aa2dc28d5736_430x.jpg?v=1780978075\" alt=\"Natalie review\" loading=\"lazy\">\n      </div>\n      <div class=\"ugc-review\">\n        <div class=\"ugc-stars\">★★★★★</div>\n        <p class=\"ugc-text\">\"Post-pregnancy stretch marks on my thighs. Tried everything — Bio-Oil for months, nothing. SkinVeil™ covered them in 10 minutes. I wore shorts to the school run. First time since 2021.\"</p>\n        <div class=\"ugc-author\">\n          <span class=\"ugc-name\">Natalie B.</span>\n          <span class=\"ugc-tag\">Verified Buyer · Bristol</span>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"ugc-card\">\n      <div class=\"ugc-img-wrap\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/IMG_6922_430x.jpg?v=1780978074\" alt=\"Jessica review\" loading=\"lazy\">\n      </div>\n      <div class=\"ugc-review\">\n        <div class=\"ugc-stars\">★★★★★</div>\n        <p class=\"ugc-text\">\"Went to Ibiza with the girls. Applied SkinVeil™ every morning — swam, sweated, danced until 4am. Zero transfer on my white bikini. Zero touch-ups. Just me, finally comfortable in my skin.\"</p>\n        <div class=\"ugc-author\">\n          <span class=\"ugc-name\">Jessica H.</span>\n          <span class=\"ugc-tag\">Verified Buyer · Leeds</span>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"ugc-card\">\n      <div class=\"ugc-img-wrap\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/f359b380-a1ae-4144-a9c1-2f476328adb8_430x.jpg?v=1780978073\" alt=\"Rachel review\" loading=\"lazy\">\n      </div>\n      <div class=\"ugc-review\">\n        <div class=\"ugc-stars\">★★★★★</div>\n        <p class=\"ugc-text\">\"Knee scar from surgery two years ago. Left leg is me without — right leg is me with SkinVeil™. One application, 10 minutes. I wore a dress to my niece's birthday party for the first time since the operation.\"</p>\n        <div class=\"ugc-author\">\n          <span class=\"ugc-name\">Rachel W.</span>\n          <span class=\"ugc-tag\">Verified Buyer · Edinburgh</span>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"ugc-card\">\n      <div class=\"ugc-img-wrap\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/2a440f9b-9ca6-4bf8-b43e-7173095450ae_430x.jpg?v=1780978073\" alt=\"Lauren review\" loading=\"lazy\">\n      </div>\n      <div class=\"ugc-review\">\n        <div class=\"ugc-stars\">★★★★★</div>\n        <p class=\"ugc-text\">\"Surgical scar on my knee from a sports injury. Always wore leggings at the gym. Applied SkinVeil™ before a yoga class — wore shorts. My instructor asked what moisturiser I use.\"</p>\n        <div class=\"ugc-author\">\n          <span class=\"ugc-name\">Lauren K.</span>\n          <span class=\"ugc-tag\">Verified Buyer · Glasgow</span>\n        </div>\n      </div>\n    </div>\n\n  </div>\n  <div class=\"ugc-dots\" id=\"ugcDots\"></div>\n</div>\n\n<style>\n.trustpilot-clean {\n  text-align: center;\n  color: #000;\n  margin-bottom: 0 !important;\n  padding-bottom: 0 !important;\n}\n.trustpilot-clean h2 {\n  font-size: 22px;\n  font-weight: 700;\n  margin-bottom: 0.8rem;\n  line-height: 1.5;\n}\n.trustpilot-line {\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  gap: 8px;\n  font-size: 1rem;\n  margin-bottom: 0.5rem;\n}\n.rating-text,\n.rating-score {\n  font-size: 1rem;\n  line-height: 1;\n  display: inline-block;\n  vertical-align: middle;\n  margin-top: 2px;\n}\n.rating-score { font-weight: bold; }\n.stars-img {\n  width: 120px;\n  margin-right: 10px;\n  vertical-align: middle;\n}\n.trustpilot-bottom {\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  gap: 8px;\n  font-size: 0.95rem;\n  white-space: nowrap;\n}\n.tp-logo {\n  height: 24px;\n  margin-top: -2px;\n}\n\n/* CAROUSEL */\n.ugc-carousel-wrapper {\n  width: 100%;\n  overflow: hidden;\n  margin-top: 28px;\n  background: #f5ede6;\n}\n.ugc-track {\n  display: flex;\n  transition: transform 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94);\n  will-change: transform;\n  cursor: grab;\n  align-items: stretch;\n}\n.ugc-track:active { cursor: grabbing; }\n\n.ugc-card {\n  min-width: 100%;\n  width: 100%;\n  flex-shrink: 0;\n  display: flex;\n  flex-direction: column;\n  background: #fff;\n}\n\n.ugc-img-wrap {\n  width: 100%;\n  aspect-ratio: 3/4;\n  overflow: hidden;\n  background: #e8ddd6;\n  flex-shrink: 0;\n}\n.ugc-img-wrap img {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  object-position: center top;\n  display: block;\n}\n\n.ugc-review {\n  padding: 18px 20px 22px;\n  background: #fff;\n  border-top: 2px solid #f5ede6;\n  flex: 1;\n  display: flex;\n  flex-direction: column;\n  justify-content: space-between;\n}\n.ugc-stars {\n  color: #f5a623;\n  font-size: 18px;\n  margin-bottom: 10px;\n  letter-spacing: 3px;\n}\n.ugc-text {\n  font-size: 14px;\n  line-height: 1.65;\n  color: #2a2a2a;\n  margin: 0 0 14px 0;\n  font-style: italic;\n  flex: 1;\n}\n.ugc-author {\n  display: flex;\n  flex-direction: column;\n  gap: 3px;\n  border-top: 1px solid #f0e8e0;\n  padding-top: 12px;\n}\n.ugc-name {\n  font-size: 14px;\n  font-weight: 700;\n  color: #1a1a2e;\n}\n.ugc-tag {\n  font-size: 11px;\n  color: #aaa;\n  text-transform: uppercase;\n  letter-spacing: 0.5px;\n}\n\n/* DOTS */\n.ugc-dots {\n  display: flex;\n  justify-content: center;\n  gap: 7px;\n  padding: 16px 0 20px;\n  background: #f5ede6;\n}\n.ugc-dot {\n  width: 7px;\n  height: 7px;\n  border-radius: 50%;\n  background: #c9b8ac;\n  transition: background 0.3s, transform 0.3s;\n  cursor: pointer;\n}\n.ugc-dot.active {\n  background: #1a1a2e;\n  transform: scale(1.35);\n}\n\n/* DESKTOP */\n@media (min-width: 768px) {\n  .ugc-card {\n    min-width: 50%;\n    width: 50%;\n  }\n}\n</style>\n\n<script>\n(function() {\n  const track = document.getElementById('ugcTrack');\n  const dotsContainer = document.getElementById('ugcDots');\n  const cards = track.querySelectorAll('.ugc-card');\n  const total = cards.length;\n  let current = 0;\n  let startX = 0;\n  let isDragging = false;\n  let autoTimer;\n\n  function cardsPerView() {\n    return window.innerWidth >= 768 ? 2 : 1;\n  }\n  function maxIndex() {\n    return total - cardsPerView();\n  }\n  function buildDots() {\n    dotsContainer.innerHTML = '';\n    const count = maxIndex() + 1;\n    for (let i = 0; i < count; i++) {\n      const dot = document.createElement('div');\n      dot.className = 'ugc-dot' + (i === 0 ? ' active' : '');\n      dot.addEventListener('click', () => goTo(i));\n      dotsContainer.appendChild(dot);\n    }\n  }\n  function updateDots() {\n    dotsContainer.querySelectorAll('.ugc-dot').forEach((d, i) => {\n      d.classList.toggle('active', i === current);\n    });\n  }\n  function goTo(index) {\n    const max = maxIndex();\n    current = ((index % (max + 1)) + (max + 1)) % (max + 1);\n    const pct = (100 / cardsPerView()) * current;\n    track.style.transform = `translateX(-${pct}%)`;\n    updateDots();\n  }\n  function next() { goTo(current + 1); }\n\n  track.addEventListener('touchstart', e => {\n    startX = e.touches[0].clientX;\n    clearInterval(autoTimer);\n  }, { passive: true });\n  track.addEventListener('touchend', e => {\n    const diff = startX - e.changedTouches[0].clientX;\n    if (Math.abs(diff) > 50) diff > 0 ? next() : goTo(current - 1);\n    startAuto();\n  }, { passive: true });\n  track.addEventListener('mousedown', e => {\n    isDragging = true;\n    startX = e.clientX;\n    clearInterval(autoTimer);\n  });\n  window.addEventListener('mouseup', e => {\n    if (!isDragging) return;\n    isDragging = false;\n    const diff = startX - e.clientX;\n    if (Math.abs(diff) > 50) diff > 0 ? next() : goTo(current - 1);\n    startAuto();\n  });\n\n  function startAuto() {\n    clearInterval(autoTimer);\n    autoTimer = setInterval(next, 4000);\n  }\n  window.addEventListener('resize', () => {\n    buildDots();\n    goTo(current);\n  });\n\n  buildDots();\n  goTo(0);\n  startAuto();\n})();\n</script>",
        "background": "",
        "background_gradient": "",
        "text_color": ""
      }
    },
    "custom_liquid_WgJTim": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": true,
        "liquid": "<div class=\"sv-faq2-section\">\n  <p class=\"sv-faq2-label\">FREQUENTLY ASKED QUESTIONS</p>\n  <h2 class=\"sv-faq2-title\">QUESTIONS? WE'RE HERE TO HELP</h2>\n  <p class=\"sv-faq2-contact\">Email us at <a href=\"mailto:support@mysorelya.com\">support@mysorelya.com</a> — we reply within 24 hours.</p>\n\n  <div class=\"sv-faq2-list\">\n\n    <div class=\"sv-faq2-item\">\n      <button class=\"sv-faq2-q\" aria-expanded=\"false\">\n        <span>How do I choose the right shade from the 6 available?</span>\n        <svg class=\"sv-faq2-chevron\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"6 9 12 15 18 9\"/></svg>\n      </button>\n      <div class=\"sv-faq2-a\">\n        <p>Choose the shade closest to your natural skin tone. If you want a subtle bronzed effect, go one shade darker. When in doubt, go lighter — you can always layer for more depth. Use our 60-second shade quiz for a personalised recommendation.</p>\n      </div>\n    </div>\n\n    <div class=\"sv-faq2-item\">\n      <button class=\"sv-faq2-q\" aria-expanded=\"false\">\n        <span>How long does one tube last?</span>\n        <svg class=\"sv-faq2-chevron\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"6 9 12 15 18 9\"/></svg>\n      </button>\n      <div class=\"sv-faq2-a\">\n        <p>Covering both legs from ankle to thigh takes approximately 10ml — roughly 12 applications per tube. Used 3 times a week, one tube lasts about a month. Most customers order 2 tubes for the summer season.</p>\n      </div>\n    </div>\n\n    <div class=\"sv-faq2-item\">\n      <button class=\"sv-faq2-q\" aria-expanded=\"false\">\n        <span>Can I use it on my face, décolletage, arms and hands?</span>\n        <svg class=\"sv-faq2-chevron\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"6 9 12 15 18 9\"/></svg>\n      </button>\n      <div class=\"sv-faq2-a\">\n        <p>Yes — anywhere you want to cover something. Sun spots on the décolletage, thread veins on the hands, scars on the arms or back. On the face, use sparingly on specific areas such as redness or post-acne marks — it is not designed as a daily facial foundation.</p>\n      </div>\n    </div>\n\n    <div class=\"sv-faq2-item\">\n      <button class=\"sv-faq2-q\" aria-expanded=\"false\">\n        <span>Does it work on tattoos and keloid scars?</span>\n        <svg class=\"sv-faq2-chevron\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"6 9 12 15 18 9\"/></svg>\n      </button>\n      <div class=\"sv-faq2-a\">\n        <p><strong>Tattoos:</strong> small and light-coloured tattoos disappear with one or two layers. Large, dark or heavily saturated tattoos are partially covered — the outline may remain slightly visible.</p>\n        <p><strong>Keloid scars:</strong> the pigment adheres perfectly to the scar tissue, covering the colour effectively. The raised texture may still be felt but will no longer be visible.</p>\n      </div>\n    </div>\n\n    <div class=\"sv-faq2-item\">\n      <button class=\"sv-faq2-q\" aria-expanded=\"false\">\n        <span>Is it safe during pregnancy, breastfeeding and for sensitive skin?</span>\n        <svg class=\"sv-faq2-chevron\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"6 9 12 15 18 9\"/></svg>\n      </button>\n      <div class=\"sv-faq2-a\">\n        <p>SkinVeil™ is free from DHA, parabens, phthalates and synthetic fragrance. Dermatologically tested and nickel-tested. Suitable for reactive and sensitive skin types. If you are pregnant or breastfeeding, we recommend consulting your GP before use, as with any cosmetic product.</p>\n      </div>\n    </div>\n\n    <div class=\"sv-faq2-item\">\n      <button class=\"sv-faq2-q\" aria-expanded=\"false\">\n        <span>Is SkinVeil™ vegan and cruelty-free?</span>\n        <svg class=\"sv-faq2-chevron\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"6 9 12 15 18 9\"/></svg>\n      </button>\n      <div class=\"sv-faq2-a\">\n        <p>Yes — 100% vegan and cruelty-free. No animal-derived ingredients, and no animal testing at any stage of development or production. Free from parabens, phthalates, alcohol, DHA and synthetic fragrances.</p>\n      </div>\n    </div>\n\n    <div class=\"sv-faq2-item\">\n      <button class=\"sv-faq2-q\" aria-expanded=\"false\">\n        <span>How do I apply it on my back if I'm on my own?</span>\n        <svg class=\"sv-faq2-chevron\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"6 9 12 15 18 9\"/></svg>\n      </button>\n      <div class=\"sv-faq2-a\">\n        <p>The included kabuki brush has a long handle designed for this. For the upper back, pass the brush over your shoulder. For the lower back, reach from underneath with a slight bend. For the very centre, a back roller extension works well — or ask a partner for 30 seconds of help. The formula self-levels during drying, so perfect precision is not required.</p>\n      </div>\n    </div>\n\n  </div>\n</div>\n\n<style>\n.sv-faq2-section {\n  padding: 48px 16px 36px;\n  background: #ffffff;\n  font-family: -apple-system, 'Helvetica Neue', Arial, sans-serif;\n  text-align: center;\n}\n\n.sv-faq2-label {\n  font-size: 11px;\n  font-weight: 700;\n  letter-spacing: 1.5px;\n  text-transform: uppercase;\n  color: #999;\n  margin: 0 0 10px;\n}\n\n.sv-faq2-title {\n  font-family: 'Helvetica Neue', Arial, sans-serif;\n  font-size: 28px;\n  font-weight: 900;\n  color: #1a1a2e;\n  margin: 0 0 12px;\n  line-height: 1.1;\n  letter-spacing: -0.5px;\n  text-transform: uppercase;\n}\n\n.sv-faq2-contact {\n  font-size: 14px;\n  color: #888;\n  margin: 0 0 36px;\n  line-height: 1.5;\n}\n\n.sv-faq2-contact a {\n  color: #c9a84c;\n  text-decoration: none;\n}\n\n.sv-faq2-list {\n  text-align: left;\n  border-top: 1px solid #e8e8e8;\n}\n\n.sv-faq2-item {\n  border-bottom: 1px solid #e8e8e8;\n}\n\n.sv-faq2-q {\n  width: 100%;\n  background: none;\n  border: none;\n  padding: 18px 0;\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 12px;\n  cursor: pointer;\n  text-align: left;\n  font-family: -apple-system, 'Helvetica Neue', Arial, sans-serif;\n  font-size: 15px;\n  font-weight: 700;\n  color: #1a1a2e;\n  line-height: 1.4;\n}\n\n.sv-faq2-q:hover {\n  color: #c9a84c;\n}\n\n.sv-faq2-chevron {\n  flex-shrink: 0;\n  color: #1a1a2e;\n  transition: transform 0.3s ease;\n}\n\n.sv-faq2-q[aria-expanded=\"true\"] .sv-faq2-chevron {\n  transform: rotate(180deg);\n}\n\n.sv-faq2-a {\n  display: none;\n  padding: 0 0 18px;\n  font-size: 14px;\n  color: #555;\n  line-height: 1.7;\n}\n\n.sv-faq2-a p {\n  margin: 0 0 10px;\n}\n\n.sv-faq2-a p:last-child {\n  margin-bottom: 0;\n}\n\n.sv-faq2-a strong {\n  color: #1a1a2e;\n}\n\n.sv-faq2-item.open .sv-faq2-a {\n  display: block;\n}\n</style>\n\n<script>\ndocument.querySelectorAll('.sv-faq2-q').forEach(btn => {\n  btn.addEventListener('click', () => {\n    const item = btn.closest('.sv-faq2-item');\n    const isOpen = item.classList.contains('open');\n    document.querySelectorAll('.sv-faq2-item').forEach(i => {\n      i.classList.remove('open');\n      i.querySelector('.sv-faq2-q').setAttribute('aria-expanded', 'false');\n    });\n    if (!isOpen) {\n      item.classList.add('open');\n      btn.setAttribute('aria-expanded', 'true');\n    }\n  });\n});\n</script>",
