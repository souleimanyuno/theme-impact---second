        "liquid": "<style>\n  .sorelya-benefits,\n  .sorelya-benefits * {\n    box-sizing: border-box;\n  }\n\n  .sorelya-benefits {\n    width: 100%;\n    padding: 58px 22px 62px;\n    overflow: hidden;\n    background: #fff;\n    color: #161214;\n    font-family: Arial, Helvetica, sans-serif;\n  }\n\n  .sorelya-benefits__inner {\n    width: 100%;\n    max-width: 1460px;\n    margin: 0 auto;\n  }\n\n  /* =========================\n     HEADER\n  ========================= */\n\n  .sorelya-benefits__heading {\n    max-width: 1150px;\n    margin: 0 auto 14px;\n    color: #111;\n    font-size: clamp(36px, 5vw, 70px);\n    font-weight: 900;\n    line-height: 1.02;\n    text-align: center;\n    letter-spacing: -0.045em;\n    text-transform: uppercase;\n  }\n\n  .sorelya-benefits__subheading {\n    max-width: 670px;\n    margin: 0 auto 42px;\n    color: #746a6d;\n    font-size: 17px;\n    font-weight: 500;\n    line-height: 1.55;\n    text-align: center;\n  }\n\n  /* =========================\n     GRID\n  ========================= */\n\n  .sorelya-benefits__grid {\n    display: grid;\n    grid-template-columns: repeat(2, minmax(0, 1fr));\n    gap: 28px 32px;\n  }\n\n  .sorelya-benefit-card {\n    display: flex;\n    align-items: center;\n    gap: 22px;\n    min-height: 145px;\n    padding: 28px 30px;\n    border: 1px solid #eee9e6;\n    border-radius: 20px;\n    background: #faf9f8;\n  }\n\n  /* =========================\n     ICONS\n  ========================= */\n\n  .sorelya-benefit-card__icon {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    flex: 0 0 auto;\n    width: 66px;\n    height: 66px;\n    border-radius: 50%;\n    background: #f4e9e4;\n    color: #8d3451;\n  }\n\n  .sorelya-benefit-card__icon svg {\n    width: 31px;\n    height: 31px;\n    fill: none;\n    stroke: currentColor;\n    stroke-width: 1.8;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n\n  .sorelya-benefit-card__icon--ph {\n    font-size: 22px;\n    font-weight: 900;\n    letter-spacing: -0.04em;\n  }\n\n  /* =========================\n     COPY\n  ========================= */\n\n  .sorelya-benefit-card__content {\n    min-width: 0;\n  }\n\n  .sorelya-benefit-card__title {\n    margin: 0 0 8px;\n    color: #171214;\n    font-size: 22px;\n    font-weight: 900;\n    line-height: 1.15;\n    letter-spacing: -0.025em;\n  }\n\n  .sorelya-benefit-card__text {\n    margin: 0;\n    color: #71696c;\n    font-size: 16px;\n    font-weight: 500;\n    line-height: 1.5;\n  }\n\n  /* =========================\n     MOBILE\n  ========================= */\n\n  @media (max-width: 749px) {\n    .sorelya-benefits {\n      padding: 40px 16px 42px;\n    }\n\n    .sorelya-benefits__heading {\n      max-width: 350px;\n      font-size: 32px;\n      line-height: 1.04;\n    }\n\n    .sorelya-benefits__subheading {\n      max-width: 340px;\n      margin-bottom: 28px;\n      font-size: 14.5px;\n      line-height: 1.5;\n    }\n\n    .sorelya-benefits__grid {\n      grid-template-columns: 1fr;\n      gap: 12px;\n    }\n\n    .sorelya-benefit-card {\n      gap: 15px;\n      min-height: 0;\n      padding: 18px 16px;\n      border-radius: 15px;\n    }\n\n    .sorelya-benefit-card__icon {\n      width: 49px;\n      height: 49px;\n    }\n\n    .sorelya-benefit-card__icon svg {\n      width: 24px;\n      height: 24px;\n    }\n\n    .sorelya-benefit-card__icon--ph {\n      font-size: 17px;\n    }\n\n    .sorelya-benefit-card__title {\n      margin-bottom: 5px;\n      font-size: 17px;\n    }\n\n    .sorelya-benefit-card__text {\n      font-size: 13.5px;\n      line-height: 1.43;\n    }\n  }\n</style>\n\n<section class=\"sorelya-benefits\">\n  <div class=\"sorelya-benefits__inner\">\n\n    <h2 class=\"sorelya-benefits__heading\">\n      Why Mature Lips Are Making the Switch\n    </h2>\n\n    <p class=\"sorelya-benefits__subheading\">\n      Everything traditional lipstick makes difficult—SORELYA was\n      designed to make easier.\n    </p>\n\n    <div class=\"sorelya-benefits__grid\">\n\n      <!-- 1 -->\n      <article class=\"sorelya-benefit-card\">\n        <div class=\"sorelya-benefit-card__icon sorelya-benefit-card__icon--ph\">\n          pH\n        </div>\n\n        <div class=\"sorelya-benefit-card__content\">\n          <h3 class=\"sorelya-benefit-card__title\">\n            A Tint That Develops on Your Lips\n          </h3>\n\n          <p class=\"sorelya-benefit-card__text\">\n            It starts almost clear, then gradually develops over your\n            natural lip tone into a personalized-looking shade.\n          </p>\n        </div>\n      </article>\n\n      <!-- 2 -->\n      <article class=\"sorelya-benefit-card\">\n        <div class=\"sorelya-benefit-card__icon\">\n          <svg viewBox=\"0 0 24 24\">\n            <path d=\"M3 12c3-4 6-6 9-6s6 2 9 6c-3 4-6 6-9 6s-6-2-9-6z\"/>\n            <path d=\"M6 12h12\"/>\n          </svg>\n        </div>\n\n        <div class=\"sorelya-benefit-card__content\">\n          <h3 class=\"sorelya-benefit-card__title\">\n            Helps Stay Out of Lip Lines\n          </h3>\n\n          <p class=\"sorelya-benefit-card__text\">\n            Lightweight color designed to keep your lip contour looking\n            cleaner instead of creeping into the fine lines around it.\n          </p>\n        </div>\n      </article>\n\n      <!-- 3 -->\n      <article class=\"sorelya-benefit-card\">\n        <div class=\"sorelya-benefit-card__icon\">\n          <svg viewBox=\"0 0 24 24\">\n            <path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/>\n            <polyline points=\"9 12 11 14 15 10\"/>\n          </svg>\n        </div>\n\n        <div class=\"sorelya-benefit-card__content\">\n          <h3 class=\"sorelya-benefit-card__title\">\n            Made With Mature Lips in Mind\n          </h3>\n\n          <p class=\"sorelya-benefit-card__text\">\n            Because the lipstick that worked at 25 may no longer feel\n            right on the lips