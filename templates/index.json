        "liquid_AJfHaK": {
          "type": "liquid",
          "settings": {
            "liquid": "<details class=\"collapsible-size-guide\">\n  <summary class=\"collapsible-size-guide__summary\">Größentabelle</summary>\n  <div class=\"collapsible-size-guide__content\">\n    <p class=\"collapsible-size-guide__text\">Unsere Strumpfhosen sind so konzipiert, dass sie <strong>formen und schmeicheln</strong>. Wähle deine Größe basierend auf deinem Gewicht für die perfekte Passform.</p>\n    \n    <p class=\"collapsible-size-guide__text\">Zwischen zwei Größen? <strong>Nimm die größere</strong> – die formende Wirkung bleibt vollständig erhalten.</p>\n    \n    <p class=\"collapsible-size-guide__text\">Für die genaueste Passform, beachte die <strong>Größentabelle unten</strong>.</p>\n    \n    <div class=\"collapsible-size-guide__image\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/17_430x.png?v=1771743227#\" alt=\"Sorelya Größentabelle\" loading=\"lazy\">\n    </div>\n  </div>\n</details>\n<style>\n  .collapsible-size-guide__summary {\n    cursor: pointer;\n    font-weight: bold;\n    padding: 12px 0;\n    list-style: none;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n  }\n  \n  .collapsible-size-guide__summary::-webkit-details-marker {\n    display: none;\n  }\n  \n  .collapsible-size-guide__summary::after {\n    content: '+';\n    font-size: 20px;\n    font-weight: bold;\n    transition: transform 0.3s ease;\n  }\n  \n  .collapsible-size-guide[open] .collapsible-size-guide__summary::after {\n    content: '−';\n  }\n  \n  .collapsible-size-guide__content {\n    padding: 15px 0;\n    line-height: 1.6;\n  }\n  \n  .collapsible-size-guide__text {\n    margin-bottom: 15px;\n  }\n  \n  .collapsible-size-guide__text:last-of-type {\n    margin-bottom: 0;\n  }\n  \n  .collapsible-size-guide__image {\n    margin-top: 20px;\n  }\n  \n  .collapsible-size-guide__image img {\n    width: 100%;\n    max-width: 600px;\n    height: auto;\n    display: block;\n  }\n</style>"
          }
